{
  "name": "csv-filter-backend",
  "version": "1.0.0",
  "description": "Backend for CSV/Excel transformation webapp",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "seed": "node src/seed.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "csv",
    "excel",
    "transform",
    "mern"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/ai-form-recognizer": "^5.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parser": "^3.0.0",
    "date-fns": "^3.0.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "fast-csv": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.0.2",
    "openai": "^6.33.0",
    "pdf2pic": "^3.2.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "prisma": "^5.22.0"
  }
