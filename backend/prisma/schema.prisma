// ═══════════════════════════════════════════════════════════════
// Future Foods Portal — Full Application Schema
// PostgreSQL via Prisma
//
// ── Core multi-tenant models ─────────────────────────────────
//   Organization  = tenant (was MongoDB Tenant)
//   Store         = physical location within an org
//   User          = employee / admin account
//   UserStore     = many-to-many: user ↔ store
//
// ── Operations ───────────────────────────────────────────────
//   Invoice       = vendor invoice (OCR-processed PDF/image)
//   Customer      = loyalty / charge-account customer
//   FeeMapping    = maps fee labels → internal fee types
//   PosToken      = cached POS auth token per user/store
//   PosLog        = POS API call audit log (TTL 30 days)
//   WeatherCache  = daily weather fetched from Open-Meteo
//   Document      = generic document OCR store
//   VendorProductMap = vendor item code ↔ POS product lookup
//
// ── CSV transform pipeline ───────────────────────────────────
//   Upload / Transform / DepositMap  (MongoDB models.js)
//
// ── Native POS Catalog ───────────────────────────────────────
//   Department / TaxRule / DepositRule / Vendor
//   RebateProgram / MasterProduct / StoreProduct
//
// ID strategy:
//   cuid()           → user-facing records (User, Store, Invoice…)
//   autoincrement()  → high-volume logs / cache tables
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────
// DEPARTMENT
// Org-level product groupings (Beer, Wine, Grocery…)
// ─────────────────────────────────────────────────
model Department {
  id          Int     @id @default(autoincrement())
  orgId       String // tenant isolation
  name        String
  code        String? // "BEER", "WINE", "SPIRITS", "GROC", "TOBAC", "FOOD"
  description String?

  // Session 4b — explicit category for attribute preset matching.
  // Decouples preset matching from dept NAME so retailers can call the dept
  // whatever they want (Vino, Cerveza, etc.) without breaking the preset.
  // Valid values: wine | liquor | beer | tobacco | general | null
  category String?

  // Age verification
  ageRequired Int? // minimum purchase age: 21 (alcohol), 18 (tobacco), null (none)

  // Tax / EBT
  ebtEligible    Boolean  @default(false)
  taxClass       String? // "alcohol", "tobacco", "hot_food", "grocery", "none"
  defaultTaxRate Decimal? @db.Decimal(6, 4) // override if no TaxRule matched

  // Industry flags — restrict features by industry profile
  // e.g. bottle deposits only relevant for "liquor" / "grocery"
  bottleDeposit Boolean @default(false)

  // Display
  sortOrder Int     @default(0)
  color     String? // hex color for POS UI
  showInPOS Boolean @default(true) // whether dept appears as category filter in POS
  active    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      MasterProduct[]
  productGroups ProductGroup[]
  attributes    DepartmentAttribute[]

  @@unique([orgId, code])
  @@index([orgId, active])
  @@map("departments")
}

// ─────────────────────────────────────────────────
// VENDOR IMPORT TEMPLATE — Session 5
// Superadmin-curated mapping profiles for common wholesaler CSV formats.
// Each template declares: which import type it targets (products / promotions /
// deposits / invoice_costs), and for each column in the vendor file, how to
// map + transform it into our canonical field. Retailers pick a template at
// upload time; the engine applies the mapping + transforms, then hands rows
// to the existing import pipeline.
// ─────────────────────────────────────────────────
model VendorImportTemplate {
  id          Int      @id @default(autoincrement())
  name        String // "AGNE — Wholesale", "Sante POS — Export", etc.
  slug        String   @unique // "agne", "sante-pos", "pine-state-specials"
  description String?
  target      String // "products" | "promotions" | "deposits" | "invoice_costs"
  vendorHint  String? // free-text hint for matching, e.g. "AGNE, Associated Grocers"
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mappings VendorImportTemplateMapping[]

  @@index([target, active])
  @@map("vendor_import_templates")
}

model VendorImportTemplateMapping {
  id         Int                  @id @default(autoincrement())
  templateId Int
  template   VendorImportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  vendorColumn  String // exact header text in the vendor file, e.g. "REG_RETAIL", "Unit Cost"
  targetField   String? // canonical field key, e.g. "upc", "defaultRetailPrice", or "" for drop/skip
  transform     String? // transform fn name: "trim_leading_zero" | "strip_prefix" | "multiply_by_col" | etc. null = no transform
  transformArgs Json? // arg payload, e.g. { by: "pack" } for multiply_by_col, { prefix: "_" } for strip_prefix
  constantValue String? // if set, use this literal value instead of the vendor column (for filling a column the file doesn't provide)
  skip          Boolean @default(false) // when true, column is explicitly ignored
  sortOrder     Int     @default(0)

  @@index([templateId])
  @@map("vendor_import_template_mappings")
}

// ─────────────────────────────────────────────────
// DEPARTMENT ATTRIBUTE — typed metadata fields per department.
// Wine has Vintage / Country / Varietal; Liquor has Proof / ABV; etc.
// Rendered dynamically on the Product Form based on the product's dept.
// Admins add/remove/edit via the department management UI. Seeded with
// sensible defaults for alcohol/tobacco so retailers get value on day 1.
// ─────────────────────────────────────────────────
model DepartmentAttribute {
  id           Int         @id @default(autoincrement())
  orgId        String
  departmentId Int? // null = applies to all products org-wide
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  key         String // internal key: "vintage", "abv", "country"
  label       String // user-facing label: "Vintage Year"
  dataType    String   @default("text") // text | decimal | integer | boolean | date | dropdown
  required    Boolean  @default(false)
  options     String[] @default([]) // for dropdown: ["Red","White","Rosé"]
  unit        String? // display suffix e.g. "%" for ABV, "°" for Proof
  placeholder String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, departmentId, key])
  @@index([orgId, departmentId, active])
  @@map("department_attributes")
}

// ─────────────────────────────────────────────────
// TAX RULE
// Configurable tax rates per org / store / product class
// ─────────────────────────────────────────────────
model TaxRule {
  id      Int     @id @default(autoincrement())
  orgId   String
  storeId String? // null = org-wide default; set to override for a specific store
  name    String // "Maine State Food Tax", "Maine Alcohol Excise"

  rate Decimal @db.Decimal(6, 4) // e.g. 0.0550 = 5.5%

  // The ONLY matcher. A rule applies when the product's departmentId is in
  // this array. The legacy `appliesTo` string class matcher was removed in
  // Session 56b — every rule must now target one or more departments. The
  // migration `prisma/migrateTaxRulesToDepartments.mjs` converted existing
  // class-only rules to dept-linked rules before the column was dropped.
  // For org-wide "tax everything" rules, link to every active department
  // in the org via the multi-select chip UI.
  departmentIds Int[] @default([])

  // EBT: if true, EBT-eligible items are exempt from this tax
  ebtExempt Boolean @default(true)

  // Geographic — used for grouping the rules list when an org has rules
  // tagged with multiple distinct states. Not part of tax matching at
  // checkout. Auto-prefilled from Store.stateCode for single-state orgs
  // so single-store admins never see this field. (Session 56 simplification:
  // dropped `description` and `county` columns — both were cosmetic-only.)
  state String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Products with an explicit per-product override pointing at this rule.
  // Phase 1 of the strict-FK migration (Session 40) — used by delete-guard
  // in catalogController.deleteTaxRule to block removing a rule that's
  // still referenced by N products.
  products MasterProduct[]

  @@index([orgId])
  @@map("tax_rules")
}

// ─────────────────────────────────────────────────
// DEPOSIT RULE
// Container redemption value (CRV) / bottle deposit
// Maine: <24oz = $0.05, ≥24oz = $0.15
// ─────────────────────────────────────────────────
model DepositRule {
  id          Int     @id @default(autoincrement())
  orgId       String
  name        String // "Maine CRV Small", "Maine CRV Large"
  description String?

  // Volume range (oz) — null means no limit in that direction
  minVolumeOz Float? // inclusive lower bound
  maxVolumeOz Float? // exclusive upper bound (null = no max)

  // Container types this rule applies to (comma-separated)
  containerTypes String @default("bottle,can") // "bottle", "can", "carton", "jug"

  depositAmount Decimal @db.Decimal(10, 4) // e.g. 0.05 or 0.15

  // Geographic
  state String? // "ME"

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      MasterProduct[]
  productGroups ProductGroup[]

  @@index([orgId, state])
  @@map("deposit_rules")
}

// ─────────────────────────────────────────────────
// VENDOR
// Supplier / distributor records
// ─────────────────────────────────────────────────
model Vendor {
  id    Int     @id @default(autoincrement())
  orgId String
  name  String
  code  String? // short code e.g. "HERSHEYS", "PINE-STATE"

  // Contact
  contactName String?
  email       String?
  phone       String?
  address     Json? // { street, city, state, zip }
  website     String?

  // Terms
  terms     String? // "Net 30", "Net 14", "COD"
  accountNo String? // our account number with this vendor

  // Invoice import — link vendor aliases used in invoices
  aliases String[] // ["Hershey's", "HERSHEY ICE CREAM"] for fuzzy matching

  active Boolean @default(true)

  // ── Ordering / Fulfillment ──
  leadTimeDays   Int       @default(3) // avg days from order to delivery
  minOrderAmount Decimal?  @db.Decimal(10, 2) // minimum $ per order
  orderFrequency String    @default("weekly") // "daily","weekly","biweekly","monthly"
  deliveryDays   String[]  @default([]) // ["Monday","Thursday"]
  lastOrderedAt  DateTime?

  // Target days of supply to keep on hand for products from this vendor.
  // Drives orderEngine.generateSuggestions sizing — orderQty aims to cover
  // (leadTimeDays + targetCoverageDays) of forecast demand. When null,
  // engine falls back to its existing review-period heuristic.
  targetCoverageDays Int?

  // ── Delivery scheduling ──
  orderCutoffTime       String? // "14:00" — must order by this time for next delivery
  orderCutoffDaysBefore Int     @default(1) // order N days before delivery day
  autoOrderEnabled      Boolean @default(false) // auto-generate draft POs
  preferredServiceLevel String  @default("standard") // "critical","standard","low"
  vendorNotes           String? // internal notes

  // Invoice cost sync — only consulted when store's invoiceCostSync.mode
  // (in store.pos JSON) is set to 'per-vendor'. When true, this vendor's
  // invoices will update matched products' defaultCasePrice. When false,
  // cost changes from this vendor are skipped (manual only).
  autoSyncCostFromInvoice Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       MasterProduct[]
  purchaseOrders PurchaseOrder[]
  vendorReturns  VendorReturn[]
  productGroups  ProductGroup[]
  productVendors ProductVendor[]

  @@unique([orgId, name])
  @@index([orgId, active])
  @@map("vendors")
}

// ─────────────────────────────────────────────────
// REBATE PROGRAM
// Manufacturer coupons / tobacco rebates
// (Marlboro, Newport, Camel, etc.)
// ─────────────────────────────────────────────────
model RebateProgram {
  id           Int     @id @default(autoincrement())
  orgId        String
  name         String // "Marlboro Premium Retailer Rebate"
  manufacturer String // "Philip Morris", "RJ Reynolds"
  description  String?

  // Which products qualify (can link to specific MasterProducts later)
  qualifyingUpcs String[] // UPCs or SKUs this rebate applies to

  // Rebate structure
  rebateType   String // "per_unit", "percent_of_purchase", "fixed_monthly"
  rebateAmount Decimal @db.Decimal(10, 4) // $ per unit OR percent OR fixed

  minQtyPerMonth Int? // minimum units to qualify
  maxQtyPerMonth Int? // cap per month

  // Validity
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, active])
  @@map("rebate_programs")
}

// ─────────────────────────────────────────────────
// MASTER PRODUCT (Org-level catalog)
// The canonical product record for the organization.
// All stores share the same catalog; price/stock
// overrides live in StoreProduct.
// ─────────────────────────────────────────────────
model MasterProduct {
  id    Int    @id @default(autoincrement())
  orgId String

  // Identifiers
  upc      String? // 2–14 digit identifier (primary scan key). Long codes
                   // (6+) are real barcodes; short codes (2-5) are typically
                   // store-assigned keypad shortcuts like "299".
  plu      String? // Price Look-Up (produce, bulk)
  sku      String? // internal SKU / item code
  itemCode String? // vendor item code (e.g. Hershey's code)

  // Display
  name        String
  description String? // long description for ecom / shelf tag
  brand       String?
  imageUrl    String?

  // Physical attributes
  size         String? // "12oz", "750ml", "1.75L", "1lb"
  sizeUnit     String? // "oz", "ml", "L", "lb", "g", "each"
  pack         Int? // total individual units per case (always = casePacks × sellUnitSize)
  casePacks    Int? // how many sell units come in a vendor case (e.g. 4 for "4 of 6pk")
  sellUnitSize Int? // units per sell unit (1=single, 6=6pk, 18=18pk whole)
  sellUnit     String? // "each" | "pack" | "case"
  // Legacy aliases kept for backward compat:
  innerPack    Int? // alias for casePacks
  unitsPerPack Int? // alias for sellUnitSize
  weight       Decimal? @db.Decimal(10, 4) // net weight for by-weight items

  // Classification
  departmentId   Int?
  department     Department?   @relation(fields: [departmentId], references: [id])
  vendorId       Int?
  vendor         Vendor?       @relation(fields: [vendorId], references: [id])
  productGroupId Int?
  productGroup   ProductGroup? @relation(fields: [productGroupId], references: [id])

  // Tax
  //
  // Session 40 Phase 1 (strict FK migration):
  //   `taxRuleId` is the authoritative per-product tax rule reference (FK).
  //   When set, the cashier engine uses that exact rule's rate — immune to
  //   rule renames, appliesTo changes, or ambiguity between similarly-named
  //   rules.
  //
  //   `taxClass` is the legacy free-text matcher kept as a fallback so
  //   existing data + older cashier-app builds keep working during the
  //   transition. A Phase 2 migration script auto-populates `taxRuleId` for
  //   products where `taxClass` maps unambiguously to an active rule.
  //
  //   Resolution priority at checkout:
  //     (1) product.taxRuleId  → rule (highest priority; per-product override)
  //     (2) dept-linked rule   via TaxRule.departmentIds[]  (Option B)
  //     (3) legacy taxClass string match on TaxRule.appliesTo
  //     (4) rate = 0 (no rule matched)
  taxRuleId Int?
  taxRule   TaxRule? @relation(fields: [taxRuleId], references: [id], onDelete: SetNull)
  taxClass  String? // legacy — kept for backward compat during migration
  // Tax rates resolved at checkout using TaxRule table; taxClass is the lookup key

  // Deposit / CRV
  depositRuleId     Int?
  depositRule       DepositRule? @relation(fields: [depositRuleId], references: [id])
  containerType     String? // "bottle", "can", "carton" — used to match DepositRule
  containerVolumeOz Float? // actual volume for deposit calculation

  // Pricing (org-level defaults; stores can override in StoreProduct)
  defaultCostPrice   Decimal? @db.Decimal(10, 4)
  defaultRetailPrice Decimal? @db.Decimal(10, 4)
  defaultCasePrice   Decimal? @db.Decimal(10, 4) // cost per case

  // Selling method
  byWeight Boolean @default(false) // sold per lb/kg at scale
  byUnit   Boolean @default(true)

  // Compliance flags
  ebtEligible      Boolean @default(false)
  ageRequired      Int? // 21 or 18; null = no age check
  taxable          Boolean @default(true)
  discountEligible Boolean @default(true)
  foodstamp        Boolean @default(false) // alias for ebtEligible

  // Inventory management
  trackInventory Boolean @default(true)
  reorderPoint   Int? // trigger reorder when stock hits this
  reorderQty     Int? // suggested order quantity
  shelfLifeDays  Int? // perishable items: days until expiry
  serviceLevel   String  @default("standard") // "critical","standard","low"

  // ── Grocery / Scale features (enabled when store type = grocery) ──
  wicEligible    Boolean   @default(false) // WIC program eligibility
  tareWeight     Decimal?  @db.Decimal(10, 4) // tare weight for scale items (lbs)
  scaleByCount   Boolean   @default(false) // scale by count instead of weight
  scalePluType   String? // CAS scale PLU type
  ingredients    String?   @db.Text // scale label ingredients list
  nutritionFacts String?   @db.Text // scale nutrition data (JSON or text)
  certCode       String? // "organic", "kosher", "halal", "gluten-free"
  sectionId      Int? // sub-department / section
  expirationDate DateTime? // product expiry date
  labelFormatId  Int? // electronic shelf label format number

  // ── E-commerce extended ──
  hideFromEcom    Boolean  @default(false)
  ecomDescription String? // SEO-friendly description
  ecomTags        String[] // searchable tags
  ecomExternalId  String? // external ecom platform product ID
  ecomPackWeight  Decimal? @db.Decimal(10, 4) // shipping weight (lbs)
  // Shipping package dimensions (imperial: inches). Used by ecom storefront
  // + carrier integrations for rate quotes and label generation. All nullable
  // — fall back to defaults or require quote-time override if any are unset.
  shipLengthIn    Decimal? @db.Decimal(10, 4)
  shipWidthIn     Decimal? @db.Decimal(10, 4)
  shipHeightIn    Decimal? @db.Decimal(10, 4)
  ecomPrice       Decimal? @db.Decimal(10, 4) // separate ecommerce price
  ecomSalePrice   Decimal? @db.Decimal(10, 4) // ecommerce sale price
  ecomOnSale      Boolean  @default(false) // ecommerce sale flag
  ecomSummary     String?  @db.Text // ecommerce summary text

  posLastSyncAt DateTime? // last time synced from/to POS

  // Status
  active  Boolean @default(true)
  deleted Boolean @default(false)

  // Simplified pack config (v2). Both fields default to 1 because every real
  // product is at least one unit / one pack-per-case — null was the source of
  // the silent-zero-deposit bug (snapshot's caseDeposit ÷ packsPerCase math
  // returned null when either field was null). Backfill migration ran in
  // Session F sets every existing null to 1 before the constraint takes effect.
  unitPack   Int @default(1) // individual units in one sell unit (1=single, 6=6-pk, 12=12-pk)
  packInCase Int @default(1) // sell units per vendor case (e.g. 4 means "4 × 6-packs per case")

  // Simplified deposit (v2)
  depositPerUnit Decimal? @db.Decimal(10, 4) // flat per-unit deposit
  caseDeposit    Decimal? @db.Decimal(10, 4) // total deposit for a full vendor case

  // Invoice cost sync lock (Invoice Scanning feature)
  // When true, invoice imports leave defaultCasePrice untouched even if the
  // store's auto-sync mode is 'always' or per-vendor. Use case: stores that
  // manually adjust cost to account for free-case credits / month-end
  // rebates and don't want the next invoice to overwrite their figure.
  lockManualCaseCost Boolean @default(false)

  // Session 4 — department-scoped + freeform attributes. Keys like
  // "vintage", "abv", "country" get promoted to typed DepartmentAttribute
  // fields; the rest live here until they're seen often enough to promote.
  // Shape: { [key: string]: string | number | boolean }
  attributes Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeProducts        StoreProduct[]
  upcs                 ProductUpc[]
  packSizes            ProductPackSize[]
  purchaseOrderItems   PurchaseOrderItem[]
  vendorReturnItems    VendorReturnItem[]
  inventoryAdjustments InventoryAdjustment[]
  labelQueueItems      LabelQueue[]
  // Per-vendor item codes / costs. One row per (product, vendor) pair.
  // The row flagged `isPrimary: true` mirrors its `vendorItemCode` back into
  // `MasterProduct.itemCode` so legacy readers (auto-order, ProductCatalog
  // list) keep working. See model ProductVendor below.
  vendorMappings       ProductVendor[]
  // Session 45 — Scan Data / tobacco compliance back-relations
  tobaccoProductMaps   TobaccoProductMap[]

  @@index([orgId, upc])
  @@index([orgId, deleted, active])
  @@index([orgId, departmentId])
  @@index([orgId, vendorId])
  @@index([orgId, productGroupId])
  @@index([orgId, name])
  @@map("master_products")
}

// ─────────────────────────────────────────────────
// PRODUCT GROUP  — template / price group
// Products in the same group share classification and pricing.
// Bulk price / sale price changes cascade to all members.
// ─────────────────────────────────────────────────
model ProductGroup {
  id          Int     @id @default(autoincrement())
  orgId       String
  name        String // "750ml Red Wine", "12oz Can Beer"
  description String?
  color       String? // UI chip color

  // Classification template
  departmentId      Int?
  department        Department?  @relation(fields: [departmentId], references: [id])
  vendorId          Int?
  vendor            Vendor?      @relation(fields: [vendorId], references: [id])
  taxClass          String?
  ageRequired       Int?
  ebtEligible       Boolean?
  discountEligible  Boolean?
  taxable           Boolean?
  depositRuleId     Int?
  depositRule       DepositRule? @relation(fields: [depositRuleId], references: [id])
  containerType     String?
  containerVolumeOz Decimal?     @db.Decimal(10, 2)

  // Size / Pack template
  size         String?
  sizeUnit     String?
  pack         Int?
  casePacks    Int?
  sellUnitSize Int?

  // Pricing template
  defaultCostPrice   Decimal? @db.Decimal(10, 4)
  defaultRetailPrice Decimal? @db.Decimal(10, 4)
  defaultCasePrice   Decimal? @db.Decimal(10, 4)

  // Sale pricing (applies to all members when active)
  salePrice Decimal?  @db.Decimal(10, 4)
  saleStart DateTime?
  saleEnd   DateTime?

  // When true, changes to the group cascade to all member products.
  // When false, the group is a one-time template (manual apply).
  autoSync Boolean @default(true)

  // S69 (C11b) — when false, mix_match promotions cannot target this group.
  // Enforced at promo create/update time AND when this flag flips
  // true→false (rejects if active mix_match promos still reference the group).
  allowMixMatch Boolean @default(true)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products     MasterProduct[]
  organization Organization    @relation(fields: [orgId], references: [id])

  @@unique([orgId, name])
  @@index([orgId, active])
  @@index([orgId, departmentId])
  @@map("product_groups")
}

// ─────────────────────────────────────────────────
// PRODUCT UPC  (multiple barcodes per product)
// ─────────────────────────────────────────────────
model ProductUpc {
  id              String   @id @default(cuid())
  orgId           String
  masterProductId Int
  upc             String
  label           String? // optional description e.g. "12-Pack box"
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())

  masterProduct MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  @@unique([orgId, upc])
  @@index([orgId, masterProductId])
  @@map("product_upcs")
}

// ─────────────────────────────────────────────────
// PRODUCT PACK SIZE  (cashier picker at scan time)
// ─────────────────────────────────────────────────
model ProductPackSize {
  id              String   @id @default(cuid())
  orgId           String
  masterProductId Int
  label           String // "Single", "6-Pack", "12-Pack"
  unitCount       Int      @default(1) // individual units in this pack
  packsPerCase    Int? // how many of this pack come in one vendor case
  retailPrice     Decimal  @db.Decimal(10, 4)
  costPrice       Decimal? @db.Decimal(10, 4)
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  masterProduct MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  @@index([orgId, masterProductId])
  @@map("product_pack_sizes")
}

// ─────────────────────────────────────────────────
// GLOBAL PRODUCT IMAGE  (cross-org image cache by UPC)
// Shared image lookup: if a product has no imageUrl,
// fall back to this table using stripped UPC.
// ─────────────────────────────────────────────────
model GlobalProductImage {
  id          String   @id @default(cuid())
  strippedUpc String   @unique // UPC with ALL leading zeros removed (match key)
  originalUpc String? // original UPC for audit / display
  imageUrl    String // external or re-hosted image URL
  rehostedUrl String? // our CDN URL after re-hosting (Phase 3)
  source      String   @default("import") // "import" | "manual" | "api"
  productName String? // denormalized name for admin display
  brand       String? // denormalized brand
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([strippedUpc])
  @@map("global_product_images")
}

// ─────────────────────────────────────────────────
// STORE PRODUCT (Store-level inventory)
// Price overrides, stock levels, and store-specific
// settings for each product at each location.
// ─────────────────────────────────────────────────
model StoreProduct {
  id      Int    @id @default(autoincrement())
  storeId String // MongoDB Store._id
  orgId   String

  masterProductId Int
  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  // Price overrides (null = use MasterProduct default)
  retailPrice Decimal? @db.Decimal(10, 4)
  costPrice   Decimal? @db.Decimal(10, 4)
  casePrice   Decimal? @db.Decimal(10, 4)

  // Sale / promo price
  salePrice Decimal?  @db.Decimal(10, 4)
  saleStart DateTime?
  saleEnd   DateTime?

  // Stock
  quantityOnHand  Decimal?  @db.Decimal(10, 2) // Decimal supports by-weight (lbs)
  quantityOnOrder Decimal?  @db.Decimal(10, 2)
  lastStockUpdate DateTime?
  lastReceivedAt  DateTime?

  // S73 — Expiry tracking. Records the soonest-expiring date on the shelf
  // for this product at this store. Single-batch model — admins are
  // expected to update this when they receive a new batch (since the
  // soonest expiry is what drives clearance decisions). For multi-batch
  // products (e.g. yogurt receiving twice a week), a future ExpiryBatch
  // table can be added without breaking this column.
  // Drives: Expiry Tracker page, F28 AI promo suggestions, dead-stock report.
  expiryDate      DateTime?
  expiryUpdatedAt DateTime?
  expiryNotes     String?

  // Store-specific flags
  active  Boolean @default(true)
  inStock Boolean @default(true) // for quick ecom filtering

  // Shelf info
  aisle         String?
  shelfLocation String?
  bin           String?

  // POS sync tracking
  posLastSyncAt DateTime?
  posSyncSource String? // "itretail", "manual", "invoice"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, masterProductId])
  @@index([storeId, orgId, active])
  @@index([storeId, orgId])
  @@map("store_products")
}

// ─────────────────────────────────────────────────
// PROMOTION
// Org-level deals: sale, BOGO, volume tiers,
// mix & match, combo bundles.
// dealConfig JSON shape varies by promoType:
//   sale:       { discountType, discountValue }
//   bogo:       { buyQty, getQty, getDiscount }
//   volume:     { tiers: [{minQty, price}] }
//   mix_match:  { minQty, comboPrice }
//   combo:      { productIds, comboPrice }
// ─────────────────────────────────────────────────
model Promotion {
  id    Int    @id @default(autoincrement())
  orgId String

  name        String
  promoType   String // "sale" | "bogo" | "volume" | "mix_match" | "combo"
  description String?

  // Scope — any combination of specific products, entire departments, or
  // product groups. The cashier's promo engine ORs these scopes — a line
  // qualifies if its productId is in productIds[], OR its departmentId is
  // in departmentIds[], OR its productGroupId is in productGroupIds[].
  // Empty scope arrays mean "applies to every line" (org-wide deal).
  productIds      Int[] // MasterProduct IDs this promo applies to
  departmentIds   Int[] // Department IDs (broadens scope)
  productGroupIds Int[] @default([]) // ProductGroup IDs — Session 56b

  // Deal configuration — shape depends on promoType
  dealConfig Json @default("{}")

  // POS display
  badgeLabel String? // e.g. "2 FOR $5", "BOGO", "BUY 6 SAVE 10%"
  badgeColor String? // hex e.g. "#ef4444"

  // Validity window
  startDate DateTime?
  endDate   DateTime?
  active    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, active])
  @@index([orgId, promoType])
  @@map("promotions")
}

// ─────────────────────────────────────────────────────────────
// POS TRANSACTION  (native POS cashier)
// ─────────────────────────────────────────────────────────────

model Transaction {
  id        String  @id @default(cuid())
  orgId     String
  storeId   String
  cashierId String
  stationId String?
  // Session 57 — shiftId is nullable on purpose:
  //  • new transactions populate it from the cashier-app payload (already wired)
  //  • legacy rows stay NULL (no automatic backfill)
  //  • no existing read path uses it yet — every report still queries by
  //    `createdAt >= shift.openedAt` (zero recalc risk). Future sessions can
  //    opt-in per-report when they're ready.
  shiftId   String?

  txNumber String // human-readable: "TXN-20240301-001423"
  status   String @default("complete") // "complete"|"voided"|"suspended"

  lineItems    Json // CartItem[] — denormalised snapshot at time of sale
  subtotal     Decimal @db.Decimal(10, 4)
  taxTotal     Decimal @db.Decimal(10, 4)
  depositTotal Decimal @default(0) @db.Decimal(10, 4)
  ebtTotal     Decimal @default(0) @db.Decimal(10, 4)
  grandTotal   Decimal @db.Decimal(10, 4)

  // ── Session 50 — Dual Pricing snapshot ──
  // pricingModel snapshotted at tx time so historical receipts/refunds keep
  // working even if the store later flips back to interchange.
  // baseSubtotal = subtotal AFTER promo + loyalty + manual order discounts but
  // BEFORE tax + surcharge. surchargeAmount is 0 for cash/EBT, > 0 for card/debit.
  pricingModel       String?  @default("interchange") // snapshot
  baseSubtotal       Decimal? @db.Decimal(10, 4)
  surchargeAmount    Decimal? @db.Decimal(10, 4) // computed: baseSubtotal × pct + fixed (only for card/debit)
  surchargeRate      Decimal? @db.Decimal(5, 3) // snapshot of effective % at tx time
  surchargeFixedFee  Decimal? @db.Decimal(10, 2) // snapshot
  surchargeTaxable   Boolean  @default(false) // snapshot of state policy
  surchargeTaxAmount Decimal? @db.Decimal(10, 4) // surcharge × tax rate (only when state taxable)

  tenderLines Json // [{ method, amount }]
  changeGiven Decimal @default(0) @db.Decimal(10, 4)

  ageVerifications Json? // [{ productId, method, age, verifiedAt }]
  notes            String?

  offlineCreatedAt DateTime? // set when created offline
  syncedAt         DateTime? // set when synced to server
  refundOf         String? // ID of original transaction (for refunds)
  voidedAt         DateTime? // timestamp when voided
  voidedById       String? // user ID who performed the void

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, createdAt])
  @@index([orgId, cashierId])
  @@index([txNumber])
  @@index([shiftId])
  @@map("transactions")
}

// ─────────────────────────────────────────────────
// STATION
// A physical POS register terminal.
// Registered once by a manager; persists its token
// in the browser's localStorage so cashiers can PIN-in.
// ─────────────────────────────────────────────────
model Station {
  id             String    @id @default(cuid())
  orgId          String
  storeId        String
  name           String // "Register 1", "Express Lane"
  token          String    @unique // long-lived station token — stored in POS localStorage
  lastSeenAt     DateTime?
  hardwareConfig Json? // Stores peripheral config: receipt printer, scale, PAX, label printer
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([orgId, storeId])
  @@map("stations")
}

// ═══════════════════════════════════════════════════════════════
// CORE MULTI-TENANT MODELS
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// ORGANIZATION  (was: MongoDB Tenant)
// Top-level billing / account entity.
// ─────────────────────────────────────────────────
model Organization {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique // URL-safe identifier
  plan           String    @default("trial") // "trial" | "starter" | "pro" | "enterprise"
  billingEmail   String?
  trialEndsAt    DateTime?
  maxStores      Int       @default(1)
  maxUsers       Int       @default(3)
  ratePerStation Decimal?  @db.Decimal(10, 2)

  // Org-wide preferences stored as JSONB
  // { timezone, currency, defaultTaxRate, receiptFooter, loyaltyEnabled }
  settings Json @default("{}")

  isActive      Boolean   @default(true)
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  stores         Store[]
  subscription   OrgSubscription?
  purchaseOrders PurchaseOrder[]
  vendorReturns  VendorReturn[]
  productGroups  ProductGroup[]
  roles          Role[]
  members        UserOrg[]
  invitations    Invitation[]
  promoSuggestions PromoSuggestion[]
  storeSubscriptions StoreSubscription[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────
// PLATFORM MODULE — S78
// Registry of every gateable feature on the platform. Each sidebar item
// (or group of related routes) is one module. Modules are referenced by
// their stable `key` from the frontend so adding a new module is a single
// seed insert + frontend route map update.
// ─────────────────────────────────────────────────
model PlatformModule {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  category    String              // 'Operations', 'Catalog', 'POS', etc.
  icon        String?             // lucide-react icon name (admin UI)

  // Routes this module governs. Frontend gate matches the route's permission
  // map against this list. Multiple paths allowed (e.g. /portal/foo + /portal/foo/:id).
  routePaths  String[] @default([])

  // Core modules can NEVER be removed from any plan (Dashboard, Account,
  // Support — anything an org needs to log in + manage their account).
  isCore      Boolean  @default(false)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)

  // S80 Phase 3 — Grouped business-module architecture.
  //
  //   isBusinessModule = true  → top-level toggleable parent. The 12 user-
  //                              facing add-ons (Lottery, Fuel, E-Commerce,
  //                              Marketplace, Exchange, Loyalty, Scan Data,
  //                              AI Assistant, Vendor Orders, Invoice OCR,
  //                              Multi-Store, Predictions). StoreSettings
  //                              shows toggles ONLY for these.
  //   parentKey        = "..."  → child sidebar items grouped under a parent.
  //                              When the parent business module is enabled,
  //                              all children with this parentKey activate.
  //                              When disabled, all children hide.
  //
  // Some business modules ARE sidebar items themselves (lottery, fuel,
  // exchange, scan_data, vendor_orders) — their own routePaths are populated
  // and parentKey is null. Pure parents (ecommerce, marketplace_integration,
  // invoice_ocr, ai_assistant, predictions, loyalty, multi_store_dashboard)
  // have empty routePaths and just gate their children.
  isBusinessModule Boolean @default(false)
  parentKey        String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans       PlanModule[]

  @@index([category, sortOrder])
  @@index([active])
  @@index([parentKey])
  @@map("platform_modules")
}

// ─────────────────────────────────────────────────
// PLAN MODULE — junction
// ─────────────────────────────────────────────────
model PlanModule {
  planId    String
  moduleId  String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  module    PlatformModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([planId, moduleId])
  @@index([moduleId])
  @@map("plan_modules")
}

// ─────────────────────────────────────────────────
// USER
// Employee / admin account scoped to one org.
// May have access to multiple stores via UserStore.
// ─────────────────────────────────────────────────
model User {
  id           String        @id @default(cuid())
  // Home organisation — default org on login. Nullable because a user may
  // exist without a home org (e.g. after a full ownership transfer, or
  // mid-onboarding before they accept their first invitation). Access
  // decisions go through the UserOrg junction, not this column.
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  name     String
  email    String  @unique
  phone    String?
  password String // bcrypt hash — never select by default in queries
  posPin   String? // bcrypt hash of 4–6 digit POS PIN

  role   String @default("staff") // "superadmin" | "admin" | "manager" | "staff"
  status String @default("active") // "pending" | "active" | "suspended"

  // Default store location (used for weather, etc.)
  storeLatitude  Float?
  storeLongitude Float?
  storeTimezone  String?
  storeAddress   String?

  // Password reset flow
  resetPasswordToken  String?
  resetPasswordExpire DateTime?

  // S77 — Vendor onboarding gate (Phase 1).
  //   onboardingSubmitted → vendor finished the business questionnaire
  //   contractSigned      → vendor signed the contract (Phase 3)
  //   vendorApproved      → admin manually approved + assigned a plan
  // All three default false on new signups so the access gate kicks in.
  // The migration sets them true for every existing user so no one gets locked out.
  onboardingSubmitted Boolean @default(false)
  contractSigned      Boolean @default(false)
  vendorApproved      Boolean @default(false)

  // S78 — Implementation Engineer PIN (cashier-app hardware-settings gate).
  //   canConfigureHardware  — admin-toggle. When true, system auto-generates
  //                           a 6-digit PIN every Monday and emails the user.
  //                           Intended for internal implementation/support
  //                           team only — NOT for store staff.
  //   implementationPinEnc  — AES-256-GCM ciphertext (cryptoVault, reversible
  //                           so the user can view their current PIN in
  //                           the admin panel).
  //   implementationPinSetAt — when the current PIN was written. Drives
  //                            the weekly rotation scheduler ("rotate any
  //                            user whose PIN is older than last Monday").
  canConfigureHardware    Boolean   @default(false)
  implementationPinEnc    String?
  implementationPinSetAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores         UserStore[]
  invoices       Invoice[]
  documents      Document[]
  posToken       PosToken?
  userRoles      UserRole[]
  orgs           UserOrg[]
  priceScenarios PriceScenario[] @relation("PriceScenarioCreator")

  assignedTickets   SupportTicket[] @relation("TicketAssignee")
  assignedByMe      SupportTicket[] @relation("TicketAssigner")

  notificationDeliveries NotificationDelivery[] @relation("UserNotifications")

  reviewedPromoSuggestions PromoSuggestion[] @relation("PromoSuggestionReviewer")

  vendorOnboarding         VendorOnboarding?  @relation("UserVendorOnboarding")
  reviewedOnboardings      VendorOnboarding[] @relation("VendorOnboardingReviewer")
  // S77 Phase 2 — Contracts
  contracts                Contract[]              @relation("ContractMerchant")
  generatedContracts       Contract[]              @relation("ContractGenerator")
  publishedContractTemplates ContractTemplateVersion[] @relation("ContractTemplatePublisher")

  @@index([orgId, role])
  @@index([orgId, email])
  @@map("users")
}

// ─────────────────────────────────────────────────
// VENDOR ONBOARDING — S77 Phase 1
// Business questionnaire captured between signup and portal access.
// One row per user. Workflow: draft → submitted → reviewed → contract_sent
// → contract_signed → approved → (rejected at any step). Phase 2 adds
// contract template/generation; Phase 3 adds signing + plan assignment.
// ─────────────────────────────────────────────────
model VendorOnboarding {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("UserVendorOnboarding", fields: [userId], references: [id], onDelete: Cascade)

  // ── Step 1 — Personal/Business Identity (most fields prefilled from signup) ──
  fullName            String
  email               String
  phone               String?
  businessLegalName   String?
  dbaName             String?
  businessAddress     String?
  businessCity        String?
  businessState       String?  // 2-letter code
  businessZip         String?
  businessType        String?  // LLC | Corp | SoleProp | Partnership | Nonprofit | Other
  ein                 String?
  yearsInBusiness     String?  // "<1" | "1-3" | "3-5" | "5-10" | "10+"

  // ── Step 2 — Operations ──
  industry             String? // convenience | liquor | grocery | gas_station | restaurant | smoke_shop | other
  numStoresRange       String? // "1" | "2-5" | "6-10" | "11+"
  numStoresExact       Int?
  numRegistersPerStore Int?
  monthlyVolumeRange   String? // "0-50k" | "50k-200k" | "200k-500k" | "500k-1m" | "1m+"
  avgTxPerDay          Int?
  currentPOS           String? // None | NCR | Verifone | Square | Clover | Shopify | Other
  goLiveTimeline       String? // immediate | 1month | 3months | exploring

  // ── Step 3 — Plan + add-on interest (S80 Phase 3) ──
  // Stored as "interest only" — admin sees the prospect's intended plan + addons
  // and uses this to negotiate / approve. The actual StoreSubscription gets
  // applied at approval time, not here.
  //
  //   selectedPlanSlug    : 'starter' | 'pro' | null  — plan tile they picked
  //   selectedAddonKeys   : addon keys from PlanAddon catalog (Starter only — Pro
  //                         hides the addon picker since it includes everything)
  //   estimatedMonthlyTotal : computed at submit time, mirrors the live cart
  //   requestedModules    : legacy multi-select kept for back-compat. New
  //                         selections write to selectedAddonKeys; admin UI
  //                         can read either.
  selectedPlanSlug      String?
  selectedAddonKeys     String[]   @default([])
  estimatedMonthlyTotal Decimal?   @db.Decimal(10, 2)

  // Legacy: pos_core, lottery, fuel, ecommerce, marketplace, exchange, loyalty,
  // scan_data, ai_assistant, vendor_orders, invoice_ocr, multi_store, predictions
  requestedModules    String[]  @default([])

  // ── Step 4 — Hardware needs ──
  // Shape: { posTerminal:N, receiptPrinter:N, cashDrawer:N, scanner:N,
  //          cardTerminal:N, customerDisplay:N, labelPrinter:N,
  //          fuelIntegration:bool, scaleIntegration:bool }
  hardwareNeeds       Json      @default("{}")

  // ── Step 5 — Additional context ──
  hearAboutUs         String?  // search | referral | event | social | partner | other
  referralSource      String?
  specialRequirements String?  @db.Text
  agreedToTerms       Boolean  @default(false)

  // ── Workflow ──
  status              String    @default("draft")
  // Allowed: draft | submitted | reviewed | contract_sent | contract_signed | approved | rejected
  currentStep         Int       @default(1)
  submittedAt         DateTime?
  reviewedAt          DateTime?
  reviewedById        String?
  reviewedBy          User?     @relation("VendorOnboardingReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason     String?   @db.Text
  adminNotes          String?   @db.Text
  // Phase 3 hook — admin's recommended pricing tier during review.
  suggestedPricingTierId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, submittedAt])
  @@map("vendor_onboardings")
}

// ─────────────────────────────────────────────────
// CONTRACT TEMPLATE — S77 Phase 2
// Master/named contract templates (e.g. "Standard Merchant Agreement",
// "Enterprise", "Free Trial"). Templates are versioned — every published
// edit produces a new ContractTemplateVersion row that's snapshotted onto
// new Contracts. Existing Contracts NEVER mutate when a template changes
// (legal/audit requirement — what was signed is what was signed).
// ─────────────────────────────────────────────────
model ContractTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions ContractTemplateVersion[]
  contracts Contract[]

  @@index([active, isDefault])
  @@map("contract_templates")
}

// One immutable, versioned snapshot of a template. Status flow:
//   draft   → admin is editing
//   published → live; Contracts pull this version
//   archived  → superseded by a newer version
model ContractTemplateVersion {
  id            String   @id @default(cuid())
  templateId    String
  template      ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  versionNumber Int               // monotonic per templateId
  bodyHtml      String   @db.Text // sanitized HTML (DOMPurify) — Quill output
  // mergeFields: catalog of placeholders this version expects + their types/defaults.
  // Shape: { fields: [{ key, label, type: 'text'|'number'|'currency'|'date'|'choice'|'block', required, default, choices? }] }
  mergeFields   Json     @default("{}")
  status        String   @default("draft") // draft | published | archived
  changeNotes   String?  @db.Text
  publishedAt   DateTime?
  publishedById String?
  publishedBy   User?    @relation("ContractTemplatePublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contracts Contract[]

  @@unique([templateId, versionNumber])
  @@index([templateId, status])
  @@map("contract_template_versions")
}

// ─────────────────────────────────────────────────
// CONTRACT — S77 Phase 2
// One row per merchant per contract cycle. Snapshots the template version
// at generation time (`bodyHtmlSnapshot`) so the signed copy is byte-stable
// regardless of future template edits.
// ─────────────────────────────────────────────────
model Contract {
  id                  String   @id @default(cuid())
  // ── Subject ──
  vendorOnboardingId  String?  // optional — admin can spin up a contract without an onboarding
  userId              String
  user                User     @relation("ContractMerchant", fields: [userId], references: [id], onDelete: Cascade)
  organizationId      String?  // populated only after activation creates the org

  // ── Template snapshot (immutable for legal hold) ──
  templateId          String
  template            ContractTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersionId   String
  templateVersion     ContractTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Restrict)
  bodyHtmlSnapshot    String   @db.Text       // frozen HTML at generation
  // mergeValues: filled-in data including:
  //   merchant: { businessLegalName, dba, address, city, state, zip, ein, ownerName, ownerDOB, ownerSSNLast4, phone, email }
  //   pricing: {
  //     saas: { baseMonthlyFee, additionalLicenseFee, addons:[{name,fee}] },
  //     hardware: [{ description, model?, qty, unitPrice, total }],
  //     shipping: number,
  //     processing: { model:'IC+'|'dual_pricing', icplusMarkupPercent, icplusInStorePerTx, icplusOnlinePerTx, batchFee, pciFee, breachFee, gatewayFee, aofFee, chargebackFee, retrievalFee, achReturnFee, voiceAuthFee, intlCardPercent, cashDiscountPercent?, cardSurchargePercent? }
  //   }
  //   bank: { name, routingLast4, accountLast4 }  // populated at signing
  mergeValues         Json     @default("{}")

  // ── Workflow ──
  status              String   @default("draft")
  // draft | sent | viewed | signed | countersigned | cancelled | expired

  // ── URL token (lets vendor reach the page even if the email link is forwarded) ──
  // Combined with auth — the vendor must be logged in AS the assigned user
  // AND present the matching token. Token is regenerated on cancel + re-send.
  signingToken        String   @unique

  // ── Timestamps & actors ──
  createdById         String
  createdBy           User     @relation("ContractGenerator", fields: [createdById], references: [id], onDelete: Restrict)
  sentAt              DateTime?
  viewedAt            DateTime?
  signedAt            DateTime?
  cancelledAt         DateTime?
  expiresAt           DateTime?  // optional time-limited contracts
  cancelReason        String?

  // ── Signature data (persisted at sign time) ──
  signerName          String?    // typed full legal name
  signerTitle         String?    // optional ("Owner", "CEO")
  signerEmail         String?
  signatureDataUrl    String?  @db.Text  // base64 PNG from canvas
  signerIp            String?
  signerUserAgent     String?

  // ── Output PDF storage ──
  signedPdfPath       String?    // local path under uploads/contracts/

  // ── Activation hooks ──
  // Admin's selected PricingTier when they Approve & Activate. Drives ongoing
  // SaaS billing + module access (Phase 4).
  assignedPricingTierId String?
  activatedAt          DateTime?
  activatedById        String?

  events ContractEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([signingToken])
  @@map("contracts")
}

// ─────────────────────────────────────────────────
// CONTRACT EVENT — S77 Phase 2
// Append-only audit log for every contract action. Never updated — new row
// per event. Used by the admin "history" panel and any compliance audit.
// ─────────────────────────────────────────────────
model ContractEvent {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  eventType  String   // generated | sent | viewed | downloaded | signed | cancelled | expired | activated | reissued
  actorId    String?  // null for vendor-side events (use signerEmail in meta)
  actorRole  String?  // 'admin' | 'vendor' | 'system'
  ipAddress  String?
  userAgent  String?
  meta       Json?    // flexible bag of data per event type
  createdAt  DateTime @default(now())

  @@index([contractId, createdAt])
  @@map("contract_events")
}

// ─────────────────────────────────────────────────
// USER ORG  (junction: User ↔ Organization, multi-org access)
// A user's active org is derived from the active Store's orgId;
// `role` here is the effective role within that org.
// ─────────────────────────────────────────────────
model UserOrg {
  userId      String
  orgId       String
  role        String // "owner" | "admin" | "manager" | "cashier" | custom role key
  isPrimary   Boolean  @default(false) // default org on login, one per user
  invitedById String?
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@index([orgId, role])
  @@index([userId, isPrimary])
  @@map("user_orgs")
}

// ─────────────────────────────────────────────────
// INVITATION
// Drives onboarding (new user → org access) AND store transfer
// (org ownership handed to a new owner). One table, one flow.
// ─────────────────────────────────────────────────
model Invitation {
  id           String       @id @default(cuid())
  token        String       @unique // opaque, sent in URL
  email        String
  phone        String?
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Empty array = grant access to all stores in org (typical for owner/admin/manager).
  // Non-empty = cashier-style scoped access.
  storeIds String[] @default([])
  role     String // role key to grant on acceptance

  invitedById       String // User.id of the inviter
  transferOwnership Boolean   @default(false) // true for store-sale flow
  status            String    @default("pending") // pending | accepted | revoked | expired
  expiresAt         DateTime
  acceptedAt        DateTime?
  acceptedByUserId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email, status])
  @@index([orgId, status])
  @@index([token])
  @@map("invitations")
}

// ─────────────────────────────────────────────────
// RBAC — Permission catalog (global, seeded)
// Examples: "products.view", "users.edit", "reports.view"
// ─────────────────────────────────────────────────
model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique // e.g. "products.edit"
  module      String // e.g. "products"
  action      String // view | create | edit | delete | manage
  label       String // Human-readable ("Edit Products")
  description String?
  scope       String   @default("org") // "org" | "admin" — admin = superadmin-only
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@index([scope])
  @@map("permissions")
}

// ─────────────────────────────────────────────────
// RBAC — Role. System roles are seeded (orgId=null, isSystem=true);
// per-org custom roles are created by org admins.
// ─────────────────────────────────────────────────
model Role {
  id           String        @id @default(cuid())
  orgId        String? // null for built-in system roles
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  key          String // unique identifier within scope (e.g. "cashier", "custom_foo")
  name         String // display name
  description  String?
  status       String  @default("active") // "active" | "inactive"
  isSystem     Boolean @default(false) // true = built-in, cannot be deleted (but can be edited)
  isCustomized Boolean @default(false) // true once a system role has been edited — seeder will skip perm resync
  scope        String  @default("org") // "org" | "admin"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([orgId, key])
  @@index([orgId])
  @@index([scope])
  @@map("roles")
}

// ─────────────────────────────────────────────────
// RBAC — Role ↔ Permission junction
// ─────────────────────────────────────────────────
model RolePermission {
  roleId       String
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────
// RBAC — User ↔ Role junction (users may hold multiple roles)
// ─────────────────────────────────────────────────
model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────
// USER STORE  (junction: User ↔ Store)
// ─────────────────────────────────────────────────
model UserStore {
  userId  String
  storeId String
  // Per-store POS PIN override (bcrypt hash of 4–6 digits).
  // Takes precedence over User.posPin at this store — lets owners/managers
  // use a different PIN per location. Non-owner users MUST have a per-store
  // entry here to log in at that station. Owners fall back to User.posPin
  // as a global org-wide override (highest hierarchy, works everywhere).
  posPin  String?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@map("user_stores")
}

// ─────────────────────────────────────────────────
// STORE
// Physical retail location within an org.
// ─────────────────────────────────────────────────
model Store {
  id           String       @id @default(cuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId      String? // User.id of the store owner / manager

  name                  String
  // 2-letter US state code (e.g. "MA", "CA"). Nullable for legacy stores.
  // When set, the backend auto-populates TaxRule / DepositRule defaults /
  // LotterySettings.state / ageLimits from the State admin catalog.
  stateCode             String?
  state                 State?   @relation(fields: [stateCode], references: [code], onDelete: SetNull)
  latitude              Float?
  longitude             Float?
  timezone              String?
  address               String?
  stationCount          Int      @default(1)
  monthlyRatePerStation Decimal? @db.Decimal(10, 2)

  // POS integration credentials — stored as JSONB so we can support
  // multiple POS systems without schema changes.
  // Shape: { type, username, password, storeCode, chainCode, locationId,
  //          merchantId, restaurantGuid, apiKey }
  pos Json?

  isActive Boolean @default(true)
  branding Json?   @default("{}")

  // S80 — per-store module on/off overrides. Shape: { moduleKey: bool }.
  // A module is ACTIVE at a store iff (subscription includes it) AND
  // (featureModules[key] !== false). Default behavior when key is absent
  // is "on" — every subscribed module renders unless the admin disabled
  // it here. Legacy per-module flags (store.pos.lottery.enabled,
  // store.pos.ecomEnabled, FuelSettings.enabled, etc.) are mirrored on
  // write for back-compat; phased out in Phase 3.
  featureModules Json @default("{}")

  // ── Storeveu Exchange (B2B wholesale between stores) ──
  // Globally unique human-friendly code used by trading partners to find
  // and invite this store, e.g. "NORTH-MAIN" or "STV-4F9K2A". Claimable at
  // creation, editable until first accepted partnership or first sent PO —
  // locked thereafter (see storeCodeLockedAt).
  storeCode         String?   @unique
  storeCodeLockedAt DateTime?

  // ── Session 50 — Dual Pricing / Cash Discount model ──
  //
  // pricingModel: "interchange" (default — single price, no surcharge)
  //               "dual_pricing" (card/debit pay surcharge; cash + EBT pay base)
  //
  // The marked/displayed item price is always the BASE price (cash equivalent).
  // At checkout, when the cashier picks a card/debit tender, the surcharge
  // (% of subtotal + fixed per-tx fee) is added on top. Cash and EBT tenders
  // never carry the surcharge.
  //
  // Tier-vs-flexible resolution (see dualPricing.js getEffectiveSurchargeRate):
  //   1. customSurchargePercent / customSurchargeFixedFee (when both set)
  //   2. pricingTier rates (when pricingTierId set)
  //   3. null (returns 0 — surcharge effectively disabled even if model='dual_pricing')
  //
  // Toggle is superadmin-only (see PricingModelChange audit trail).
  pricingModel            String       @default("interchange")
  pricingTierId           String?
  pricingTier             PricingTier? @relation(fields: [pricingTierId], references: [id], onDelete: SetNull)
  customSurchargePercent  Decimal?     @db.Decimal(5, 3) // e.g. 3.000 = 3.0%
  customSurchargeFixedFee Decimal?     @db.Decimal(10, 2) // e.g. 0.30
  dualPricingActivatedAt  DateTime?
  dualPricingActivatedBy  String? // User.id of the superadmin who flipped the toggle
  dualPricingDisclosure   String?      @db.Text // store-level override (else uses State.surchargeDisclosureText)
  // Session 52 — Refund-surcharge policy. When true, card-transaction
  // refunds INCLUDE the original surcharge proportionally (pro-rata for
  // partial refunds). When false (default), refunds return ONLY the
  // principal — surcharge stays with the merchant per industry standard.
  // Per-store policy editable from Store Settings (manager+) since this
  // is operational, not pricing-model authority.
  refundSurcharge         Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             UserStore[]
  customers         Customer[]
  invoices          Invoice[]
  documents         Document[]
  posTokens         PosToken[]
  posLogs           PosLog[]
  feeMappings       FeeMapping[]
  vendorProductMaps VendorProductMap[]

  // Storeveu Exchange back-relations
  partnershipsOutgoing TradingPartner[] @relation("RequesterPartnerships")
  partnershipsIncoming TradingPartner[] @relation("PartnerPartnerships")
  wholesaleSent        WholesaleOrder[] @relation("WholesaleSender")
  wholesaleReceived    WholesaleOrder[] @relation("WholesaleReceiver")
  partnerBalancesA     PartnerBalance[] @relation("PartnerBalanceA")
  partnerBalancesB     PartnerBalance[] @relation("PartnerBalanceB")

  // Session 50 — pricing model audit trail
  pricingModelChanges PricingModelChange[]

  // S80 — per-store subscription (Phase 1). One sub per store; addons/billing
  // tracked here. Org-level OrgSubscription kept for transition (Phase 3 retires).
  subscription StoreSubscription?

  @@index([orgId, isActive])
  @@index([storeCode])
  @@index([pricingModel])
  @@map("stores")
}

// ═══════════════════════════════════════════════════════════════
// OPERATIONS
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// CUSTOMER
// Loyalty / house-account customer.
// ─────────────────────────────────────────────────
model Customer {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  // Name fields — some POS systems provide split, some combined
  name      String?
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  // Storefront auth (nullable — POS-only customers have no password)
  passwordHash String?
  addresses    Json    @default("[]")

  // Loyalty
  loyaltyPoints Int  @default(0)
  // Array of { date, points, reason, balance } — JSONB for flexibility
  pointsHistory Json @default("[]")

  // POS-synced fields
  posCustomerId        String?
  cardNo               String?
  discount             Decimal? @db.Decimal(5, 4) // e.g. 0.0500 = 5%
  balance              Decimal? @db.Decimal(10, 2)
  balanceLimit         Decimal? @db.Decimal(10, 2)
  instoreChargeEnabled Boolean  @default(false)

  birthDate      DateTime?
  expirationDate DateTime?

  deleted     Boolean   @default(false)
  posSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, deleted])
  @@index([orgId, email])
  @@index([orgId, phone])
  @@map("customers")
}

// ─────────────────────────────────────────────────
// INVOICE
// Vendor delivery invoice processed via Azure OCR.
// lineItems → JSONB (25+ fields per line; schema varies by vendor)
// pages     → JSONB array of page image paths / Azure page metadata
// ─────────────────────────────────────────────────
model Invoice {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  fileName String?
  fileType String? // "pdf" | "image" | "csv"

  // Header fields extracted by OCR
  vendorName     String?
  vendorId       Int? // resolved Vendor FK — powers vendor-scoped item-code matching
  customerNumber String?
  invoiceNumber  String?
  invoiceDate    DateTime?
  paymentDueDate DateTime?
  paymentType    String?
  checkNumber    String?

  // Financial summary
  totalInvoiceAmount Decimal? @db.Decimal(10, 2)
  tax                Decimal? @db.Decimal(10, 2)
  totalDiscount      Decimal? @db.Decimal(10, 2)
  totalDeposit       Decimal? @db.Decimal(10, 2)
  otherFees          Decimal? @db.Decimal(10, 2)

  // Quantity summary
  totalCasesReceived Decimal? @db.Decimal(10, 2)
  totalUnitsReceived Decimal? @db.Decimal(10, 2)

  // Personnel
  driverName   String?
  salesRepName String?
  loadNumber   String?

  // Page images / Azure page results (array of objects)
  pages Json @default("[]")

  // Line items — complex, vendor-specific shape
  // Each item may have: description, upc, sku, qty, caseQty, unitQty,
  // unitCost, caseCost, retailPrice, deposit, discount, tax, total, etc.
  lineItems Json @default("[]")

  // Invoice classification — distinguishes a normal purchase invoice from
  // a vendor-issued credit memo (rebates, volume bonuses, pricing
  // adjustments). Credit memos store a POSITIVE totalInvoiceAmount; P&L
  // reports subtract them from the vendor's purchase total to produce the
  // net cost.
  //
  // Values: 'purchase' (default) | 'credit_memo'
  invoiceType     String  @default("purchase")
  // Optional link back to the original purchase invoice this credit
  // applies to (purely for traceability — no FK constraint so the
  // reference survives when the original is deleted/archived).
  linkedInvoiceId String?

  // Processing state
  status          String  @default("pending") // "pending" | "processing" | "complete" | "error"
  processingError String?
  rawText         String? @db.Text

  // Match accuracy tracking
  matchStats Json? // { total, matched, unmatched, byTier: {upc, vendorMap, fuzzy, ai, manual, costProx, global}, avgConfidence }

  // Cost-sync audit trail — populated by confirmInvoice when it decides
  // whether each line's invoiceCaseCost should (or shouldn't) overwrite the
  // matched product's defaultCasePrice. Shape:
  // [{ productId, productName, invoiceCaseCost, decision: 'sync'|'skip'|'error', reason }]
  costSyncAudit Json?

  // PO linkage — auto-matched after OCR
  linkedPurchaseOrderId String?
  poMatchResult         Json? // { matchedPO, matchedItems, costVariances, summary }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([orgId, invoiceDate])
  @@index([orgId, vendorName])
  @@index([orgId, vendorId])
  @@map("invoices")
}

// ─────────────────────────────────────────────────
// FEE MAPPING
// Maps fee label strings (from invoices / POS) to
// internal fee types for consistent reporting.
// ─────────────────────────────────────────────────
model FeeMapping {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  feeType     String // "bottle_deposit" | "bag_fee" | "alcohol_surcharge"
  mappedValue String // the raw label as it appears in invoices / POS
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, storeId, feeType, mappedValue])
  @@index([orgId, storeId])
  @@map("fee_mappings")
}

// ─────────────────────────────────────────────────
// POS TOKEN
// Cached POS auth token per user (one per user max).
// ─────────────────────────────────────────────────
model PosToken {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String    @db.Text
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("pos_tokens")
}

// ─────────────────────────────────────────────────
// POS LOG
// Immutable audit log of POS API calls.
// Application layer should purge records > 30 days
// (equivalent to MongoDB TTL index).
// ─────────────────────────────────────────────────
model PosLog {
  id      Int     @id @default(autoincrement())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  endpoint   String
  method     String // "GET" | "POST" | "PUT" | "DELETE"
  status     String // "success" | "error"
  statusCode Int?
  message    String?

  createdAt DateTime @default(now())

  @@index([orgId, storeId, createdAt])
  @@map("pos_logs")
}

// ─────────────────────────────────────────────────
// WEATHER CACHE
// Daily weather data per lat/lng from Open-Meteo.
// Unique on (date, latitude, longitude).
// ─────────────────────────────────────────────────
model WeatherCache {
  id        Int    @id @default(autoincrement())
  date      String // "YYYY-MM-DD"
  latitude  Float
  longitude Float

  temperatureMax   Float?
  temperatureMin   Float?
  temperatureMean  Float?
  precipitationSum Float?
  weatherCode      Int?
  condition        String? // "sunny" | "rainy" | "snowy" | "cloudy"
  windSpeedMax     Float?
  humidity         Float?

  source    String? // "open-meteo" | "noaa"
  fetchedAt DateTime @default(now())

  @@unique([date, latitude, longitude])
  @@index([date])
  @@map("weather_cache")
}

// ─────────────────────────────────────────────────
// DOCUMENT
// Generic OCR-processed document store
// (receipts, contracts, etc. beyond invoices).
// extractedFields → flexible JSONB per docType.
// ─────────────────────────────────────────────────
model Document {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  fileName        String
  fileType        String? // "pdf" | "image" | "csv"
  docType         String? // "invoice" | "contract" | "receipt" | "other"
  extractedFields Json? // shape varies by docType — kept as JSONB
  confidence      Float? // overall OCR confidence score 0.0–1.0

  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId, storeId, docType])
  @@map("documents")
}

// ─────────────────────────────────────────────────
// VENDOR PRODUCT MAP
// Lookup table: vendor item code ↔ POS product.
// Built up over time from invoice processing.
// ─────────────────────────────────────────────────
model VendorProductMap {
  id      String  @id @default(cuid())
  orgId   String
  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  vendorName        String
  vendorItemCode    String
  vendorDescription String?

  // Matched POS product
  posProductId String?
  posUPC       String?
  posName      String?

  matchTier      String? // "exact" | "fuzzy" | "manual"
  confirmedCount Int       @default(0) // how many times confirmed correct
  lastSeenAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, storeId, vendorName, vendorItemCode])
  @@index([orgId, storeId, vendorName])
  @@map("vendor_product_maps")
}

// ProductVendor — authoritative per-vendor item-code / cost mapping.
//
// One MasterProduct can have N vendors, each with its own item code, cost,
// and case/pack configuration. Exactly one row per product is flagged
// `isPrimary: true` — its `vendorItemCode` is mirrored back into
// `MasterProduct.itemCode` so legacy readers (auto-order engine, product
// catalog list, reports) keep working without being rewritten.
//
// Distinct from VendorProductMap above, which is OCR fuzzy-matching memory
// (keyed on vendor NAME STRING with matchTier/confirmedCount tracking). This
// one is the clean normalized relationship users maintain explicitly (or
// that gets populated from invoice imports with a known `vendorId`).
model ProductVendor {
  id              Int    @id @default(autoincrement())
  orgId           String
  masterProductId Int
  vendorId        Int

  vendorItemCode String? // vendor's SKU/item number for this product
  description    String? // vendor's description (may differ from our name)
  priceCost      Decimal? @db.Decimal(10, 4) // cost per sell unit
  caseCost       Decimal? @db.Decimal(10, 4) // cost per full case (if known)
  packInCase     Int? // vendor's case-pack count (may differ from master)

  isPrimary      Boolean   @default(false)
  // Most recent invoice date that referenced this (product, vendor) pair —
  // used by the auto-primary-on-first-import rule.
  lastReceivedAt DateTime?

  notes String? // free-form (reorder preferences etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)
  vendor  Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([orgId, masterProductId, vendorId])
  @@index([orgId, vendorId])
  @@index([orgId, masterProductId, isPrimary])
  @@map("product_vendors")
}

// ═══════════════════════════════════════════════════════════════
// CSV TRANSFORM PIPELINE
// (original webapp functionality — was in MongoDB models.js)
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// UPLOAD
// Tracks uploaded CSV/Excel files before transform.
// ─────────────────────────────────────────────────
model Upload {
  id       String @id @default(cuid())
  uploadId String @unique // legacy UUID from original app

  filename     String
  originalPath String?
  fileType     String?
  fileSize     Int?
  rowCount     Int?
  columns      Json    @default("[]") // String[] — column headers
  preview      Json? // first N rows as array of objects
  vendorId     String?
  status       String  @default("pending") // "pending" | "processing" | "complete" | "error"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transforms Transform[]

  @@map("uploads")
}

// ─────────────────────────────────────────────────
// TRANSFORM
// Result of a CSV transformation run.
// ─────────────────────────────────────────────────
model Transform {
  id          String @id @default(cuid())
  transformId String @unique // legacy UUID

  uploadId String
  // S80: FK references Upload.uploadId (the @unique legacy UUID column),
  // NOT Upload.id (the cuid PK). The route handler in routes/api.ts writes
  // a UUID into Transform.uploadId — pointing the FK at Upload.id (a cuid)
  // made the FK unsatisfiable for every insert. See CLAUDE.md S80.
  upload   Upload @relation(fields: [uploadId], references: [uploadId], onDelete: Cascade)

  depositMapId  String?
  outputPath    String?
  outputFormat  String? // "csv" | "xlsx"
  vendorId      String?
  rowsProcessed Int?
  warnings      Json      @default("[]") // String[] — non-fatal issues
  status        String    @default("pending")
  error         String?
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transforms")
}

// ─────────────────────────────────────────────────
// DEPOSIT MAP
// Uploaded CSV that maps item codes → deposit amounts.
// mappings → JSONB object: { [itemCode]: depositAmount }
// ─────────────────────────────────────────────────
model DepositMap {
  id           String @id @default(cuid())
  depositMapId String @unique // legacy UUID

  filename      String
  filePath      String?
  mappings      Json    @default("{}") // { itemCode: depositAmount }
  totalMappings Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("deposit_maps")
}

// ─────────────────────────────────────────────────
// SHIFT
// Cash drawer open/close session per register per day.
// ─────────────────────────────────────────────────
model Shift {
  id         String  @id @default(cuid())
  orgId      String
  storeId    String
  stationId  String? // which register
  cashierId  String // who opened
  closedById String? // who closed

  status   String    @default("open") // "open" | "closed"
  openedAt DateTime  @default(now())
  closedAt DateTime?

  // Opening count
  openingAmount        Decimal @db.Decimal(10, 4)
  openingDenominations Json? // { "100": 2, "20": 5, "1": 3, "0.25": 8, ... }
  openingNote          String?

  // Closing count (filled in when shift is closed)
  closingAmount        Decimal? @db.Decimal(10, 4)
  closingDenominations Json?
  closingNote          String?

  // Calculated at close
  expectedAmount Decimal? @db.Decimal(10, 4)
  variance       Decimal? @db.Decimal(10, 4) // closingAmount - expectedAmount
  cashSales      Decimal? @db.Decimal(10, 4)
  cashRefunds    Decimal? @db.Decimal(10, 4)
  cashDropsTotal Decimal? @db.Decimal(10, 4)
  payoutsTotal   Decimal? @db.Decimal(10, 4)

  // Persisted lottery cash-flow breakdown captured at close-time. Surfaces
  // the un-rung instant cash, machine draw sales, machine cashings, and
  // instant cashings the drawer accounted for. Frozen at close-time so
  // future audits show the variance the cashier saw, not what the data
  // looks like today. Schema = LotteryCashFlow (services/reconciliation/shift/types.ts).
  lotteryReconciliation Json?

  drops   CashDrop[]
  payouts CashPayout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([orgId, storeId, openedAt])
  @@map("shifts")
}

// ─────────────────────────────────────────────────
// CASH DROP  (mid-shift safe drop)
// ─────────────────────────────────────────────────
model CashDrop {
  id          String   @id @default(cuid())
  orgId       String
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id])
  amount      Decimal  @db.Decimal(10, 4)
  note        String?
  // S77 (C9) — cash drawer event direction:
  //   'drop'    = money OUT of drawer to safe (legacy default; existing rows untouched)
  //   'paid_in' = money INTO drawer (petty cash refill, change drop, mid-shift cash-in)
  // Drawer reconciliation flips sign per type (drop subtracts, paid_in adds).
  type            String   @default("drop")
  // S77 (C9) — persistent printable ref (CD-YYYYMMDD-NNN for drop, CI-YYYYMMDD-NNN for paid_in).
  // Generated server-side on create + survives reprints. Unique per org for collision safety.
  referenceNumber String?
  createdById String
  createdAt   DateTime @default(now())

  @@unique([orgId, referenceNumber])
  @@index([orgId, shiftId])
  @@index([orgId, type])
  @@map("cash_drops")
}

// ─────────────────────────────────────────────────
// CASH PAYOUT  (paid out to vendor / driver / employee)
// ─────────────────────────────────────────────────
model CashPayout {
  id          String   @id @default(cuid())
  orgId       String
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id])
  amount      Decimal  @db.Decimal(10, 4)
  recipient   String? // vendor name / free-text recipient
  vendorId    Int? // optional FK to Vendor
  // S77 (C9) — extended payoutType enum:
  //   'expense' / 'merchandise'    = vendor payout (money OUT, legacy)
  //   'loan'                       = cashier/employee cash advance (money OUT)
  //   'received_on_account'        = charge-account customer settling balance (money IN)
  // Drawer reconciliation flips sign per type (loan/expense/merchandise subtract, received_on_account adds).
  payoutType  String?
  // S77 (C9) — link Customer for received_on_account; loose scalar (no FK) so a
  // future Customer.cashPayouts back-relation can be added without schema churn.
  customerId  String?
  // S77 (C9) — persistent printable ref (VP for vendor payout, LN for loan, RA for received-on-account).
  referenceNumber String?
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  @@unique([orgId, referenceNumber])
  @@index([orgId, shiftId])
  @@index([orgId, payoutType])
  @@index([orgId, customerId])
  @@map("cash_payouts")
}

// ─────────────────────────────────────────────────
// VENDOR PAYMENT  (back-office managed vendor payments)
// ─────────────────────────────────────────────────
model VendorPayment {
  id           String   @id @default(cuid())
  orgId        String
  storeId      String?
  vendorId     Int?
  vendorName   String?
  amount       Decimal  @db.Decimal(10, 4)
  paymentType  String   @default("expense")
  tenderMethod String?  @default("cash")
  notes        String?
  paymentDate  DateTime @default(now())
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId, storeId])
  @@index([orgId, paymentDate])
  @@map("vendor_payments")
}

// ─────────────────────────────────────────────────
// VENDOR CREDIT
// Free-case receipts, mix-and-match bonuses, damaged-goods allowances,
// and other non-cash credits from a vendor. Distinct from VendorPayment
// (which tracks cash going OUT to the vendor) — credits are goods or
// equivalent value coming IN from the vendor without charge.
//
// Example: "Buy 6 cases of Coke, get 1 free" → 1 VendorCredit row with
// creditType='free_case', casesReceived=1, amount=48.00 (the retail/whole
// sale value of the free case), reason="Mix-and-match 6+1 promo".
//
// Monthly totals surface on the vendor-detail page. No automatic
// invoice linkage — admins enter credits manually after receiving goods.
model VendorCredit {
  id            String   @id @default(cuid())
  orgId         String
  storeId       String?
  vendorId      Int?
  vendorName    String? // denormalised fallback when vendorId is null
  amount        Decimal  @db.Decimal(10, 4) // credit value in $
  creditType    String   @default("free_case")
  // "free_case" | "mix_match" | "damaged_return" | "adjustment" | "other"
  reason        String? // short user-entered description
  casesReceived Int? // optional — how many free cases came with this credit
  productRef    String? // optional — product name / UPC / SKU reference
  notes         String?
  creditDate    DateTime @default(now())
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId, storeId])
  @@index([orgId, creditDate])
  @@index([orgId, vendorId])
  @@map("vendor_credits")
}

// ─────────────────────────────────────────────────
// CLOCK EVENT
// Employee clock in / clock out records.
// Identified by PIN without requiring a full JWT session.
// ─────────────────────────────────────────────────
model ClockEvent {
  id        String  @id @default(cuid())
  orgId     String
  storeId   String
  userId    String
  stationId String?
  type      String // "in" | "out"
  note      String?

  createdAt DateTime @default(now())

  @@index([orgId, storeId, userId, createdAt])
  @@index([orgId, storeId, createdAt])
  @@map("clock_events")
}

// ─────────────────────────────────────────────────
// IMPORT JOB
// Tracks every bulk import operation for history,
// partial-success reporting, and error audit.
// ─────────────────────────────────────────────────
model ImportJob {
  id      Int     @id @default(autoincrement())
  orgId   String
  storeId String? // null = org-wide import

  type     String // "products" | "departments" | "vendors" | "promotions" | "deposits" | "invoice_costs"
  fileName String
  fileSize Int? // bytes

  totalRows   Int @default(0)
  successRows Int @default(0)
  failedRows  Int @default(0)
  skippedRows Int @default(0) // duplicates skipped per strategy

  status String @default("pending")
  // "pending" | "validating" | "importing" | "done" | "failed"

  // [{ row, field, message, value, type: "error"|"warning" }]
  errors Json @default("[]")

  // Options snapshot — what settings were used
  options Json @default("{}")

  createdBy   String // User.id
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([orgId, type, createdAt])
  @@index([orgId, status])
  @@map("import_jobs")
}

// ═══════════════════════════════════════════════════════════════
// LOTTERY MODULE
// Manages scratch-ticket inventory, sales, payouts, and
// per-shift reconciliation.
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// LOTTERY GAME
// A game type (e.g. "$1 Lucky", "$5 Big Winner").
// Defines ticket price, commission rate, and tickets per box.
// ─────────────────────────────────────────────────
model LotteryGame {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  name          String // "$1 Scratch", "$5 Big Winner"
  gameName      String? // Optional display name override
  gameNumber    String? // State lottery game # for inventory orders
  ticketPrice   Decimal @db.Decimal(10, 2)
  ticketsPerBox Int     @default(300)
  active        Boolean @default(true)
  deleted       Boolean @default(false)

  // State/province this game belongs to (e.g. "ON", "BC", "AB", "QC")
  // Set at admin level; stores filter games by their state
  state    String?
  isGlobal Boolean @default(false) // true = admin-managed, visible to all stores in that state

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boxes LotteryBox[]

  @@index([orgId, storeId])
  @@map("lottery_games")
}

// ─────────────────────────────────────────────────
// LOTTERY BOX
// A physical pack/roll of scratch tickets.
// Moves through: inventory → active → depleted → settled.
// ─────────────────────────────────────────────────
model LotteryBox {
  id      String      @id @default(cuid())
  orgId   String
  storeId String
  gameId  String
  game    LotteryGame @relation(fields: [gameId], references: [id])

  boxNumber    String? // Physical serial / pack number
  slotNumber   Int? // Physical slot in the lottery machine (1–32)
  totalTickets Int
  ticketPrice  Decimal @db.Decimal(10, 2)
  totalValue   Decimal @db.Decimal(10, 2) // totalTickets × ticketPrice

  // Lifecycle
  // status values: inventory (Safe) | active (Counter) | depleted (Soldout) | returned (Returned to Lotto) | settled
  status      String    @default("inventory")
  activatedAt DateTime?
  depletedAt  DateTime?
  returnedAt  DateTime? // when Return to Lotto happened

  // Scheduled location moves (e.g. "move to safe starting tomorrow")
  pendingLocation              String? // target status, e.g. "inventory" or "depleted"
  pendingLocationEffectiveDate DateTime? // when the pending move executes
  pendingLocationRequestedAt   DateTime?

  // Audit
  autoSoldoutReason String? // 'new_book_scanned' | 'manual' | 'eod_so_button'

  // Ticket tracking
  startTicket          String?
  currentTicket        String?
  lastShiftEndTicket   String? // ticket # scanned at end of last shift (for next-shift calculation)
  lastShiftStartTicket String? // ticket # at the start of the current/last shift

  // Running totals (updated on each LotteryTransaction)
  ticketsSold Int     @default(0)
  salesAmount Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([gameId])
  @@index([pendingLocationEffectiveDate])
  @@map("lottery_boxes")
}

// ─────────────────────────────────────────────────
// LOTTERY TRANSACTION
// Individual lottery sale or payout during a shift.
// amount is always positive; type signals direction.
// ─────────────────────────────────────────────────
model LotteryTransaction {
  id        String  @id @default(cuid())
  orgId     String
  storeId   String
  shiftId   String? // FK to Shift (not enforced; Shift may be from POS terminal)
  cashierId String?
  stationId String?

  type        String // "sale" | "payout"
  amount      Decimal @db.Decimal(10, 2) // always positive
  ticketCount Int? // number of tickets sold

  gameId String?
  boxId  String?
  notes  String?

  posTransactionId String? // links to parent cart transaction when recorded together

  createdAt DateTime @default(now())

  @@index([orgId, storeId, shiftId])
  @@index([orgId, storeId, createdAt])
  @@map("lottery_transactions")
}

// ─────────────────────────────────────────────────
// LOTTERY SHIFT REPORT
// End-of-shift lottery reconciliation (one per shift).
// Cashier enters machine cash + digital totals,
// app validates against recorded transactions.
// ─────────────────────────────────────────────────
model LotteryShiftReport {
  id      String @id @default(cuid())
  orgId   String
  storeId String
  shiftId String @unique

  // Cashier-entered values (from physical lottery machine)
  machineAmount  Decimal? @db.Decimal(10, 2) // cash on lottery machine printout
  digitalAmount  Decimal? @db.Decimal(10, 2) // digital/online lottery sales
  scannedTickets Json? // [{gameId, gameName, count, amount}]
  scannedAmount  Decimal? @db.Decimal(10, 2) // sum of scanned ticket amounts

  // Per-box scan data — [{boxId, gameId, gameName, slotNumber, startTicket, endTicket, ticketsSold, amount}]
  boxScans Json?

  // Apr 2026 — cumulative-day readings from the lottery terminal at shift close.
  // All values are day-to-date totals (NOT per-shift) because the machine shows
  // running daily totals that reset at midnight. Per-shift activity is computed
  // by delta-ing chronologically-ordered shifts in the same day.
  grossSalesReading     Decimal? @db.Decimal(10, 2) // gross machine sales cumulative
  cancelsReading        Decimal? @db.Decimal(10, 2) // cancels/voids cumulative
  machineCashingReading Decimal? @db.Decimal(10, 2) // "Pays/Cashes" cumulative
  couponCashReading     Decimal? @db.Decimal(10, 2) // coupon redemptions cumulative
  discountsReading      Decimal? @db.Decimal(10, 2) // discounts cumulative
  instantCashingReading Decimal? @db.Decimal(10, 2) // "Instant Pays/Cashes" cumulative

  // Computed from LotteryTransactions
  totalSales   Decimal? @db.Decimal(10, 2)
  totalPayouts Decimal? @db.Decimal(10, 2)
  netAmount    Decimal? @db.Decimal(10, 2) // totalSales - totalPayouts
  variance     Decimal? @db.Decimal(10, 2) // (machineAmount+digitalAmount) - netAmount

  notes      String?
  closedById String?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("lottery_shift_reports")
}

// ─────────────────────────────────────────────────
// LOTTERY SETTINGS
// Store-level lottery configuration.
// Commission is managed here, not at individual game level.
// ─────────────────────────────────────────────────
model LotterySettings {
  id      String @id @default(cuid())
  orgId   String
  storeId String @unique

  enabled  Boolean @default(true)
  cashOnly Boolean @default(false) // restrict lottery transactions to cash

  // Store's province/state — determines which games are visible
  state String? // e.g. "MA", "ME", "NY"

  // Commission — store-level rate applied to all lottery sales
  commissionRate Decimal? @db.Decimal(5, 4) // e.g. 0.0540 = 5.4%

  // Shift-end ticket scan mandate
  scanRequiredAtShiftEnd Boolean @default(false) // if true, cashier must scan before closing shift

  // Sell direction — how tickets are loaded in the physical counter dispenser
  // 'desc' = highest ticket number dispensed first (e.g. 99 → 0)
  // 'asc'  = lowest ticket number dispensed first (e.g. 0 → 99)
  sellDirection String @default("desc")

  // Multi-book policy. When false (default), scanning a new book of a game that already has
  // an active book on the counter auto-soldouts the old book. When true, both stay active.
  allowMultipleActivePerGame Boolean @default(false)

  // State adapter overrides (null = use state default)
  weekStartDay            Int? // 0-6, Sunday=0
  settlementPctThreshold  Int? // e.g. 80 = 80% sold qualifies
  settlementMaxDaysActive Int? // e.g. 180 = settle after 180 days regardless of % sold

  // Apr 2026 — per-shift variance display preference for the Shift Reports
  // audit view. Stores can choose to always show variance per shift, only
  // flag shifts whose variance exceeds a $ threshold, or hide per-shift
  // variance entirely (only show day-level rollup).
  shiftVarianceDisplay   String   @default("always") // "always" | "threshold" | "hidden"
  shiftVarianceThreshold Decimal  @default(0) @db.Decimal(10, 2) // only used when display="threshold"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("lottery_settings")
}

// ─────────────────────────────────────────────────
// LOTTERY ONLINE TOTAL
// One row per (store, date) capturing the 3 daily totals
// entered by the cashier/manager at end of day:
//   - instantCashing  : scratch-off winnings paid from drawer
//   - machineSales    : draw-game sales rung on the state terminal (not POS)
//   - machineCashing  : draw-game winnings paid from drawer
// ─────────────────────────────────────────────────
model LotteryOnlineTotal {
  id             String   @id @default(cuid())
  orgId          String
  storeId        String
  date           DateTime @db.Date
  // Core 3 (machine cashings + instant cashings + machine sales)
  instantCashing Decimal  @default(0) @db.Decimal(10, 2)
  machineSales   Decimal  @default(0) @db.Decimal(10, 2)
  machineCashing Decimal  @default(0) @db.Decimal(10, 2)
  // Manual breakdown — back-office daily entry from machine printout.
  // Added Apr 2026 to fix wipe-on-refresh bug where these UI fields had
  // no persistence layer.
  grossSales     Decimal  @default(0) @db.Decimal(10, 2)
  cancels        Decimal  @default(0) @db.Decimal(10, 2)
  couponCash     Decimal  @default(0) @db.Decimal(10, 2)
  discounts      Decimal  @default(0) @db.Decimal(10, 2)
  enteredById    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([orgId, storeId, date])
  @@index([orgId, storeId])
  @@map("lottery_online_totals")
}

// ─────────────────────────────────────────────────
// LOTTERY SCAN EVENT
// Audit trail for every ticket/book barcode scan.
// Helps diagnose auto-activation issues and provides
// an immutable log for settlement disputes.
// ─────────────────────────────────────────────────
model LotteryScanEvent {
  id        String   @id @default(cuid())
  orgId     String
  storeId   String
  boxId     String? // null if scan didn't match any inventory
  scannedBy String? // userId
  raw       String // original barcode string
  parsed    Json? // { type, gameNumber, bookNumber, ticketNumber, state }
  action    String // 'activate' | 'update_current' | 'soldout' | 'rejected' | 'auto_soldout'
  context   String // 'pos' | 'eod' | 'receive' | 'return' | 'admin'
  notes     String?
  createdAt DateTime @default(now())

  @@index([orgId, storeId, createdAt])
  @@index([boxId])
  @@map("lottery_scan_events")
}

// ─────────────────────────────────────────────────
// LOTTERY WEEKLY SETTLEMENT (Phase 2)
// One row per (store, weekStart). Computed on demand — the engine can
// regenerate it at any time until it's finalized. After finalize, the row
// is locked (except for paid-at / notes).
// ─────────────────────────────────────────────────
model LotteryWeeklySettlement {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  // Week identification — weekStart is the store's configured start-of-week
  // (Sunday for MA/ME by default; configurable per state adapter). weekEnd
  // is 6 days later. dueDate is the settlement due date (typically the
  // Monday after weekEnd).
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date
  dueDate   DateTime @db.Date

  // ─ Online (draw-game terminal) ───────────────────────
  onlineGross      Decimal @default(0) @db.Decimal(12, 2) // sum of machineSales across the 7 days
  onlineCashings   Decimal @default(0) @db.Decimal(12, 2) // sum of machineCashing + instantCashing
  onlineCommission Decimal @default(0) @db.Decimal(12, 2) // store commission on online sales

  // ─ Instant (scratchoff) ──────────────────────────────
  instantSales       Decimal @default(0) @db.Decimal(12, 2) // value of tickets sold from settled + partial-return books
  instantSalesComm   Decimal @default(0) @db.Decimal(12, 2) // sales commission on instant sales
  instantCashingComm Decimal @default(0) @db.Decimal(12, 2) // cashing commission on scratch payouts

  // ─ Eligible books this week ──────────────────────────
  // IDs of LotteryBox rows that became eligible for settlement this week
  // based on the state adapter rules (80% sold OR maxDaysActive reached).
  settledBookIds   Json @default("[]")
  returnedBookIds  Json @default("[]")
  // Books activated but NOT yet eligible — tracked for transparency
  unsettledBookIds Json @default("[]")

  // ─ Deductions ────────────────────────────────────────
  returnsDeduction Decimal @default(0) @db.Decimal(12, 2) // unsold value of books returned this week

  // ─ Adjustments (manager-entered) ─────────────────────
  bonus         Decimal @default(0) @db.Decimal(12, 2)
  serviceCharge Decimal @default(0) @db.Decimal(12, 2)
  adjustments   Decimal @default(0) @db.Decimal(12, 2) // positive or negative
  notes         String?

  // ─ Final total owed to lottery commission ────────────
  totalDue Decimal @default(0) @db.Decimal(12, 2)

  // ─ Lifecycle ─────────────────────────────────────────
  status        String    @default("draft") // draft | finalized | paid
  computedAt    DateTime? // last time engine recomputed the row
  finalizedAt   DateTime?
  finalizedById String?
  paidAt        DateTime?
  paidRef       String? // cheque # / ACH ref / etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, storeId, weekStart])
  @@index([orgId, storeId, weekStart])
  @@map("lottery_weekly_settlements")
}

// ─────────────────────────────────────────────────
// LOTTERY TICKET CATALOG
// Platform-wide catalog created by superadmin.
// State-scoped so stores only see tickets for their
// own state / province.
// ─────────────────────────────────────────────────
model LotteryTicketCatalog {
  id             String  @id @default(cuid())
  name           String
  gameNumber     String?
  ticketPrice    Decimal @db.Decimal(10, 2)
  ticketsPerBook Int     @default(300)
  state          String // e.g. "TX", "ON", "CA"
  category       String? // e.g. "instant", "draw"
  active         Boolean @default(true)
  createdBy      String? // superadmin user id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@map("lottery_ticket_catalog")
}

// ─────────────────────────────────────────────────
// LOTTERY TICKET REQUEST
// Submitted by a store when a ticket is not in the
// catalog.  Admin reviews and can promote to catalog.
// ─────────────────────────────────────────────────
model LotteryTicketRequest {
  id                String   @id @default(cuid())
  orgId             String
  storeId           String
  storeName         String?
  name              String
  gameNumber        String?
  ticketPrice       Decimal? @db.Decimal(10, 2)
  ticketsPerBook    Int?
  state             String?
  notes             String?
  status            String   @default("pending") // pending | approved | rejected
  adminNotes        String?
  resolvedCatalogId String? // linked catalog entry after approval

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@index([status])
  @@map("lottery_ticket_requests")
}

// ─────────────────────────────────────────────────
// CMS PAGE
// System-level content pages managed by superadmin
// ─────────────────────────────────────────────────
model CmsPage {
  id        String  @id @default(cuid())
  slug      String  @unique // URL-safe identifier (e.g. "home", "about", "features")
  title     String
  content   String  @db.Text // HTML or Markdown body
  metaTitle String? // SEO meta title
  metaDesc  String? // SEO meta description
  published Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_pages")
}

// ─────────────────────────────────────────────────
// CAREER POSTING
// Job listings managed by superadmin
// ─────────────────────────────────────────────────
model CareerPosting {
  id          String  @id @default(cuid())
  title       String
  department  String? // e.g. "Engineering", "Sales", "Support"
  location    String? // e.g. "Remote", "Toronto, ON"
  type        String? // "full-time" | "part-time" | "contract" | "internship"
  description String  @db.Text // Full job description (HTML or Markdown)
  published   Boolean @default(false)

  applications JobApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("career_postings")
}

// ─────────────────────────────────────────────────
// JOB APPLICATION
// Public job applications submitted for career postings
// ─────────────────────────────────────────────────
model JobApplication {
  id              String        @id @default(cuid())
  careerPostingId String
  careerPosting   CareerPosting @relation(fields: [careerPostingId], references: [id], onDelete: Cascade)

  name        String
  email       String
  phone       String?
  coverLetter String? @db.Text
  resumeUrl   String? // file path to uploaded resume

  status     String  @default("new") // "new" | "reviewed" | "shortlisted" | "rejected"
  adminNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([careerPostingId])
  @@index([status])
  @@map("job_applications")
}

// ─────────────────────────────────────────────────
// SUPPORT TICKET
// Customer/user support requests
// ─────────────────────────────────────────────────
model SupportTicket {
  id         String  @id @default(cuid())
  userId     String? // optional — may be from unauthenticated user
  orgId      String? // optional — which org the ticket relates to
  email      String // contact email
  name       String? // contact name
  subject    String
  body       String  @db.Text
  status     String  @default("open") // "open" | "in_progress" | "resolved" | "closed"
  priority   String  @default("normal") // "low" | "normal" | "high" | "urgent"
  adminNotes String? @db.Text // internal notes by superadmin
  responses  Json?   @default("[]") // Array of { by, byType, message, date } and { type:'assignment', from, to, by, at }

  // Assignment — admin/superadmin user responsible for handling the ticket
  assignedToId String?
  assignedAt   DateTime?
  assignedById String?
  assignedTo   User? @relation("TicketAssignee", fields: [assignedToId], references: [id])
  assignedBy   User? @relation("TicketAssigner", fields: [assignedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([orgId])
  @@index([assignedToId, status])
  @@map("support_tickets")
}

// ─────────────────────────────────────────────────
// LOYALTY PROGRAM
// Per-store loyalty settings (one record per store)
// ─────────────────────────────────────────────────
model LoyaltyProgram {
  id                    String   @id @default(cuid())
  orgId                 String
  storeId               String   @unique
  enabled               Boolean  @default(true)
  programName           String   @default("Loyalty Rewards")
  pointsPerDollar       Decimal  @default(1) @db.Decimal(8, 4) // pts earned per $1 spent
  redeemPointsPerDollar Decimal  @default(100) @db.Decimal(10, 2) // pts needed per $1 off
  minPointsToRedeem     Int      @default(100)
  maxRedemptionPerTx    Decimal? @db.Decimal(10, 2) // max $ off per tx (null = unlimited)
  welcomeBonus          Int      @default(0)
  birthdayBonus         Int      @default(0)
  expiryDays            Int? // null = no expiry
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orgId])
  @@map("loyalty_programs")
}

// ─────────────────────────────────────────────────
// LOYALTY EARN RULE
// Department or product overrides for earning multiplier
// ─────────────────────────────────────────────────
model LoyaltyEarnRule {
  id         String   @id @default(cuid())
  orgId      String
  storeId    String
  targetType String // 'department' | 'product'
  targetId   String // departmentId or productId
  targetName String? // denormalised label for display
  action     String // 'exclude' | 'multiply'
  multiplier Decimal  @default(1) @db.Decimal(8, 4) // only used when action='multiply'
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("loyalty_earn_rules")
}

// ─────────────────────────────────────────────────
// LOYALTY REWARD
// Fixed reward tiers customers can redeem
// ─────────────────────────────────────────────────
model LoyaltyReward {
  id          String   @id @default(cuid())
  orgId       String
  storeId     String
  name        String
  description String?
  pointsCost  Int
  rewardType  String   @default("dollar_off") // 'dollar_off' | 'pct_off'
  rewardValue Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("loyalty_rewards")
}

// ─────────────────────────────────────────────────
// SYSTEM CONFIG
// Global key-value settings managed by superadmin
// ─────────────────────────────────────────────────
model SystemConfig {
  id          Int     @id @default(autoincrement())
  key         String  @unique // e.g. "maintenance_mode", "signup_enabled", "default_plan"
  value       String // stored as string; parse in controller
  description String? // human-readable description of the setting

  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ═══════════════════════════════════════════════════════════════
// PAYMENT TRANSACTION
// PCI-safe audit record for every card transaction (Dejavoo / future providers).
// Raw PAN, CVV, magnetic-stripe data are NEVER stored — only masked card info
// (last 4, card type) and the processor-issued ReferenceId.
// ═══════════════════════════════════════════════════════════════
model PaymentTransaction {
  id               String  @id @default(cuid())
  orgId            String
  storeId          String
  merchantId       String // FK to PaymentMerchant (per-store credentials)
  posTransactionId String? // FK to Transaction.id (nullable — set after POS tx saved)
  provider         String  @default("dejavoo") // "dejavoo" | future providers

  // ── Source ──────────────────────────────────────────────────
  // Which surface initiated the transaction.
  //   "pos"  — in-person card-present via SPIn (cashier-app)
  //   "ecom" — online via HPP (storefront)
  txSource    String  @default("pos")
  ecomOrderId String? // cross-DB ref to EcomOrder.id when txSource='ecom' (no FK — ecom DB is separate)

  // ── Processor response fields ───────────────────────────────
  retref   String? @unique // ReferenceId (Dejavoo UUID) — unique per transaction
  authCode String? // approval auth code
  respCode String? // Dejavoo StatusCode — "0000" = approved
  respText String? // Dejavoo Message — "Approved", "Declined", etc.

  // ── Card info (PCI-safe) ───────────────────────────────────
  token     String? // processor token (for future card-on-file)
  lastFour  String? // last 4 digits
  acctType  String? // Visa | Mastercard | Amex | Discover | EBT
  expiry    String? // MMYY
  entryMode String? // Chip | Swipe | Contactless | Manual

  // ── Amounts ─────────────────────────────────────────────────
  amount         Decimal  @db.Decimal(10, 2)
  capturedAmount Decimal? @db.Decimal(10, 2)

  // ── Status ──────────────────────────────────────────────────
  type   String @default("sale") // sale | void | refund
  status String @default("pending") // pending | approved | declined | voided | refunded | error

  // ── Signature ───────────────────────────────────────────────
  signatureData     String? @db.Text
  signatureCaptured Boolean @default(false)

  // ── Linkage ─────────────────────────────────────────────────
  originalRetref String? // for void/refund — references original sale ReferenceId
  invoiceNumber  String? // matches posTransaction.txNumber
  orderNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchant PaymentMerchant @relation(fields: [merchantId], references: [id])

  @@index([orgId, storeId])
  @@index([posTransactionId])
  @@index([retref])
  @@index([ecomOrderId])
  @@index([txSource, status])
  @@map("payment_transactions")
}

// ═══════════════════════════════════════════════════════════════
// DEJAVOO / iPOSpays — store-scoped merchant credentials
// One row per store. Managed ONLY via admin panel (superadmin).
// Credentials encrypted at rest via cryptoVault.js.
// ═══════════════════════════════════════════════════════════════
model PaymentMerchant {
  id          String @id @default(cuid())
  orgId       String
  storeId     String @unique
  provider    String @default("dejavoo")
  environment String @default("uat")

  // ── Dejavoo SPIn (in-person) ──
  spinTpn        String?
  spinAuthKey    String? // encrypted
  spinBaseUrl    String?
  // RegisterId is the iPOSpays "Register Id" shown under TPN → Edit Parameter →
  // Integration. Required by most /v2/Payment/* endpoints; without it Dejavoo
  // returns 400. One TPN can have multiple lanes — each gets its own RegisterId.
  spinRegisterId String?

  // ── Dejavoo HPP (online checkout) ──
  // hppEnabled gates the storefront ecom flow. Even with credentials filled in,
  // HPP won't process until both hppEnabled=true AND hppLastTestResult='ok'.
  hppMerchantId     String?
  hppAuthKey        String? // encrypted (the iPOSpays HPP JWT / API token)
  hppBaseUrl        String?
  hppEnabled        Boolean   @default(false)
  hppWebhookSecret  String? // encrypted; opaque per-store token embedded in webhook URL
  hppLastTestedAt   DateTime?
  hppLastTestResult String?

  // ── Dejavoo iPOS Transact (card-on-file) ──
  transactApiKey  String? // encrypted
  transactBaseUrl String?

  // ── Feature flags ──
  ebtEnabled      Boolean @default(false)
  debitEnabled    Boolean @default(true)
  tokenizeEnabled Boolean @default(false)

  // ── Status / audit ──
  status         String    @default("active")
  lastTestedAt   DateTime?
  lastTestResult String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  updatedById    String?

  // NOTE: `status` values used by app:
  //   "pending"  — created but never successfully tested; processing BLOCKED
  //   "active"   — tested ok at least once; processing ALLOWED
  //   "disabled" — manually disabled by admin; processing BLOCKED

  transactions PaymentTransaction[]
  terminals    PaymentTerminal[]
  auditLogs    PaymentMerchantAudit[]

  @@index([orgId, storeId])
  @@map("payment_merchants")
}

// ═══════════════════════════════════════════════════════════════
// PAYMENT TERMINAL — physical device bound to a station (multi-terminal support)
// One store may have multiple P17 devices (one per register). This model
// binds each device to a specific station, with an optional per-device TPN
// override (some processors assign a different TPN per lane).
// ═══════════════════════════════════════════════════════════════
model PaymentTerminal {
  id                 String    @id @default(cuid())
  orgId              String
  storeId            String
  merchantId         String // FK → PaymentMerchant
  stationId          String?   @unique // one terminal per station; nullable until paired
  nickname           String? // "Register 1 Terminal", "Express Lane"
  deviceSerialNumber String? // physical P17 serial (from About screen)
  deviceModel        String? // "P17", "Z8", "Z11"
  overrideTpn        String? // per-device TPN (falls back to merchant.spinTpn)
  status             String    @default("active") // active | inactive | unknown
  lastPingedAt       DateTime?
  lastPingResult     String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  merchant PaymentMerchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([orgId, storeId])
  @@index([merchantId])
  @@map("payment_terminals")
}

// ═══════════════════════════════════════════════════════════════
// PAYMENT MERCHANT AUDIT — immutable change log for merchant credentials
// Every create/update/delete on PaymentMerchant appends a row here so we
// have a forensic trail of who changed what and when. Secrets are NEVER
// stored — only a flag indicating the secret was changed.
// ═══════════════════════════════════════════════════════════════
model PaymentMerchantAudit {
  id            String   @id @default(cuid())
  merchantId    String // FK → PaymentMerchant
  action        String // "created" | "updated" | "deleted" | "activated" | "disabled" | "tested"
  changedById   String? // User.id of the superadmin who made the change
  changedByName String? // denormalized for display (user may be deleted later)
  // What changed — JSON diff. Secret fields show { changed: true } instead of values.
  changes       Json?
  note          String? // optional human-readable note
  createdAt     DateTime @default(now())

  merchant PaymentMerchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
  @@map("payment_merchant_audits")
}

// ─────────────────────────────────────────────────
// PAYMENT SETTINGS
// Per-store configuration for card payment behaviour.
// ─────────────────────────────────────────────────
model PaymentSettings {
  id      String @id @default(cuid())
  orgId   String
  storeId String @unique

  // Signature capture
  signatureThreshold Decimal @default(25.00) @db.Decimal(10, 2) // require sig above this amount

  // Tips
  tipEnabled Boolean @default(false)
  tipPresets Json? // [15, 18, 20, 25] as percent integers

  // ── Surcharge / convenience fee ──
  //
  // Session 50 NOTE: the canonical fields for dual pricing now live on the
  // Store model (pricingModel, pricingTierId, customSurchargePercent,
  // customSurchargeFixedFee). These two fields are kept for back-compat with
  // any legacy code that still reads them — they MUST remain in sync via the
  // setStorePricingModel controller. Do NOT add new code that reads from here.
  // surchargePercent is also stored as a fraction here (0.0300 = 3%) whereas
  // the new fields use whole-percent (3.000 = 3%) — different scale.
  surchargeEnabled Boolean  @default(false)
  surchargePercent Decimal? @db.Decimal(5, 4) // e.g. 0.0300 = 3%

  // Accepted card types
  acceptCreditCards Boolean @default(true)
  acceptDebitCards  Boolean @default(true)
  acceptAmex        Boolean @default(true)
  acceptContactless Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("payment_settings")
}

// ═══════════════════════════════════════════════════════════════
// SESSION 50 — DUAL PRICING / CASH DISCOUNT MODEL
// ═══════════════════════════════════════════════════════════════
//
// Two related concepts:
//   1. Pricing model — toggle on Store ("interchange" | "dual_pricing")
//   2. Pricing tier  — preset surcharge rates that map to billing tiers
//                      (Standard / Volume / Enterprise) for SaaS revenue
//                      management. A store also has the option to override
//                      a tier's rates per-store via the customSurcharge*
//                      fields on Store.
//
// Toggle authority is superadmin-only — every flip writes a PricingModelChange
// row for audit. Mid-shift switches are blocked by the controller (the new
// model takes effect at the next OpenShift).

// ─────────────────────────────────────────────────
// PRICING TIER — platform catalog of surcharge presets
// Managed by superadmin. Stores reference one tier via Store.pricingTierId,
// or override with custom rates on the Store record itself.
// ─────────────────────────────────────────────────
model PricingTier {
  id                String   @id @default(cuid())
  // Stable key for code/billing references. e.g. "tier_1", "tier_2", "tier_3", "custom".
  // The "custom" key is reserved as a sentinel for the per-store override
  // path — no Store should reference it directly.
  key               String   @unique
  name              String // "Standard 3% + $0.30"
  description       String?  @db.Text
  surchargePercent  Decimal  @db.Decimal(5, 3) // e.g. 3.000 = 3%
  surchargeFixedFee Decimal  @db.Decimal(10, 2) // e.g. 0.30
  active            Boolean  @default(true)
  isDefault         Boolean  @default(false) // shown as default in tier picker
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stores Store[]

  @@index([active, sortOrder])
  @@map("pricing_tiers")
}

// ─────────────────────────────────────────────────
// PRICING MODEL CHANGE — audit log of per-store pricing model toggles
// Every superadmin flip lands here. Used to:
//   - show "Recent changes" history on the per-store admin config page
//   - reconcile when a store's pricingModel changed mid-period
//   - prove regulatory compliance (some states require auditable history
//     of when surcharge was activated/deactivated)
// ─────────────────────────────────────────────────
model PricingModelChange {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  changedById   String // User.id of the superadmin who made the change
  changedByName String? // denormalized for display (user may be deleted later)
  fromModel     String // "interchange" | "dual_pricing"
  toModel       String
  fromTierId    String?
  toTierId      String?
  fromPercent   Decimal? @db.Decimal(5, 3)
  toPercent     Decimal? @db.Decimal(5, 3)
  fromFixedFee  Decimal? @db.Decimal(10, 2)
  toFixedFee    Decimal? @db.Decimal(10, 2)
  reason        String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([storeId, createdAt])
  @@map("pricing_model_changes")
}

// ═══════════════════════════════════════════════════════════════
// BILLING — SUBSCRIPTION PLANS, INVOICES & EQUIPMENT
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// SUBSCRIPTION PLAN
// ─────────────────────────────────────────────────
model SubscriptionPlan {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?
  basePrice         Decimal  @db.Decimal(10, 2)
  pricePerStore     Decimal  @default(0) @db.Decimal(10, 2)
  pricePerRegister  Decimal  @default(0) @db.Decimal(10, 2)
  includedStores    Int      @default(1)
  includedRegisters Int      @default(1)
  trialDays         Int      @default(14)
  isPublic          Boolean  @default(true)
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // S78 — extended fields for the marketing/feature-gating UI.
  // These are optional so existing plans seeded by older code stay valid.
  tagline           String?  // short marketing line shown on the pricing page
  annualPrice       Decimal? @db.Decimal(10, 2) // pre-discounted yearly amount; null falls back to basePrice * 12
  isCustomPriced    Boolean  @default(false)    // 'Contact us for pricing' (Enterprise)
  currency          String   @default("USD")
  maxUsers          Int?     // null = unlimited; complements includedStores/Registers
  highlighted       Boolean  @default(false)    // shown as "most popular" in pricing UI
  isDefault         Boolean  @default(false)    // assigned to fresh orgs as fallback

  // S81 — dynamic bundle pricing for Pro-style "everything included" plans.
  //   bundleDiscountPercent: when set, basePrice is computed as
  //     (default plan basePrice + Σ default plan addon prices) × (1 - pct/100).
  //     Re-derived by the seeder + admin pricing endpoints whenever Starter base,
  //     addon prices, or this percentage change. Stored alongside basePrice so
  //     reads stay O(1) and don't need to join PlanAddon at request time.
  //   priceOverride: admin manual override. When set, computeEffectivePlanPrice()
  //     returns this verbatim and ignores the dynamic bundle calc. Lets ops
  //     hand-tune Pro for a promo without losing the underlying formula.
  bundleDiscountPercent Decimal? @db.Decimal(5, 2)
  priceOverride         Decimal? @db.Decimal(10, 2)

  addons             PlanAddon[]
  subscriptions      OrgSubscription[]   // legacy — kept for transition; phased out in Phase 3
  storeSubscriptions StoreSubscription[]
  // S78 — modules this plan grants access to
  modules       PlanModule[]

  @@map("subscription_plans")
}

// ─────────────────────────────────────────────────
// PLAN ADD-ON
// ─────────────────────────────────────────────────
model PlanAddon {
  id          String           @id @default(cuid())
  planId      String
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  key         String
  label       String
  price       Decimal          @db.Decimal(10, 2)
  description String?
  isActive    Boolean          @default(true)
  // S80 — module keys this addon unlocks when purchased.
  // Resolver: store's modules = plan modules ∪ (purchased-addon modules) ∪ core.
  moduleKeys  String[]         @default([])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([planId, key])
  @@map("plan_addons")
}

// ─────────────────────────────────────────────────
// ORG SUBSCRIPTION
// ─────────────────────────────────────────────────
model OrgSubscription {
  id           String           @id @default(cuid())
  orgId        String           @unique
  organization Organization     @relation(fields: [orgId], references: [id])
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  status             String    @default("trial")
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  storeCount    Int      @default(1)
  registerCount Int      @default(1)
  extraAddons   String[]

  basePriceOverride Decimal? @db.Decimal(10, 2)

  discountType   String?
  discountValue  Decimal?  @db.Decimal(10, 2)
  discountNote   String?
  discountExpiry DateTime?

  paymentToken  String?
  paymentMasked String?
  paymentMethod String?

  retryCount   Int       @default(0)
  lastFailedAt DateTime?
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices BillingInvoice[]

  @@map("org_subscriptions")
}

// ─────────────────────────────────────────────────
// STORE SUBSCRIPTION (S80 — per-store billing/entitlement)
// One subscription per store. Org with N stores = N StoreSubscription rows,
// each potentially on a different plan + different addon set. Entitlement
// resolver scopes by active X-Store-Id header.
//
// extraAddons: array of PlanAddon.key values purchased on this store. Each
// addon's moduleKeys[] union into the store's effective module set.
//
// Phase 1: lives alongside OrgSubscription. New code reads StoreSubscription;
// fallback to OrgSubscription kept for safety during transition.
// Phase 3: BillingInvoice repointed here, OrgSubscription retired.
// ─────────────────────────────────────────────────
model StoreSubscription {
  id      String           @id @default(cuid())
  storeId String           @unique
  store   Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orgId   String           // denormalized for fast org-scoped queries
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  planId  String
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  status             String    @default("trial")   // trial | active | past_due | cancelled | suspended
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?

  registerCount Int      @default(1)
  extraAddons   String[] @default([])   // PlanAddon.key values purchased on this store

  basePriceOverride Decimal? @db.Decimal(10, 2)

  discountType   String?
  discountValue  Decimal?  @db.Decimal(10, 2)
  discountNote   String?
  discountExpiry DateTime?

  paymentToken  String?
  paymentMasked String?
  paymentMethod String?

  retryCount   Int       @default(0)
  lastFailedAt DateTime?
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices BillingInvoice[]

  @@index([orgId, status])
  @@index([planId])
  @@index([status, currentPeriodEnd])
  @@map("store_subscriptions")
}

// ─────────────────────────────────────────────────
// BILLING INVOICE
// ─────────────────────────────────────────────────
model BillingInvoice {
  id             String           @id @default(cuid())
  invoiceNumber  String           @unique

  // Legacy org-level link (kept for transition; nullable from S80 Phase 3b).
  // Old invoices reference an OrgSubscription; new invoices reference a
  // StoreSubscription via storeSubscriptionId. Reads should prefer the
  // newer field; writers populate the appropriate one based on the
  // subscription type. Phase 4 retires `subscriptionId` entirely.
  subscriptionId String?
  subscription   OrgSubscription? @relation(fields: [subscriptionId], references: [id])

  // S80 Phase 3b — per-store invoice linkage (preferred for new invoices).
  storeSubscriptionId String?
  storeSubscription   StoreSubscription? @relation(fields: [storeSubscriptionId], references: [id])

  periodStart DateTime
  periodEnd   DateTime

  baseAmount     Decimal @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  status        String    @default("pending")
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  paidAt        DateTime?

  retref   String?
  authcode String?
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId, status])
  @@index([storeSubscriptionId, status])
  @@map("billing_invoices")
}

// ─────────────────────────────────────────────────
// EQUIPMENT PRODUCT
// ─────────────────────────────────────────────────
model EquipmentProduct {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  category    String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  images      String[]
  specs       Json?
  stockQty    Int      @default(0)
  trackStock  Boolean  @default(true)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems EquipmentOrderItem[]

  @@map("equipment_products")
}

// ─────────────────────────────────────────────────
// EQUIPMENT ORDER
// ─────────────────────────────────────────────────
model EquipmentOrder {
  id          String  @id @default(cuid())
  orderNumber String  @unique
  orgId       String?

  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress Json

  subtotal Decimal @db.Decimal(10, 2)
  shipping Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  paymentToken  String?
  retref        String?
  authcode      String?
  paymentStatus String  @default("pending")

  status          String  @default("pending")
  trackingCarrier String?
  trackingNumber  String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items EquipmentOrderItem[]

  @@map("equipment_orders")
}

// ─────────────────────────────────────────────────
// EQUIPMENT ORDER ITEM
// ─────────────────────────────────────────────────
model EquipmentOrderItem {
  id        String           @id @default(cuid())
  orderId   String
  order     EquipmentOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   EquipmentProduct @relation(fields: [productId], references: [id])
  qty       Int
  unitPrice Decimal          @db.Decimal(10, 2)
  lineTotal Decimal          @db.Decimal(10, 2)
  createdAt DateTime         @default(now())

  @@map("equipment_order_items")
}

// ─────────────────────────────────────────────────
// PURCHASE ORDER — Vendor reorder system
// ─────────────────────────────────────────────────
model PurchaseOrder {
  id       String @id @default(cuid())
  orgId    String
  storeId  String
  vendorId Int
  poNumber String @unique // "PO-YYYYMMDD-001"
  status   String @default("draft") // draft, pending_approval, approved, submitted, partial, received, cancelled

  orderDate    DateTime  @default(now())
  expectedDate DateTime? // orderDate + vendor.leadTimeDays
  receivedDate DateTime?

  subtotal   Decimal @db.Decimal(10, 2)
  taxTotal   Decimal @default(0) @db.Decimal(10, 2)
  grandTotal Decimal @db.Decimal(10, 2)

  notes       String?
  generatedBy String  @default("manual") // "manual" | "auto" | "suggestion"
  createdById String

  // ── Invoice linkage ──
  invoiceId     String?
  invoiceNumber String?

  // ── Receiving ──
  receivedById  String?
  receiverNotes String?
  totalVariance Decimal @default(0) @db.Decimal(10, 2)

  // ── Approval workflow ──
  approvalRequired Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  approvalNotes    String?

  // ── Vendor communication ──
  sentToVendor Boolean   @default(false)
  sentAt       DateTime?
  sentMethod   String? // "email" | "manual"

  items        PurchaseOrderItem[]
  vendor       Vendor              @relation(fields: [vendorId], references: [id])
  organization Organization        @relation(fields: [orgId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([vendorId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  orderId         String
  masterProductId Int

  qtyOrdered  Int // units ordered
  qtyCases    Int @default(0) // cases ordered (for display)
  qtyReceived Int @default(0) // units actually received
  qtyDamaged  Int @default(0) // units damaged on arrival
  qtyReturned Int @default(0) // units returned to vendor

  unitCost  Decimal @db.Decimal(10, 4)
  caseCost  Decimal @default(0) @db.Decimal(10, 4)
  lineTotal Decimal @db.Decimal(10, 2)

  // ── Invoice reconciliation ──
  actualUnitCost Decimal? @db.Decimal(10, 4) // cost from invoice (may differ)
  actualCaseCost Decimal? @db.Decimal(10, 4)
  costVariance   Decimal? @db.Decimal(10, 4) // actualUnitCost - unitCost
  varianceFlag   String? // "none" | "minor" | "major"

  // ── Backorder tracking ──
  backorderQty    Int     @default(0) // qtyOrdered - qtyReceived when short
  backorderStatus String? // "pending" | "on_next_po" | "cancelled"

  receivedNotes String?

  // Algorithm metadata — why this qty was suggested
  forecastDemand Decimal? @db.Decimal(10, 2)
  safetyStock    Decimal? @db.Decimal(10, 2)
  currentOnHand  Decimal? @db.Decimal(10, 2)
  avgDailySales  Decimal? @db.Decimal(10, 4)
  reorderReason  String? // "below_reorder_point","forecast_demand","trending_up","low_days_supply","backorder"

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product MasterProduct @relation(fields: [masterProductId], references: [id])

  createdAt DateTime @default(now())

  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────────
// VENDOR RETURNS — Track returns to vendors for credit
// ─────────────────────────────────────────────────
model VendorReturn {
  id              String    @id @default(cuid())
  orgId           String
  storeId         String
  vendorId        Int
  purchaseOrderId String? // optional link to original PO
  returnNumber    String    @unique // "RET-YYYYMMDD-001"
  status          String    @default("draft") // draft, submitted, credited, closed
  reason          String // damaged, expired, wrong_item, overstock, recall
  totalAmount     Decimal   @default(0) @db.Decimal(10, 2)
  creditReceived  Decimal   @default(0) @db.Decimal(10, 2)
  notes           String?
  submittedAt     DateTime?
  creditedAt      DateTime?
  createdById     String

  items        VendorReturnItem[]
  vendor       Vendor             @relation(fields: [vendorId], references: [id])
  organization Organization       @relation(fields: [orgId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([vendorId])
  @@map("vendor_returns")
}

model VendorReturnItem {
  id              String  @id @default(cuid())
  returnId        String
  masterProductId Int
  qty             Int
  unitCost        Decimal @db.Decimal(10, 4)
  lineTotal       Decimal @db.Decimal(10, 2)
  reason          String // per-item reason

  return  VendorReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product MasterProduct @relation(fields: [masterProductId], references: [id])

  @@map("vendor_return_items")
}

// ─────────────────────────────────────────────────
// INVENTORY ADJUSTMENTS — Shrinkage, damage, corrections
// ─────────────────────────────────────────────────
model InventoryAdjustment {
  id              String   @id @default(cuid())
  orgId           String
  storeId         String
  masterProductId Int
  adjustmentQty   Int // negative = shrinkage, positive = found stock
  previousQty     Int      @default(0)
  newQty          Int      @default(0)
  reason          String // shrinkage, damage, spoilage, expired, theft, count_correction, found, return
  notes           String?
  createdById     String
  createdAt       DateTime @default(now())

  product MasterProduct @relation(fields: [masterProductId], references: [id])

  @@index([orgId, storeId, createdAt])
  @@index([masterProductId])
  @@map("inventory_adjustments")
}

// ─────────────────────────────────────────────────
// LABEL QUEUE — Auto-detected + manual label print queue
// ─────────────────────────────────────────────────
model LabelQueue {
  id              Int       @id @default(autoincrement())
  orgId           String
  storeId         String? // null = org-wide master product change
  masterProductId Int
  reason          String // "price_change"|"new_product"|"sale_started"|"sale_ended"|"manual"
  oldPrice        Decimal?  @db.Decimal(10, 4)
  newPrice        Decimal?  @db.Decimal(10, 4)
  status          String    @default("pending") // "pending"|"printed"|"dismissed"
  addedAt         DateTime  @default(now())
  printedAt       DateTime?
  printedBy       String? // User.id who printed

  product MasterProduct @relation(fields: [masterProductId], references: [id])

  @@unique([orgId, storeId, masterProductId, status])
  @@index([orgId, storeId, status])
  @@index([orgId, status, reason])
  @@map("label_queue")
}

// ─────────────────────────────────────────────────
// LABEL PRINT JOB — ZPL payloads routed through the cashier-app's
// Electron bridge. Portal submits ZPL → backend queues → a station
// (running Electron with local Zebra Browser Print) polls, prints,
// reports completion. Works around Chrome LNA / CORS restrictions
// that prevent storeveu.com from calling localhost:9101 directly.
// ─────────────────────────────────────────────────
model LabelPrintJob {
  id                 Int       @id @default(autoincrement())
  orgId              String
  storeId            String?
  stationId          String? // null = any eligible station; non-null = target this station
  zpl                String    @db.Text
  printerName        String? // optional Zebra printer name; station decides default if null
  source             String    @default("label_queue") // "label_queue"|"label_design"|"manual"
  labelCount         Int       @default(1)
  metadata           Json? //  productIds?, templateName?, userName?, ...
  status             String    @default("pending") // "pending"|"claimed"|"completed"|"failed"
  claimedByStationId String?
  claimedAt          DateTime?
  completedAt        DateTime?
  error              String?   @db.Text
  attempts           Int       @default(0)
  submittedByUserId  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([orgId, storeId, status])
  @@index([status, createdAt])
  @@index([claimedByStationId, status])
  @@map("label_print_jobs")
}

// ─────────────────────────────────────────────────
// AUDIT LOG — Immutable record of all user actions
// Cannot be deleted by any user including admin.
// ─────────────────────────────────────────────────
model AuditLog {
  id        Int     @id @default(autoincrement())
  orgId     String
  storeId   String?
  userId    String // who performed the action
  userName  String? // denormalized for fast display
  userRole  String? // role at time of action
  action    String // "create"|"update"|"delete"|"void"|"refund"|"login"|"logout"|"shift_open"|"shift_close"|"price_change"|"settings_change"
  entity    String // "product"|"transaction"|"shift"|"user"|"store"|"order"|"customer"|"label"|"settings"
  entityId  String? // ID of the affected record
  details   Json? // { field: "retailPrice", oldValue: 4.99, newValue: 5.49 }
  ipAddress String?
  userAgent String?
  source    String  @default("portal") // "portal"|"cashier"|"admin"|"api"

  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([orgId, userId])
  @@index([orgId, entity, action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────
// CHAT MESSAGE — Internal messaging (cashier ↔ back-office)
// ─────────────────────────────────────────────────
model ChatMessage {
  id          String   @id @default(cuid())
  orgId       String
  storeId     String?
  channelId   String // "store:{storeId}" for store-wide, "direct:{userId1}:{userId2}" for DM
  senderId    String
  senderName  String // denormalized
  senderRole  String? // "owner"|"manager"|"cashier" etc
  message     String   @db.Text
  messageType String   @default("text") // "text"|"image"|"system"|"alert"
  readBy      String[] @default([]) // array of userIds who read it
  pinned      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([orgId, channelId, createdAt])
  @@index([orgId, storeId, createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────
// TASK — Task assignment system
// ─────────────────────────────────────────────────
model Task {
  id          String  @id @default(cuid())
  orgId       String
  storeId     String?
  title       String
  description String? @db.Text
  priority    String  @default("normal") // "low"|"normal"|"high"|"urgent"
  status      String  @default("open") // "open"|"in_progress"|"completed"|"cancelled"
  category    String? // "cleaning"|"stocking"|"display"|"inventory"|"other"

  assignedTo   String? // userId — who should do it
  assignedBy   String // userId — who created it
  assigneeName String? // denormalized
  assignerName String? // denormalized

  // Checklist items: [{ id, text, done, completedAt, completedBy }]
  checklist Json @default("[]")

  // Assign to register (optional — in addition to assignedTo user)
  stationId   String? // which register this task is for
  stationName String? // denormalized

  // Recurring schedule
  isRecurring     Boolean   @default(false)
  recurType       String? // "daily"|"weekly"|"biweekly"|"monthly"
  recurDays       String[]  @default([]) // ["Monday","Wednesday","Friday"] for weekly
  recurDayOfMonth Int? // 1-31 for monthly
  recurTime       String? // "09:00" — time of day to create instance
  templateId      String? // if this task was spawned from a template, link to parent
  nextRunAt       DateTime? // when next recurring instance should be created
  lastRunAt       DateTime? // when last instance was created

  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, status])
  @@index([orgId, assignedTo, status])
  @@index([orgId, isRecurring, nextRunAt])
  @@map("tasks")
}

// ─────────────────────────────────────────────────
// STORE INTEGRATION — Multi-platform delivery credentials
// One row per store + platform combination
// ─────────────────────────────────────────────────
model StoreIntegration {
  id              String    @id @default(cuid())
  orgId           String
  storeId         String
  platform        String // "doordash"|"ubereats"|"instacart"|"grubhub"|"postmates"
  credentials     Json // platform-specific: { developerId, keyId, signingSecret, storeLocationId, ... }
  config          Json      @default("{}") // { autoConfirm, syncInterval, syncEnabled, menuId }
  inventoryConfig Json      @default("{}") // { syncFrequency, departments, defaultBehavior }
  // S71 — per-marketplace pricing/markup config: { markupPercent, roundingMode, categoryMarkups,
  //        excludedDepartmentIds, excludedProductIds, minMarginPercent, syncMode,
  //        inventorySyncEnabled, taxInclusive, prepTimeMinutes }
  // Each marketplace charges different commission, so per-platform markup lets stores recover
  // those fees without changing the in-store price. Rounding tidies the marked-up value to .50/.99/.00
  // for psychological pricing. See backend/src/services/marketplaceMarkup.ts for the canonical shape.
  pricingConfig   Json      @default("{}")
  status          String    @default("inactive") // "inactive"|"active"|"error"
  storeName       String? // name on the platform
  lastSyncAt      DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([storeId, platform])
  @@index([orgId, status])
  @@map("store_integrations")
}

// ─────────────────────────────────────────────────
// PLATFORM ORDER — Delivery orders from all platforms
// ─────────────────────────────────────────────────
model PlatformOrder {
  id              String    @id @default(cuid())
  orgId           String
  storeId         String
  platform        String // "doordash"|"ubereats"|"instacart"|"grubhub"
  platformOrderId String // external platform order ID
  shortCode       String? // delivery short code (DoorDash)
  status          String    @default("new") // new|confirmed|preparing|ready|picked_up|delivered|cancelled|failed
  fulfillmentType String? // "delivery"|"pickup"|"merchant_delivery"
  items           Json // [{name, qty, price, merchantItemId, specialInstructions}]
  customerName    String?
  customerPhone   String?
  subtotal        Decimal   @db.Decimal(10, 2)
  tax             Decimal   @default(0) @db.Decimal(10, 2)
  deliveryFee     Decimal   @default(0) @db.Decimal(10, 2)
  tip             Decimal   @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal   @db.Decimal(10, 2)
  estimatedPickup DateTime?
  confirmedAt     DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  dasherStatus    String? // DASHER_CONFIRMED|ARRIVED|PICKED_UP|DROPPED_OFF
  webhookData     Json? // raw webhook payload for audit
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([platform, platformOrderId])
  @@index([orgId, storeId, status])
  @@index([orgId, platform, createdAt])
  @@map("platform_orders")
}

// ─────────────────────────────────────────────────
// GLOBAL PRODUCT MATCH — Cross-store learning database
// Anonymous vendor→product mappings shared across all orgs.
// Higher confirmedCount + orgCount = more reliable match.
// ─────────────────────────────────────────────────
model GlobalProductMatch {
  id                Int      @id @default(autoincrement())
  vendorName        String // normalized: lowercase, trimmed
  vendorItemCode    String // vendor's item code
  vendorDescription String? // vendor's product description
  matchedUPC        String // canonical UPC of matched POS product
  matchedName       String // canonical product name
  confirmedCount    Int      @default(1) // total confirmations across ALL stores
  orgCount          Int      @default(1) // unique orgs that confirmed this mapping
  orgs              String[] @default([]) // array of orgIds that contributed (for dedup)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([vendorName, vendorItemCode])
  @@index([vendorName])
  @@map("global_product_matches")
}

// ═══════════════════════════════════════════════════════════════
// FUEL MODULE
// Fuel sales (gas station mode) — types, settings, transactions.
// Mirrors the lottery module pattern: store-level enable flag,
// per-type pricing locked in back-office, cashier records sales.
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// FUEL TYPE
// A grade of fuel sold at this store (e.g. "Regular 87",
// "Premium 91", "Diesel"). Price is set per gallon in the
// back-office and locked at cashier (cashier cannot override).
// ─────────────────────────────────────────────────
model FuelType {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  name           String // "Regular", "Premium", "Diesel"
  gradeLabel     String? // optional: "87 Octane", "91 Octane"
  pricePerGallon Decimal  @db.Decimal(10, 3) // 3.999 / gallon
  color          String? // hex color for UI badge: "#16a34a"
  isDefault      Boolean  @default(false) // pre-selected in cashier modal
  isTaxable      Boolean  @default(false)
  taxRate        Decimal? @db.Decimal(5, 4) // optional override (e.g. 0.0825 = 8.25%)
  sortOrder      Int      @default(0)
  active         Boolean  @default(true)
  deleted        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FuelTransaction[]

  // Back-relations for tanks + blend configs
  tanks        FuelTank[]
  blendMiddle  FuelBlendConfig[] @relation("FuelBlendMiddle")
  blendBase    FuelBlendConfig[] @relation("FuelBlendBase")
  blendPremium FuelBlendConfig[] @relation("FuelBlendPremium")

  @@index([orgId, storeId])
  @@map("fuel_types")
}

// ─────────────────────────────────────────────────
// FUEL SETTINGS
// Store-level fuel configuration. Mirrors LotterySettings.
// ─────────────────────────────────────────────────
model FuelSettings {
  id      String @id @default(cuid())
  orgId   String
  storeId String @unique

  enabled          Boolean @default(false)
  cashOnly         Boolean @default(false) // restrict fuel sales to cash
  allowRefunds     Boolean @default(true) // allow fuel refund button at cashier
  defaultEntryMode String  @default("amount") // "amount" | "gallons"

  // Optional convenience: pre-selected default fuel type id (set via portal)
  defaultFuelTypeId String?

  // Inventory reconciliation — when stick readings are expected
  // "shift" | "daily" | "weekly" | "on_demand"
  reconciliationCadence         String  @default("shift")
  // % variance that triggers an alert on the Reconciliation tab
  varianceAlertThreshold        Decimal @default(2.0) @db.Decimal(5, 2)
  // Opt-in: dispenser-blended middle grades (e.g. Plus/89 from 87 + 93)
  blendingEnabled               Boolean @default(false)
  // V1.5: track sales by pump #. When true, cashier picks a pump in the
  // FuelModal and the sale records `pumpId`. When false, all sales aggregate
  // to the grade's primary/manifold tank without pump attribution.
  pumpTrackingEnabled           Boolean @default(false)
  // V1.5: delivery cost variance threshold. A new FuelDelivery whose
  // $/gal exceeds the last-3-delivery rolling avg by more than this %
  // triggers a warning on the delivery-create form. Default 5% matches
  // PDI / NACS industry standard for "price anomaly" alerts.
  deliveryCostVarianceThreshold Decimal @default(5.0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("fuel_settings")
}

// ─────────────────────────────────────────────────
// FUEL TANK
// Physical underground storage tank. Multi-tank per grade supported
// (e.g. two Regular 87 tanks manifolded together, or fully independent).
// Horizontal cylindrical shape — only shape supported in V1.
// ─────────────────────────────────────────────────
model FuelTank {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  name     String // "Tank A - Regular 87"
  tankCode String? // optional short code for receipts/BOL ("A1", "T-REG-1")

  fuelTypeId String
  fuelType   FuelType @relation(fields: [fuelTypeId], references: [id])

  // Capacity in US gallons
  capacityGal    Decimal  @db.Decimal(10, 2)
  // Physical dimensions (for accurate horizontal-cylinder visualization)
  diameterInches Decimal? @db.Decimal(8, 2)
  lengthInches   Decimal? @db.Decimal(8, 2)

  // Multi-tank topology — exactly one of these applies per grade at a store:
  // - "independent"  → tank is standalone, sales deduct from its active setting
  // - "manifolded"   → tank is in a manifold group (shares level with siblings)
  // - "sequential"   → tank is primary or secondary in a drain-primary-first setup (V1.5 — stored but not yet enforced)
  topology String @default("independent")

  // When topology='manifolded', which group this tank belongs to
  manifoldGroupId String?
  manifoldGroup   FuelManifoldGroup? @relation(fields: [manifoldGroupId], references: [id])

  // When topology='independent' with 2+ tanks of same grade, one is the
  // "active" tank — sales deduct from it until empty (or until admin switches).
  // NULL for manifolded tanks.
  isPrimary Boolean @default(true)

  active  Boolean @default(true)
  deleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveryItems FuelDeliveryItem[]
  stickReadings FuelStickReading[]
  transactions  FuelTransaction[]

  @@index([orgId, storeId])
  @@index([fuelTypeId])
  @@index([manifoldGroupId])
  @@map("fuel_tanks")
}

// ─────────────────────────────────────────────────
// FUEL MANIFOLD GROUP
// Group of physically connected tanks that share one fuel level.
// Sales deduct proportionally from all members (by capacity ratio).
// ─────────────────────────────────────────────────
model FuelManifoldGroup {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  name String // "Regular 87 Manifold"

  // Behaviour when sales post against this group:
  // "equal"       → split sale evenly across tanks (most common)
  // "capacity"    → split by each tank's capacity ratio
  // "sequential"  → drain primary first then fall through (future V1.5)
  drainMode String @default("equal")

  active  Boolean @default(true)
  deleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tanks FuelTank[]

  @@index([orgId, storeId])
  @@map("fuel_manifold_groups")
}

// ─────────────────────────────────────────────────
// FUEL DELIVERY
// One BOL from the supplier. May fill one or many tanks (split delivery).
// ─────────────────────────────────────────────────
model FuelDelivery {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  deliveryDate DateTime @default(now())
  supplier     String? // "Shell Distributor", etc.
  bolNumber    String? // free-form BOL reference
  notes        String?  @db.Text

  // Aggregate fields cached for list view (sum of items)
  totalGallons Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @default(0) @db.Decimal(12, 2)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items FuelDeliveryItem[]

  @@index([orgId, storeId, deliveryDate])
  @@map("fuel_deliveries")
}

// ─────────────────────────────────────────────────
// FUEL DELIVERY ITEM  (doubles as the FIFO cost layer)
// One line per tank filled from a single BOL. As fuel sells, the
// `remainingGallons` is decremented; COGS for each sale pulls from
// the oldest non-empty layer for that tank.
// ─────────────────────────────────────────────────
model FuelDeliveryItem {
  id         String       @id @default(cuid())
  deliveryId String
  delivery   FuelDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  tankId String
  tank   FuelTank @relation(fields: [tankId], references: [id])

  gallonsReceived Decimal @db.Decimal(10, 2)
  pricePerGallon  Decimal @db.Decimal(10, 4) // 4-decimal cost precision (vendor markup is often <1¢)
  totalCost       Decimal @db.Decimal(12, 2) // gallonsReceived × pricePerGallon

  // FIFO running balance — decrements as sales post against this layer
  remainingGallons Decimal   @db.Decimal(10, 4)
  fullyConsumedAt  DateTime? // timestamp when remainingGallons → 0

  createdAt DateTime @default(now())

  @@index([tankId, createdAt]) // chronological FIFO ordering per tank
  @@index([deliveryId])
  @@map("fuel_delivery_items")
}

// ─────────────────────────────────────────────────
// FUEL STICK READING
// Manual tank measurement (stick or gauge). Compared to software-
// expected level; variance flagged if above FuelSettings threshold.
// ─────────────────────────────────────────────────
model FuelStickReading {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  tankId String
  tank   FuelTank @relation(fields: [tankId], references: [id])

  readingDate     DateTime @default(now())
  actualGallons   Decimal  @db.Decimal(10, 2) // measured by cashier / manager
  expectedGallons Decimal  @db.Decimal(10, 2) // derived from deliveries + sales at time of entry
  variance        Decimal  @db.Decimal(10, 2) // actualGallons − expectedGallons
  variancePct     Decimal  @db.Decimal(6, 3) // variance / expectedGallons × 100

  shiftId String? // optional — if entered as part of EoD close
  notes   String? @db.Text

  createdById String?
  createdAt   DateTime @default(now())

  @@index([orgId, storeId, readingDate])
  @@index([tankId, readingDate])
  @@map("fuel_stick_readings")
}

// ─────────────────────────────────────────────────
// FUEL PUMP (V1.5)
// Physical dispenser. One store has 1..N pumps. Each pump defaults to
// drawing from the grade's primary/manifold tank, but can override per-
// grade via `tankOverrides: { [fuelTypeId]: tankId }` when the station
// has multiple independent tanks of the same grade routed to different
// pumps (e.g. pumps 1-4 → Tank A, pumps 5-8 → Tank B).
// Only rendered in the cashier FuelModal when FuelSettings.pumpTrackingEnabled.
// ─────────────────────────────────────────────────
model FuelPump {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  // S79b (F27) — Human-visible pump identifier shown big on the tile.
  // Originally `Int` (1-N); migrated to `String` to allow alphanumeric
  // labels like "A1", "Diesel-1", "Out-front" — useful for stations that
  // don't number their pumps purely by integer (e.g. side-by-side islands
  // labeled A/B/1/2). Existing integer values migrate cleanly via
  // `pumpNumber::text` so old data still resolves.
  // Validator (controller side): alphanumeric + dash + underscore, 1–16 chars.
  pumpNumber String
  // Optional descriptor shown under the number ("Entry side", "Diesel Island")
  label      String?
  // Accent colour for the icon tile (hex). If null, fuel type's colour wins.
  color      String?

  // Optional per-grade tank override: { "fuelTypeIdX": "tankIdY", ... }.
  // Sales at this pump for that grade draw from the named tank instead of
  // the grade's primary/manifold. Empty → falls back to grade default.
  tankOverrides Json? @default("{}")

  sortOrder Int     @default(0)
  active    Boolean @default(true)
  deleted   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions FuelTransaction[]

  @@unique([orgId, storeId, pumpNumber])
  @@index([orgId, storeId])
  @@map("fuel_pumps")
}

// ─────────────────────────────────────────────────
// FUEL BLEND CONFIG
// Optional: dispenser-blended middle grades (e.g. Plus/89 blended in
// the pump from base Regular 87 + Premium 93). When a sale posts for
// the middle grade, the FIFO service deducts from BOTH base and
// premium tanks in the configured ratio.
// Only active when FuelSettings.blendingEnabled = true.
// ─────────────────────────────────────────────────
model FuelBlendConfig {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  // The middle grade produced by blending (e.g. FuelType "Plus 89")
  middleFuelTypeId String   @unique
  middleFuelType   FuelType @relation("FuelBlendMiddle", fields: [middleFuelTypeId], references: [id])

  // Base (lower-grade) fuel type — typically Regular 87
  baseFuelTypeId String
  baseFuelType   FuelType @relation("FuelBlendBase", fields: [baseFuelTypeId], references: [id])
  // Fraction of base in the blend (0..1). E.g. 0.67 for 89 from 87+93.
  baseRatio      Decimal  @db.Decimal(5, 4)

  // Premium (higher-grade) fuel type — typically Premium 93
  premiumFuelTypeId String
  premiumFuelType   FuelType @relation("FuelBlendPremium", fields: [premiumFuelTypeId], references: [id])
  premiumRatio      Decimal  @db.Decimal(5, 4) // 1 − baseRatio

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("fuel_blend_configs")
}

// ─────────────────────────────────────────────────
// FUEL TRANSACTION
// Individual fuel sale or refund recorded with a POS transaction.
// Stores both gallons and amount so reports can aggregate either.
// pricePerGallon is snapshotted at sale-time (3-decimal precision).
// ─────────────────────────────────────────────────
model FuelTransaction {
  id        String  @id @default(cuid())
  orgId     String
  storeId   String
  shiftId   String?
  cashierId String?
  stationId String?

  type         String // "sale" | "refund"
  fuelTypeId   String?
  fuelType     FuelType? @relation(fields: [fuelTypeId], references: [id])
  fuelTypeName String // snapshot for reporting after type rename/delete

  gallons        Decimal @db.Decimal(10, 3) // 10.234 gallons
  pricePerGallon Decimal @db.Decimal(10, 3) // 3.999 / gallon
  amount         Decimal @db.Decimal(10, 2) // gallons × price (always positive)
  entryMode      String  @default("amount") // "amount" | "gallons" (which side cashier entered)

  taxAmount Decimal? @db.Decimal(10, 2)
  notes     String?

  posTransactionId String? // links to parent cart Transaction

  // Inventory tracking — set when the sale posts against a specific tank.
  // NULL for legacy fuel transactions created before the tank module shipped.
  tankId String?
  tank   FuelTank? @relation(fields: [tankId], references: [id])

  // FIFO consumption trace — array of `{ deliveryItemId, gallons, cost }`
  // entries indicating which cost layers this sale consumed. Used for
  // accurate COGS on P&L reports. NULL for pre-FIFO transactions.
  fifoLayers Json?

  // V1.5: which physical pump dispensed the fuel. NULL when
  // pumpTrackingEnabled=false or on legacy transactions. Enables
  // pump-level reporting + pump-aware refund flow.
  pumpId String?
  pump   FuelPump? @relation(fields: [pumpId], references: [id])

  // V1.5: refund linkage — when this is a refund tx, refundsOf points at
  // the original sale tx being partially/fully refunded. Powers the
  // "pick original sale, auto-compute refund amount" cashier flow.
  refundsOf String?

  createdAt DateTime @default(now())

  @@index([orgId, storeId, shiftId])
  @@index([orgId, storeId, createdAt])
  @@index([fuelTypeId])
  @@index([tankId])
  @@index([pumpId])
  @@index([refundsOf])
  @@map("fuel_transactions")
}

// ═══════════════════════════════════════════════════════════════
// STORV EXCHANGE  (B2B wholesale between independent stores)
//
// Design:
//   - Each Store has a globally unique human-readable storeCode.
//   - TradingPartner = handshake between two stores. Required before
//     POs can flow. Either side can initiate; the other must accept.
//   - WholesaleOrder = a sender-created list of products + qtys + cost.
//     States: draft → sent → (confirmed | partially_confirmed | rejected | cancelled | expired).
//     Inventory only moves on 'confirmed' or 'partially_confirmed'.
//     Ledger entries only created on confirmation.
//   - WholesaleOrderItem = line in the order with full snapshot of the
//     product (name/upc/pack/deposit/tax) at send-time, so history
//     survives MasterProduct deletion.
//   - WholesaleOrderEvent = immutable state-change log per order.
//   - PartnerBalance = materialized net balance per pair of stores.
//     Canonicalized (storeAId < storeBId alphabetically).
//     Positive balance = storeB owes storeA.
//   - LedgerEntry = immutable log of every balance-affecting event
//     (orders confirmed + settlements recorded).
//   - Settlement = a cash/cheque/transfer payment between two stores.
//     7-day dispute window before it locks.
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────
// TRADING PARTNER
// A handshake between two stores. Either can initiate. Once accepted,
// POs can flow in either direction freely.
// ─────────────────────────────────────────────────
model TradingPartner {
  id               String @id @default(cuid())
  // Store that sent the initial request
  requesterStoreId String
  requesterOrgId   String
  // Store being invited
  partnerStoreId   String
  partnerOrgId     String

  // pending | accepted | rejected | revoked
  status String @default("pending")

  // Optional note shown to the recipient on their pending-requests list
  requestNote   String?
  requestedById String
  respondedById String?
  respondedAt   DateTime?
  revokedAt     DateTime?
  revokedById   String?
  revokeReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requesterStore Store @relation("RequesterPartnerships", fields: [requesterStoreId], references: [id], onDelete: Cascade)
  partnerStore   Store @relation("PartnerPartnerships", fields: [partnerStoreId], references: [id], onDelete: Cascade)

  @@unique([requesterStoreId, partnerStoreId])
  @@index([partnerStoreId, status])
  @@index([requesterStoreId, status])
  @@index([partnerOrgId, status])
  @@index([requesterOrgId, status])
  @@map("trading_partners")
}

// ─────────────────────────────────────────────────
// WHOLESALE ORDER
// A B2B purchase order sent from one store to another. Treated as an
// independent wholesale sale between two merchants — NOT an intra-company
// inventory transfer. Each merchant is solely responsible for their own
// licensing / compliance (liquor, tobacco, etc).
// ─────────────────────────────────────────────────
model WholesaleOrder {
  id          String @id @default(cuid())
  orderNumber String @unique // "WO-YYYYMMDD-XXXXX"

  // Two-sided
  senderStoreId   String
  senderOrgId     String
  receiverStoreId String
  receiverOrgId   String

  // draft | sent | confirmed | partially_confirmed | rejected | cancelled | expired
  status String @default("draft")

  // Totals (snapshot at latest state; recomputed on any line change)
  subtotal            Decimal  @default(0) @db.Decimal(12, 4) // Σ qty × unitCost
  depositTotal        Decimal  @default(0) @db.Decimal(12, 4) // Σ qty × depositPerUnit
  taxTotal            Decimal  @default(0) @db.Decimal(12, 4) // Σ line taxAmount
  grandTotal          Decimal  @default(0) @db.Decimal(12, 4) // subtotal + depositTotal + taxTotal
  // Receiver-confirmed totals (after partial-accept adjustments)
  confirmedSubtotal   Decimal? @db.Decimal(12, 4)
  confirmedDeposit    Decimal? @db.Decimal(12, 4)
  confirmedTax        Decimal? @db.Decimal(12, 4)
  confirmedGrandTotal Decimal? @db.Decimal(12, 4)

  // Tax options
  taxEnabled Boolean @default(false)

  // Flagging
  isInternalTransfer Boolean @default(false) // true when sender and receiver share an org
  hasRestrictedItems Boolean @default(false) // true if any line has taxClass ∈ {alcohol, tobacco}

  // Notes
  senderNotes  String?
  cancelReason String?
  rejectReason String?

  // Lifecycle
  createdById   String
  sentAt        DateTime?
  sentById      String?
  expiresAt     DateTime? // default: sentAt + 15 days
  respondedAt   DateTime?
  respondedById String?
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  cancelledById String?
  editedAt      DateTime?
  editedById    String?

  // Archive state (Session 39) — both parties must agree the order is
  // fully reconciled / settled before archiving. Archived orders are
  // hidden from the main Exchange view but retained for history via the
  // "Show archived" toggle.
  senderArchived     Boolean   @default(false)
  senderArchivedAt   DateTime?
  receiverArchived   Boolean   @default(false)
  receiverArchivedAt DateTime?

  // Dispute tracking (Session 39) — multi-round back-and-forth between
  // parties when the receiver partially accepts. The messages themselves
  // live in `events` as `eventType='dispute_message'`. These fields track
  // the overall dispute state.
  disputeStatus     String? // null | "open" | "resolved"
  disputeOpenedAt   DateTime?
  disputeResolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderStore   Store @relation("WholesaleSender", fields: [senderStoreId], references: [id], onDelete: Restrict)
  receiverStore Store @relation("WholesaleReceiver", fields: [receiverStoreId], references: [id], onDelete: Restrict)

  items         WholesaleOrderItem[]
  events        WholesaleOrderEvent[]
  ledgerEntries LedgerEntry[]

  @@index([senderStoreId, status])
  @@index([receiverStoreId, status])
  @@index([senderOrgId, createdAt])
  @@index([receiverOrgId, createdAt])
  @@index([status, expiresAt]) // for auto-expiry scan
  @@map("wholesale_orders")
}

// ─────────────────────────────────────────────────
// WHOLESALE ORDER ITEM
// Product line with full snapshot at send-time.
// ─────────────────────────────────────────────────
model WholesaleOrderItem {
  id      String @id @default(cuid())
  orderId String

  // Product references (nullable — product may be deleted later)
  // Source: MasterProduct in sender's catalog
  senderProductId   Int?
  // Target: MasterProduct in receiver's catalog (resolved on confirmation)
  receiverProductId Int?

  // Snapshot at send-time (authoritative once PO is sent, survives product deletion).
  // Shape: { name, upc, brand, size, taxClass, departmentName, packUnits, packInCase,
  //          depositPerUnit, ebtEligible, ageRequired, imageUrl }
  productSnapshot Json

  // Quantities
  qtySent     Int
  qtyReceived Int? // null until receiver confirms; may be < qtySent

  // Pricing (sender's wholesale cost — what receiver pays)
  unitCost Decimal @db.Decimal(10, 4)
  lineCost Decimal @db.Decimal(12, 4) // qtySent × unitCost at send-time

  // Deposit pass-through (per unit)
  depositPerUnit Decimal? @db.Decimal(10, 4)
  lineDeposit    Decimal  @default(0) @db.Decimal(12, 4) // qtySent × depositPerUnit

  // Tax (per-line — only if order.taxEnabled)
  taxable   Boolean  @default(false)
  taxRate   Decimal? @db.Decimal(6, 4) // decimal rate, e.g. 0.055 = 5.5%
  taxAmount Decimal  @default(0) @db.Decimal(12, 4)

  // Line total including deposit + tax
  lineTotal Decimal @default(0) @db.Decimal(12, 4)

  // Dispute log (only populated when qtyReceived < qtySent or disputed)
  disputeNote String?

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("wholesale_order_items")
}

// ─────────────────────────────────────────────────
// WHOLESALE ORDER EVENT
// Immutable audit trail of state changes per order.
// ─────────────────────────────────────────────────
model WholesaleOrderEvent {
  id      String @id @default(cuid())
  orderId String

  // created | edited | sent | viewed | confirmed | partially_confirmed |
  // rejected | cancelled | expired | disputed | inventory_moved | ledger_posted
  eventType   String
  description String?
  actorId     String?
  actorName   String?
  // Event-specific data (e.g. { fromStatus, toStatus, deltaTotal })
  payload     Json?

  createdAt DateTime @default(now())

  order WholesaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("wholesale_order_events")
}

// ─────────────────────────────────────────────────
// PARTNER BALANCE
// Materialized net balance per pair of stores. Canonicalized so there's
// only one row per pair (storeAId < storeBId).
// Convention: balance > 0 means storeB owes storeA. balance < 0 means
// storeA owes storeB. Zero = settled.
// This is a read cache; LedgerEntry is the source of truth.
// ─────────────────────────────────────────────────
model PartnerBalance {
  id       String @id @default(cuid())
  storeAId String
  storeBId String

  balance Decimal @default(0) @db.Decimal(14, 4)

  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  storeA Store @relation("PartnerBalanceA", fields: [storeAId], references: [id], onDelete: Cascade)
  storeB Store @relation("PartnerBalanceB", fields: [storeBId], references: [id], onDelete: Cascade)

  @@unique([storeAId, storeBId])
  @@index([storeAId])
  @@index([storeBId])
  @@map("partner_balances")
}

// ─────────────────────────────────────────────────
// LEDGER ENTRY
// Immutable entry for every balance-changing event between two stores.
// Canonicalized to match PartnerBalance (storeAId < storeBId).
// direction indicates which side the amount flows toward.
// ─────────────────────────────────────────────────
model LedgerEntry {
  id       String @id @default(cuid())
  storeAId String
  storeBId String

  // "A_OWES_B" means balance decreases (A paying/shipping goods to B on credit? no —
  // when A receives goods, A owes the sender; so if A received from B, "A_OWES_B").
  // More simply, we express as a signed delta applied to PartnerBalance.balance:
  //   direction = "B_OWES_A"  →  balance += amount  (B owes A more)
  //   direction = "A_OWES_B"  →  balance -= amount  (A owes B more; balance can go negative)
  direction String

  amount       Decimal @db.Decimal(14, 4)
  balanceAfter Decimal @db.Decimal(14, 4) // snapshot for audit

  // wholesale_order | settlement | adjustment | internal_transfer
  entryType String

  wholesaleOrderId String?
  settlementId     String?
  description      String?

  createdById String
  createdAt   DateTime @default(now())

  wholesaleOrder WholesaleOrder? @relation(fields: [wholesaleOrderId], references: [id], onDelete: SetNull)
  settlement     Settlement?     @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@index([storeAId, storeBId, createdAt])
  @@index([wholesaleOrderId])
  @@index([settlementId])
  @@map("partner_ledger_entries")
}

// ─────────────────────────────────────────────────
// SETTLEMENT
// A recorded payment between two stores. One-sided recording with a
// 7-day silent-accept dispute window before it locks.
// ─────────────────────────────────────────────────
model Settlement {
  id       String @id @default(cuid())
  // Canonical pair (alphabetical)
  storeAId String
  storeBId String

  // Directional (actual payer → payee)
  payerStoreId String
  payeeStoreId String

  amount Decimal @db.Decimal(12, 4)

  // cash | check | bank_transfer | zelle | venmo | other
  method    String
  methodRef String? // check #, transaction ID, last 4 etc.
  note      String?

  // pending (within dispute window) | accepted | disputed
  status              String   @default("pending")
  disputeWindowEndsAt DateTime

  recordedById String
  recordedAt   DateTime @default(now())

  disputedAt    DateTime?
  disputedById  String?
  disputeReason String?
  resolvedAt    DateTime?
  resolvedById  String?

  ledgerEntries LedgerEntry[]

  @@index([storeAId, storeBId, recordedAt])
  @@index([status, disputeWindowEndsAt]) // for auto-accept scan
  @@map("partner_settlements")
}

// ─────────────────────────────────────────────────
// PRICE SCENARIO (superadmin-only price calculator)
// Saved Interchange-plus rate/earning scenarios that the sales team uses to
// pitch the StoreVeu processing model to prospective merchants. Not linked
// to an Organisation — these are marketing/sales collateral, stored only at
// the platform level and managed from the admin panel.
//
// `inputs` JSON shape (see admin-app/src/pages/AdminPriceCalculator.jsx):
//   {
//     storeName, location?, mcc?, notes?,
//     volume, txns, trueIc,
//     mcVol, viVol, discVol, amexVol,
//     mcCredit, mcDebit, viCredit, viDebit,
//     svPct, svTxn, svSaas,
//     currentProc, currentPosSaas
//   }
// `results` cache is updated on every save so the list view can render
// summary columns (effRate, savesMo, svTotal) without recomputing.
// ─────────────────────────────────────────────────
model PriceScenario {
  id          String   @id @default(cuid())
  storeName   String
  location    String?
  mcc         String?
  notes       String?
  inputs      Json
  results     Json
  createdById String?
  createdBy   User?    @relation("PriceScenarioCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([storeName])
  @@map("price_scenarios")
}

// ─────────────────────────────────────────────────
// QUICK BUTTON LAYOUT (per-store cashier home-screen customisation)
//
// Freeform drag-and-drop "iPhone home screen" style tile grid that the
// cashier sees on the POS. Shared across all cashiers at the store (the
// user's original request — per-store, not per-station). This is the
// canonical system for POS home-screen customisation; the legacy
// `store.pos.quickFolders` JSON is no longer read.
//
// `tree` JSON shape (flat array — folder children render in drill-in view):
//   [
//     { id, type: 'product', x, y, w, h, productId, name, price, upc?,
//       backgroundColor?, textColor?, imageUrl? },
//     { id, type: 'folder',  x, y, w, h, label, emoji?, color?,
//       children: [<buttons — max 1 level deep>] },
//     { id, type: 'action',  x, y, w, h, actionKey, label,
//       backgroundColor?, textColor?, imageUrl? },
//     { id, type: 'text',    x, y, w, h, label, fontSize?,
//       backgroundColor?, textColor? },
//     { id, type: 'image',   x, y, w, h, imageUrl, label?,
//       targetProductId?, targetActionKey? },
//   ]
//
// Folder depth: capped at 2 levels by the save handler (a folder's
// `children[]` may NOT contain another folder — backend enforces this
// and returns 400 when violated).
//
// Grid: `gridCols` defaults to 6; rows are effectively unlimited (the
// grid grows as tiles are placed). Cashier renderer reflows to whatever
// viewport width is available.
// ─────────────────────────────────────────────────
model QuickButtonLayout {
  id        String   @id @default(cuid())
  orgId     String
  storeId   String   @unique
  name      String   @default("Main Screen")
  gridCols  Int      @default(6) // columns in the layout grid
  rowHeight Int      @default(64) // pixel height per grid row (for h=1 tile)
  tree      Json     @default("[]") // flat array of tiles (see shape above)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId])
  @@map("quick_button_layouts")
}

// ─────────────────────────────────────────────────
// STATE (superadmin-managed US state catalog)
// Superadmin curates per-state defaults that stores inherit when their
// `Store.stateCode` is set (or changed). The backend's `applyStateDefaults`
// controller upserts TaxRule / DepositRule / LotterySettings / POS-config
// ageLimits from this record. Managed-at-platform-level: not org-scoped.
//
// JSON field shapes:
//   bottleDepositRules: [
//     { containerType: 'can'|'bottle', material: 'aluminum'|'plastic'|'glass',
//       minVolumeOz, maxVolumeOz, depositAmount }
//   ]
//   lotteryGameStubs: [{ name, ticketPrice, notes }]  (informational — actual
//     games are created via LotteryGame with state=<code>)
// ─────────────────────────────────────────────────
model State {
  code                     String   @id // 2-letter US state code, e.g. "MA"
  name                     String // "Massachusetts"
  country                  String   @default("US")
  defaultTaxRate           Decimal? @db.Decimal(6, 4) // e.g. 0.0625 = 6.25%
  // Legacy single-rate commission — kept for backward-compat. New stores
  // should use the 4-source rates below. If state-level rates are null, the
  // settlement engine falls back to LotterySettings.commissionRate per store.
  defaultLotteryCommission Decimal? @db.Decimal(6, 4) // 0.05 = 5%
  // Phase 3e — per-revenue-stream commission rates. Set by superadmin for
  // each state and applied to all stores in that state. Decimal like 0.054
  // means 5.4%. Null means "use defaultLotteryCommission fallback."
  instantSalesCommRate     Decimal? @db.Decimal(6, 4) // e.g. 0.054 = 5.4% on scratch sales
  instantCashingCommRate   Decimal? @db.Decimal(6, 4) // e.g. 0.01 = 1% on scratch payouts
  machineSalesCommRate     Decimal? @db.Decimal(6, 4) // e.g. 0.054 on draw-game sales
  machineCashingCommRate   Decimal? @db.Decimal(6, 4) // e.g. 0.01 on draw-game payouts
  alcoholAgeLimit          Int      @default(21)
  tobaccoAgeLimit          Int      @default(21)
  // Deposit rules as JSON (varies widely by state — 10 states have mandates)
  bottleDepositRules       Json?    @default("[]")
  // Lottery game catalog stubs (for reference; actual games created in LotteryGame)
  lotteryGameStubs         Json?    @default("[]")
  // Per-state pack-size heuristic for lottery scratch tickets.
  // State lottery APIs don't expose pack size (MA's /games endpoint omits
  // it entirely), so we default the ticketsPerBook from ticket price via
  // an ordered rule list: the first rule whose maxPrice >= ticketPrice
  // wins. Superadmin edits these per state to match that state's convention
  // (MA $5 → 100 or 150; Maine $5 → 60; etc.).
  // Shape: [{ maxPrice: number, packSize: number }, …] ordered by maxPrice asc.
  // A final catch-all rule with a very high maxPrice is recommended so
  // every price has a match. Null/empty → backend falls back to a hardcoded
  // US-standard default.
  lotteryPackSizeRules     Json?    @default("[]")

  // ── Session 50 — Dual Pricing / Cash Discount per-state policy ──
  //
  // surchargeTaxable        — does sales tax apply to the surcharge itself?
  //                           NY/FL/TX/PA/NJ/MD/VA/NC/SC/GA → true
  //                           CA/MA/CT/DE/NH/VT/RI/ME → false
  // maxSurchargePercent     — state cap (most US states: 4%). null = no cap.
  // dualPricingAllowed      — when false, the model is forced to "cash_discount"
  //                           framing (surcharge ILLEGAL but cash discount legal).
  //                           MA/CT/CO/OK fall here.
  // pricingFraming          — "surcharge" (most states; "+3% card surcharge")
  //                           "cash_discount" (MA/CT/CO/OK; "−3% cash discount")
  //                           Same math, different consumer-facing copy.
  // surchargeDisclosureText — default verbatim disclosure for receipts/signage
  //                           when stores in this state run dual pricing.
  //                           Stores can override via Store.dualPricingDisclosure.
  surchargeTaxable        Boolean  @default(false)
  maxSurchargePercent     Decimal? @db.Decimal(5, 3) // e.g. 4.000 = 4%
  dualPricingAllowed      Boolean  @default(true)
  pricingFraming          String   @default("surcharge") // "surcharge" | "cash_discount"
  surchargeDisclosureText String?  @db.Text

  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]

  @@map("states")
}

// ─────────────────────────────────────────────────
// AI ASSISTANT — Conversational support with live-data tool access.
//
// The AI calls server-side tool functions (never raw SQL). Every tool
// re-checks the caller's RBAC permissions, so the AI can only surface
// data the user themselves is authorised to see.
//
// KB + feedback-review tables land in a follow-up session.
// ─────────────────────────────────────────────────
model AiConversation {
  id            String   @id @default(cuid())
  orgId         String? // null for superadmin cross-tenant chats
  storeId       String? // active store at conversation start
  userId        String // who opened the conversation
  userRole      String? // denormalized: effective role at creation time
  userName      String? // denormalized for list views
  title         String? // auto-summary of first user message (<=80 chars)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages AiMessage[]

  @@index([userId, lastMessageAt])
  @@index([orgId, lastMessageAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String   @db.Text
  toolCalls      Json? // [{name, input, output, durationMs}]
  tokenCount     Int? // input+output tokens reported by Anthropic
  model          String? // e.g. "claude-sonnet-4-6"
  feedback       String? // "helpful" | "unhelpful" | null
  feedbackNote   String?  @db.Text
  ticketId       String? // linked SupportTicket.id if escalated
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([feedback])
  @@map("ai_messages")
}

// ─────────────────────────────────────────────────
// AI KNOWLEDGE BASE — curated how-to / troubleshoot articles
//
// Embeddings generated via OpenAI text-embedding-3-small (1536-dim).
// Stored as Float[] (native Postgres array); cosine similarity computed
// in JavaScript at query time. At <500 articles this is fast enough
// without needing pgvector. Swap to pgvector if/when the KB grows large.
// ─────────────────────────────────────────────────
model AiKnowledgeArticle {
  id             String   @id @default(cuid())
  orgId          String? // null = platform-wide article (default for seeded)
  category       String // "feature" | "how-to" | "troubleshoot" | "faq"
  title          String
  content        String   @db.Text
  embedding      Float[] // 1536-dim vector
  source         String   @default("curated") // "seed" | "curated" | "admin"
  tags           String[] @default([])
  helpfulCount   Int      @default(0)
  unhelpfulCount Int      @default(0)
  createdById    String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId, active])
  @@index([category])
  @@map("ai_knowledge_articles")
}

// ─────────────────────────────────────────────────
// AI PRODUCT TOURS — narrated step-by-step walkthroughs
//
// The AI recommends a tour when the user asks "walk me through X". The tour
// runner (global component in the portal Layout) drives a floating step card
// that walks the user page-by-page through the flow.
//
// Steps are structured — no brittle CSS selectors on UI elements. Each step
// has a title, body, and an optional `url` to navigate to. This works on any
// page without requiring the page to be "tour-aware".
// ─────────────────────────────────────────────────
model ProductTour {
  id          String   @id @default(cuid())
  orgId       String? // null = platform-wide (default for seeded)
  slug        String // "add-product", "set-age-verification"
  name        String // "Add Your First Product"
  description String?  @db.Text
  category    String   @default("onboarding") // "onboarding" | "feature" | "troubleshoot"
  triggers    String[] @default([]) // phrases the AI uses to match intent
  steps       Json     @default("[]") // [{ title, body, url?, highlight? }]
  active      Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, slug])
  @@index([active, category])
  @@map("product_tours")
}

// ─────────────────────────────────────────────────
// AI FEEDBACK REVIEW — 👎 queue for admins to curate into the KB
//
// Populated when a user marks an assistant response "unhelpful" AND
// leaves a free-text suggestion. An admin with `ai_assistant.manage`
// reviews each row in the admin panel and either (a) promotes it to a
// new KB article (capturing their corrected answer) or (b) dismisses.
// ─────────────────────────────────────────────────
model AiFeedbackReview {
  id             String    @id @default(cuid())
  orgId          String? // which org the conversation came from
  messageId      String    @unique // denormalized — so we can cascade-delete cleanly
  conversationId String? // for "View conversation" action
  question       String    @db.Text // denormalized user message
  aiResponse     String    @db.Text // denormalized assistant message
  userSuggestion String?   @db.Text // feedbackNote from the user
  status         String    @default("pending") // "pending" | "promoted" | "dismissed"
  reviewedById   String?
  reviewedAt     DateTime?
  articleId      String? // if promoted to KB
  ticketId       String? // if escalated to support ticket alongside review
  createdAt      DateTime  @default(now())

  @@index([status, createdAt])
  @@index([orgId, status])
  @@map("ai_feedback_reviews")
}

// ─────────────────────────────────────────────────
// DAILY SALE REPORT — Phase 3d unified reconciliation
//
// One row per (orgId, storeId, date). Stores only the manually-entered /
// adjustable fields — everything auto-derivable from POS transactions,
// lottery totals, shifts, and vendor payments is computed live in the
// service layer and merged into the response.
//
// Math (computed in service):
//   Total In  = cash collected + credit + debit + lottery sales
//             + otherIncome + moneyIn + houseAccts credits
//   Total Out = bankDeposit + lotteryDeposit + creditCardTotal + debitCardTotal
//             + purchaseCashPO + expenseCashPO + lottery payouts
//   Short/Over = Total In − Total Out   (positive = over, negative = short)
// ─────────────────────────────────────────────────
model DailySaleReport {
  id      String   @id @default(cuid())
  orgId   String
  storeId String
  date    DateTime @db.Date

  // Per-department adjustments on top of POS-auto totals.
  // Shape: [{ key, name, adjustment, note }]  — "key" is the dept id or slug;
  //   auto POS amount is fetched live, never stored here.
  deptAdjustments Json @default("[]")

  // Lottery terminal readings (manually entered)
  totalizerBegin Decimal? @db.Decimal(12, 2)
  totalizerEnd   Decimal? @db.Decimal(12, 2)
  voids          Decimal? @default(0) @db.Decimal(12, 2)
  customerCount  Int?
  reportNumbers  String?

  // Tax override (blank = use live-computed from transactions)
  salesTaxOverride Decimal? @db.Decimal(12, 2)

  // Other inflows not captured by POS/lottery
  otherIncome Decimal @default(0) @db.Decimal(12, 2)
  moneyIn     Decimal @default(0) @db.Decimal(12, 2)

  // Cash counted at close (pre-fills from Shift.closingAmount; manager-editable)
  cashCounted    Decimal? @db.Decimal(12, 2)
  cashAdjustment Decimal  @default(0) @db.Decimal(12, 2)

  // Store Money — deposits planned / made today
  bankDeposit     Decimal @default(0) @db.Decimal(12, 2)
  lotteryDeposit  Decimal @default(0) @db.Decimal(12, 2)
  creditCardTotal Decimal @default(0) @db.Decimal(12, 2)
  debitCardTotal  Decimal @default(0) @db.Decimal(12, 2)

  // Cash paidout categorization (auto-filled from VendorPayment.paymentType;
  // manager can override totals)
  purchaseCashPO Decimal @default(0) @db.Decimal(12, 2)
  expenseCashPO  Decimal @default(0) @db.Decimal(12, 2)

  // House accounts — simple running list
  // Shape: [{ customerId, customerName, amount, note }]
  houseAccounts Json @default("[]")

  // Freeform notes
  notes String?

  // Lifecycle
  status     String    @default("draft") // 'draft' | 'closed'
  closedAt   DateTime?
  closedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, storeId, date])
  @@index([orgId, storeId, date])
  @@map("daily_sale_reports")
}

// ═══════════════════════════════════════════════════════════════
// SCAN DATA / TOBACCO COMPLIANCE  (Session 45 — foundation)
//
// Daily-batch reporting of tobacco transactions to manufacturer
// "scan data" programs (Altria, RJR/RAI, ITG Brands) in exchange
// for funded promos + buydowns + coupon reimbursement.
//
// Architecture overview:
//   TobaccoManufacturer   — platform catalog. One row per "feed"
//                           because each has its own SFTP target +
//                           file format (e.g. altria_pmusa cigarettes
//                           is a separate feed from altria_usstc smokeless).
//   ScanDataEnrollment    — per-store per-feed enrollment + encrypted
//                           SFTP credentials.
//   TobaccoProductMap     — links a MasterProduct to a manufacturer
//                           feed + brand family. Drives which products
//                           get exported on each feed.
//   ManufacturerCoupon    — coupon catalog (manual entry primary,
//                           CSV import secondary). Replaces paper
//                           mail-in monthly bundles.
//   CouponRedemption      — POS redemption records → flow into the
//                           daily scan data submission for credit.
//   ScanDataSubmission    — daily file submission log per store × feed.
//
// File formatters + SFTP service ship in Session 47.
// Coupon engine + POS modal + line-item discount split ship in Session 46.
// ═══════════════════════════════════════════════════════════════

model TobaccoManufacturer {
  id String @id @default(cuid())

  // Stable code — used in seeds, formatters, UI lookups.
  // Format: "{parentMfr}_{feed}" for sub-feeds, or "{parentMfr}" for
  // single-feed mfrs.
  // Examples: altria_pmusa, altria_usstc, altria_middleton,
  //           rjr_edlp, rjr_scandata, rjr_vap, itg
  code          String @unique
  parentMfrCode String // "altria" | "rjr" | "itg" — UI grouping
  name          String // "Altria PMUSA (Cigarettes)"
  shortName     String // "PMUSA"

  // File format spec
  fileFormat    String // "pipe_delimited" | "fixed_width" | "csv"
  fileExtension String @default("txt")

  // Supported brand families for product mapping UI.
  // Examples for altria_pmusa: ["Marlboro", "L&M", "Parliament", "Virginia Slims", "Basic", "Chesterfield"]
  brandFamilies String[]

  // Submission cadence
  cadence        String @default("daily") // "daily" | "weekly"
  submissionHour Int    @default(2) // 24h store-local

  // Cert / production hosts (per-feed defaults — enrollment can override)
  uatHost  String?
  prodHost String?
  uatPort  Int?    @default(22)
  prodPort Int?    @default(22)

  // Documentation
  specVersion String?
  specUrl     String?
  notes       String? @db.Text

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments ScanDataEnrollment[]
  productMaps TobaccoProductMap[]
  coupons     ManufacturerCoupon[]
  submissions ScanDataSubmission[]

  @@index([parentMfrCode, active])
  @@map("tobacco_manufacturers")
}

model ScanDataEnrollment {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  manufacturerId String
  manufacturer   TobaccoManufacturer @relation(fields: [manufacturerId], references: [id])

  // Manufacturer-assigned retailer ID (NOT our store ID).
  // Examples: Altria assigns a 7-digit retailer code; ITG uses
  // chain + outlet IDs.
  mfrRetailerId String?
  mfrChainId    String?

  // SFTP credentials — sftpPasswordEnc stored encrypted with
  // AES-256-GCM via cryptoService. Plaintext NEVER persists.
  sftpHost        String?
  sftpPort        Int     @default(22)
  sftpUsername    String?
  sftpPasswordEnc String? @db.Text
  sftpPath        String? @default("/upload/")

  // Environment toggle — until cert passes, point at UAT host
  environment String @default("uat") // "uat" | "production"

  // Lifecycle status:
  //   "draft"      — saved but submissions disabled
  //   "certifying" — submitting test files for cert review
  //   "active"     — production submissions running nightly
  //   "suspended"  — admin paused submissions
  //   "rejected"   — mfr rejected the enrollment outright
  status String @default("draft")

  enrolledAt       DateTime?
  certifiedAt      DateTime?
  suspendedAt      DateTime?
  lastSubmissionAt DateTime?
  lastAckAt        DateTime?

  // Most recent submission status (denormalized for fast UI)
  lastStatus   String? // "ok" | "warning" | "rejected"
  lastErrorMsg String? @db.Text

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, manufacturerId])
  @@index([orgId, storeId])
  @@index([orgId, status])
  @@map("scan_data_enrollments")
}

model TobaccoProductMap {
  id    String @id @default(cuid())
  orgId String

  masterProductId Int
  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  manufacturerId String
  manufacturer   TobaccoManufacturer @relation(fields: [manufacturerId], references: [id])

  brandFamily    String // "Marlboro" | "Camel" | "Winston" | etc.
  // Manufacturer-assigned product code (some require this in submission)
  mfrProductCode String?

  // Funding type — drives which discount fields can be claimed:
  //   "buydown"    — ongoing shelf-price funding from mfr
  //   "multipack"  — funded multipack discount ("buy 2 get $1 off")
  //   "promotion"  — time-limited promo
  //   "regular"    — no funded discount, submission-only
  fundingType String @default("regular")

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([masterProductId, manufacturerId])
  @@index([orgId, manufacturerId])
  @@index([orgId, brandFamily])
  @@map("tobacco_product_maps")
}

model ManufacturerCoupon {
  id    String  @id @default(cuid())
  // null = platform-wide (rare); non-null = org-specific
  orgId String?

  manufacturerId String
  manufacturer   TobaccoManufacturer @relation(fields: [manufacturerId], references: [id])

  // Unique serial number / barcode from the printed coupon
  serialNumber String  @unique
  displayName  String?
  brandFamily  String

  // Discount mechanics
  discountType   String // "fixed" | "percent"
  discountAmount Decimal @db.Decimal(10, 4)

  // Validity window
  effectiveDate  DateTime?
  expirationDate DateTime

  // Qualifying products — explicit UPCs win over brandFamily fallback
  qualifyingUpcs    String[] @default([])
  minQty            Int      @default(1)
  requiresMultipack Boolean  @default(false)

  // Usage limits
  maxPerTx     Int? // null = unlimited per transaction
  maxPerCoupon Int  @default(1) // most coupons are single-use

  // Funding source — drives reimbursement path
  fundedBy String @default("manufacturer") // "manufacturer" | "retailer"

  active Boolean @default(true)

  // Audit
  createdById  String?
  importedFrom String? // "manual" | "csv" | "api"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions CouponRedemption[]

  @@index([orgId, manufacturerId, active])
  @@index([brandFamily])
  @@index([expirationDate])
  @@map("manufacturer_coupons")
}

model CouponRedemption {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  // Original transaction this was redeemed against
  transactionId String
  // null = manual entry that didn't match a known coupon (still tracked)
  couponId      String?
  coupon        ManufacturerCoupon? @relation(fields: [couponId], references: [id])

  // Denormalized so we keep the audit trail even if coupon row is deleted
  couponSerial   String
  brandFamily    String?
  manufacturerId String?

  // What was applied
  discountApplied Decimal @db.Decimal(10, 4)
  qualifyingUpc   String?
  qualifyingQty   Int?

  cashierId           String?
  managerApprovedById String? // if threshold required manager PIN

  // Submission lifecycle
  submittedAt     DateTime?
  submissionId    String?
  reimbursedAt    DateTime?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text

  createdAt DateTime @default(now())

  @@index([orgId, storeId, createdAt])
  @@index([transactionId])
  @@index([couponSerial])
  @@index([submittedAt])
  @@map("coupon_redemptions")
}

model ScanDataSubmission {
  id      String @id @default(cuid())
  orgId   String
  storeId String

  manufacturerId String
  manufacturer   TobaccoManufacturer @relation(fields: [manufacturerId], references: [id])

  // What range this submission covers
  submissionDate DateTime // the date the submission ran
  periodStart    DateTime // covers transactions from this date
  periodEnd      DateTime // ... to this date (inclusive)

  // Generated artefact
  fileName        String
  fileSize        Int?
  // Local path or S3 key — file kept for replay/audit
  fileStoragePath String?

  // Counts
  txCount     Int      @default(0)
  couponCount Int      @default(0)
  totalAmount Decimal? @db.Decimal(12, 2)

  // Lifecycle status:
  //   "queued"       — generated, waiting for SFTP upload
  //   "uploading"    — SFTP transfer in progress
  //   "uploaded"     — SFTP delivered, awaiting ack
  //   "acknowledged" — mfr returned a positive ack
  //   "rejected"     — mfr returned a rejection ack (see errorMessage)
  //   "failed"       — SFTP transfer failed after retries
  status String @default("queued")

  uploadedAt DateTime?
  ackedAt    DateTime?

  // Ack details (when received)
  ackFileName  String?
  ackContent   String? @db.Text
  errorMessage String? @db.Text

  // Per-line ack breakdown (Session 48). Shape:
  //   [{ recordRef: "TXN-...|UPC", status: 'accepted'|'rejected',
  //      reason?: string, code?: string, originalLine?: string }]
  // Stored as JSON because ack files are typically <10KB. If we ever
  // need per-line indexing/querying, promote to its own AckLine model.
  ackLines      Json?
  acceptedCount Int   @default(0)
  rejectedCount Int   @default(0)

  // Retry tracking
  attempts    Int       @default(0)
  nextRetryAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, storeId, submissionDate])
  @@index([manufacturerId, status])
  @@map("scan_data_submissions")
}

// ─────────────────────────────────────────────────
// NOTIFICATIONS
// Cross-portal notification system. One Notification row per "broadcast"
// (an event the system or a superadmin wants to surface). NotificationDelivery
// fans out to individual users + tracks per-user read state.
//
// Targeting:
//   • Org-wide          → audience='org',   targetOrgId set, targetStoreId/UserId null
//   • Store-wide        → audience='store', targetOrgId+StoreId set
//   • Single user       → audience='user',  targetUserId set
//   • Platform-wide     → audience='platform' (superadmin → every active user)
//
// Source of the row drives the icon + grouping in the UI:
//   'system' (auto-emitted), 'admin' (manual broadcast), 'order' (ecom),
//   'task' (task assignment / reminder), 'support' (ticket events).
// ─────────────────────────────────────────────────
model Notification {
  id          String   @id @default(cuid())

  // Author / source
  source      String   @default("system") // system | admin | order | task | support
  createdById String?  // User.id who triggered the broadcast (null for system events)

  // Content
  title       String
  message     String   @db.Text
  linkUrl     String?  // optional click-through (e.g. /portal/online-orders)
  iconKey     String?  // optional UI hint: 'order', 'task', 'system', 'alert', etc.
  priority    String   @default("normal") // low | normal | high | urgent
  type        String   @default("info")   // info | success | warning | error

  // Targeting — only one of these dimensions is enforced; deliveries fan out.
  audience      String   @default("user")  // platform | org | store | user
  targetOrgId   String?
  targetStoreId String?
  targetUserId  String?

  // Idempotency — populated by emitters that risk duplicates (e.g. order webhooks
  // firing twice). When set, repeat emits with the same key drop silently.
  dedupeKey   String?  @unique

  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  deliveries  NotificationDelivery[]

  @@index([source, createdAt])
  @@index([targetOrgId, createdAt])
  @@index([targetStoreId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id             String       @id @default(cuid())
  notificationId String
  userId         String

  readAt         DateTime?    // null = unread
  dismissedAt    DateTime?    // user explicitly dismissed (X button)
  deliveredAt    DateTime     @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_deliveries")
}

// ─────────────────────────────────────────────────
// PROMO SUGGESTIONS — S74 (F28)
// AI- or stub-generated promo recommendations awaiting manager review.
// Approve flow CREATES a Promotion record from the suggestion.
// Rejected suggestions stay around for audit + AI training feedback.
// ─────────────────────────────────────────────────
model PromoSuggestion {
  id     Int    @id @default(autoincrement())
  orgId  String
  storeId String?

  // Lifecycle: pending → approved | rejected | dismissed
  status String @default("pending")

  // Promo proposal — same shape as Promotion but not yet active
  promoType         String  // sale | bogo | volume | mix_match | combo
  title             String  // human-readable summary, e.g. "Slow-mover: 12oz Dairy → 15% off Sat–Sun"
  proposedScope     Json    // { productIds, departmentIds, productGroupIds }
  proposedConfig    Json    // dealConfig shape
  proposedStartDate DateTime?
  proposedEndDate   DateTime?

  // AI metadata
  rationale   Json    // { source: 'dead_stock' | 'expiring' | ..., citations, reasoning }
  estImpact   Json?   // { expectedSales, marginImpact, unitsCleared }
  generatedBy String  @default("stub") // stub | claude | manual

  // Review
  reviewedById String?
  reviewedAt   DateTime?
  rejectReason String?

  // When approved, points to the resulting Promotion row
  createdPromoId Int?

  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  reviewer     User?        @relation("PromoSuggestionReviewer", fields: [reviewedById], references: [id])

  @@index([orgId, status, generatedAt])
  @@index([orgId, storeId, status])
  @@map("promo_suggestions")
}

// ─────────────────────────────────────────────────
// SEEDER EXECUTION TRACKING — S81
// Records every run of the production seeder system. Catalog seeders write
// a row on every successful re-run (idempotent — newest row reflects latest
// state). One-shot seeders use the unique (seederName, version) constraint
// as the gate: a successful row blocks re-runs at that version, and bumping
// the version forces a new run.
//
// To force a one-shot to re-run on production, either:
//   1. Bump the version in src/services/seeder/registry.ts (preferred —
//      survives a database reset and is captured in git history), OR
//   2. Delete the row directly: DELETE FROM seeder_executions
//      WHERE "seederName" = 'foo' AND version = 1;
// ─────────────────────────────────────────────────
model SeederExecution {
  id         String   @id @default(cuid())
  seederName String   // matches SeederTask.name in registry
  version    Int      // bump in registry to force a re-run
  category   String   // 'catalog' | 'one_shot' — copied from registry for visibility
  runAt      DateTime @default(now())
  durationMs Int?
  success    Boolean  @default(true)
  summary    Json?    // optional task-specific stats (rows created/updated/skipped)
  errorMsg   String?  @db.Text

  @@unique([seederName, version])
  @@index([seederName])
  @@index([runAt])
  @@map("seeder_executions")
}
