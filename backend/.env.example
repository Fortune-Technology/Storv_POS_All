# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use '*' for open access (not recommended for production).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── PostgreSQL (Native POS Catalog) ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/futurefoods_portal"

# ─── External API Integrations ──────────────────────────────────────────────
# OpenAI API (GPT-4o-mini for text enrichment)
OPENAI_API_KEY=

# Azure Document Intelligence (OCR)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ─── POS Connectivity (Managed in-app via Store Settings) ───────────────────
#
# POS credentials are stored in the PostgreSQL 'Store' table (JSONB column 'pos').
# No need to define them here in prod.
#
# Dev/Test Guard: set true to block PUT/POST mutations to POS during local testing
POS_WRITE_DISABLED=false
# ─────────────────────────────────────────────────────────────────────────────
# ─── POS Connectivity & Testing ─────────────────────────────────────────────
# Set to 'true' to block any write operations (PUT/POST) to POS during local testing.
POS_WRITE_DISABLED=false
