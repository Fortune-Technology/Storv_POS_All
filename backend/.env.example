# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must include portal, cashier-app,
# and admin-app origins. Use '*' for open access (NOT recommended for production).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5005

# ─── PostgreSQL (Prisma) ────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_pos"

# ─── Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ─── External API Integrations ──────────────────────────────────────────────
# OpenAI API (GPT-4o-mini for invoice text enrichment)
OPENAI_API_KEY=sk-proj-...

# Azure Document Intelligence (primary invoice OCR)
# Get from: Azure Portal → Document Intelligence resource → Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Frontend URLs (used in emails for links) ──────────────────────────────
# Portal URL — used in password reset emails, user approval/rejection emails
FRONTEND_URL=http://localhost:5173
# Admin panel URL — used in admin notification emails
ADMIN_URL=http://localhost:5175

# ─── Email / SMTP ──────────────────────────────────────────────────────────
# Used for: password reset, signup notifications, user approve/reject/suspend,
# contact form confirmations, support ticket notifications.
# If not configured, emails are skipped but features still work (DB records saved).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ─── POS Connectivity (Managed in-app via Store Settings) ───────────────────
# POS credentials are stored in PostgreSQL 'Store' table (JSONB column 'pos').
# No need to define them here in prod.
# Dev/Test Guard: set true to block PUT/POST mutations to POS during local testing
POS_WRITE_DISABLED=false

# ─── MarktPOS / IT Retail Integration (Optional) ───────────────────────────
# MARKTPOS_BASE_URL=https://app.marktpos.com
# MARKTPOS_USERNAME=
# MARKTPOS_PASSWORD=
# ITRETAIL_STORE_ID=
# MARKTPOS_ACCESS_LEVEL=0
# MARKTPOS_SECURITY_CODE=
# MARKTPOS_SYNC_INTERVAL_HOURS=24
