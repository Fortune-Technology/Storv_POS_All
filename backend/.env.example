# ─── Core ────────────────────────────────────────────────────────────────────
# Server port + environment (development | production)
PORT=5000
NODE_ENV=development

# Postgres connection string (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/storeveu_pos
# Ecom DB used for cross-DB price/stock lookup from POS (optional)
ECOM_DATABASE_URL=postgresql://user:password@localhost:5432/storeveu_ecom

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000,http://localhost:5005

# Public URLs (used in emails, redirects, links across apps)
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175
BACKEND_URL=http://localhost:5000
ECOM_BACKEND_URL=http://localhost:5005

# ─── Auth ────────────────────────────────────────────────────────────────────
# JWT signing secret — must match ecom-backend JWT_SECRET
JWT_SECRET=your_jwt_secret_key_here
# Access token TTL — short = more secure, long = less re-login
JWT_ACCESS_TTL=8h
# Encryption key for vendor-credential storage at rest (AES-256-GCM)
APP_SECRET=your_app_secret_key_here
# Shared key for ecom-backend → POS internal calls (must match ECOM_BACKEND)
INTERNAL_API_KEY=change_me_to_a_long_random_string

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SUPPORT_EMAIL=

# ─── AI Assistant ────────────────────────────────────────────────────────────
# Anthropic key for AI Assistant chat — without it, /api/ai-assistant returns 503
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-4-5)
ANTHROPIC_MODEL=
# OpenAI key for OCR + KB embeddings
OPENAI_API_KEY=

# ─── Azure Document Intelligence (Invoice OCR) ───────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Twilio SMS (optional, for invitation/transfer SMS) ──────────────────────
# Run `npm i twilio` and fill these to enable SMS — no-op stub when blank
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Dejavoo Payment Gateway ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting merchant credentials at rest
DEJAVOO_VAULT_KEY=change_me_to_a_long_random_string
VAULT_PROVIDER=local
# Endpoints
DEJAVOO_HPP_BASE_UAT=https://uat.payment.dejavoo.io
DEJAVOO_HPP_BASE_PROD=https://payment.dejavoo.io
DEJAVOO_HPP_QUERY_BASE_UAT=https://uat-cube.dejavoo.io
DEJAVOO_HPP_QUERY_BASE_PROD=https://cube.dejavoo.io
DEJAVOO_SPIN_BASE_UAT=https://uat-spinpos.dejavoo.io
DEJAVOO_SPIN_BASE_PROD=https://spinpos.dejavoo.io
# Dev-only fallback register ID (real creds managed in admin panel)
DEJAVOO_TEST_REGISTER_ID=
# Default revenue share — can be overridden per merchant in admin
DEJAVOO_DEFAULT_PCT=2.9
DEJAVOO_DEFAULT_FEE=0.30
# Storeveu's own org ID + revshare percent (for marketplace billing)
STOREVEU_ORG_ID=
STORV_ORG_ID=
STOREVEU_REVSHARE_PCT=15

# ─── Scan Data SFTP (Tobacco compliance) ─────────────────────────────────────
SCAN_DATA_ACK_REMOTE_PATH=/ack
SCAN_DATA_ACK_PROCESSED_PATH=/ack/processed
SCAN_DATA_ACK_POLL_INTERVAL_MS=1800000

# ─── Production Seeder ───────────────────────────────────────────────────────
# When "true", runs the seeder system on every backend boot
# (catalog seeders idempotent; one-shots gated by seeder_executions table)
RUN_PRODUCTION_SEEDER=false

# ─── Misc ────────────────────────────────────────────────────────────────────
# Multer file-upload cap (bytes) — default 100 MB
MAX_FILE_SIZE=104857600
UPLOAD_DIR=uploads
# Path to pg_dump binary for admin DB backup (leave blank to auto-detect)
PG_DUMP_PATH=

# Disable rate limiting in dev (never set in production)
DISABLE_RATE_LIMIT=false

# Synthetic transaction generator (test environments only)
ENABLE_SYNTHETIC_DATA=false
SYNTHETIC_DATA_HOUR_UTC=4
SYNTHETIC_PROD_STORE_NAME=
SYNTHETIC_PROD_STORE_ADDRESS=
SYNTHETIC_TX_LOW=20
SYNTHETIC_TX_HIGH=60
SYNTHETIC_TARGET_LOW=
SYNTHETIC_TARGET_HIGH=
