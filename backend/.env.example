# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5005
# Production: CORS_ORIGIN=https://storeveu.com,https://pos.storeveu.com,https://admin.storeveu.com,https://shop-api.storeveu.com

# ─── PostgreSQL (Prisma) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_pos"
# E-commerce DB — used by admin backup feature (optional)
ECOM_DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_ecom"

# ─── Authentication ─────────────────────────────────────────────────────────
# Must match ecom-backend JWT_SECRET for shared auth
JWT_SECRET=your_jwt_secret_key_here
# Access token TTL (default 8h — one workday). Shorter = more secure, longer = less re-login.
JWT_ACCESS_TTL=8h
# Encryption key for CardPointe credential storage
APP_SECRET=your_app_secret_key_here

# ─── E-commerce Sync ────────────────────────────────────────────────────────
# HTTP fallback sync when Redis unavailable (used by packages/queue/producers.js)
ECOM_BACKEND_URL=http://localhost:5005
# Production: ECOM_BACKEND_URL=https://shop-api.storeveu.com

# ─── Redis (Optional — enables BullMQ async sync) ──────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── OpenAI (GPT-4o-mini text enrichment after OCR) ────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Anthropic Claude (AI Support Assistant — /api/ai-assistant/*) ─────────
# Without this key, POST /conversations/:id/messages returns 503. Get a key
# from https://console.anthropic.com/. Optional override: ANTHROPIC_MODEL
# (default: claude-sonnet-4-5).
ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Azure Document Intelligence (invoice OCR) ─────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_key_here

# ─── Frontend URLs (used in email links) ────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175
# Production: FRONTEND_URL=https://storeveu.com
# Production: ADMIN_URL=https://admin.storeveu.com

# ─── Email / SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ─── SMS (Twilio) ───────────────────────────────────────────────────────────
# Leave blank to disable SMS — invitations will fall back to email-only.
# When filled in, run: npm i twilio   and SMS activates automatically.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Billing ────────────────────────────────────────────────────────────────
# Org ID of the Storeveu platform itself (for billing features).
# Renamed from STORV_ORG_ID — billingService.js falls back to the legacy name
# until production .env files are updated, but new deploys should use this.
STOREVEU_ORG_ID=your_storeveu_org_id

# ─── Internal API Key (ecom-backend -> POS service-to-service calls) ───────
# REQUIRED — ecom-stock-check refuses requests without this header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the INTERNAL_API_KEY in ecom-backend/.env
INTERNAL_API_KEY=your_internal_api_key

# ─── Backend URL (used for image re-hosting, backup downloads) ─────────────
# Must be the publicly accessible URL of this backend server.
# In dev: http://localhost:5000 — In prod: https://api.storeveu.com
BACKEND_URL=http://localhost:5000

# ─── POS Connectivity ──────────────────────────────────────────────────────
# Set true to block write mutations during local testing
POS_WRITE_DISABLED=false

# ─── Rate Limiter ──────────────────────────────────────────────────────────
# Set to 'true' to disable the in-memory rate limiter (auto-disabled in dev).
DISABLE_RATE_LIMIT=false

# ─── Backup (pg_dump) ──────────────────────────────────────────────────────
# Override pg_dump binary path if auto-discovery fails (Windows only).
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\16\bin\pg_dump.exe

# ─── API Base URL (legacy fallback for BACKEND_URL) ────────────────────────
# Only used when BACKEND_URL is unset. Prefer BACKEND_URL above.
# API_BASE_URL=http://localhost:5000


# ─── Credential vault ────────────────────────────────────────────────────────
# AES-256-GCM master key used by backend/src/utils/cryptoVault.js to encrypt
# every payment-merchant credential at rest (SPIn auth keys, HPP auth keys,
# HPP webhook secrets, Transact API keys). 32-byte random hex.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: losing this key makes existing encrypted credentials unrecoverable.
# Back it up the same way you back up the DB.
DEJAVOO_VAULT_KEY=

# Vault provider. Default 'env' = AES-256-GCM with the key above.
# Set to 'kms' once you wire up AWS KMS / GCP Secret Manager (see cryptoVault.js
# header for the envelope-encryption upgrade path).
# VAULT_PROVIDER=env

# ─── Dejavoo SPIn (in-person card-present) ──────────────────────────────────
# Sandbox base URL (UAT). Per-merchant override available in admin panel.
DEJAVOO_SPIN_BASE_UAT=https://test.spinpos.net/spin
# DEJAVOO_SPIN_BASE_PROD=https://api.spinpos.net   (uncomment when going live)

# ─── Dejavoo HPP (online checkout / storefront) ─────────────────────────────
# iPOSpays HPP API base URLs — verified against:
#   https://docs.ipospays.com/hosted-payment-page/apidocs
#
# These defaults are baked into the service code, so leave commented unless you
# need to override (e.g. iPOSpays gives you a custom regional host). The
# create-session endpoint is `/api/v1/external-payment-transaction/getHostedPaymentPage`.
# DEJAVOO_HPP_BASE_UAT=https://payment.ipospays.tech
# DEJAVOO_HPP_BASE_PROD=https://payment.ipospays.com
#
# Query Status API (separate host).
# DEJAVOO_HPP_QUERY_BASE_UAT=https://api.ipospays.tech
# DEJAVOO_HPP_QUERY_BASE_PROD=https://api.ipospays.com

# ─── Test credentials (UAT — Fortune Technology) ────────────────────────────
# These are the SPIn UAT credentials seeded for development. In production,
# every store enters its own credentials via the admin panel — these env
# vars are only fallbacks for dev/test scripts.
DEJAVOO_TEST_TPN=220926475717
DEJAVOO_TEST_AUTH_KEY=e78wAaxNyT
DEJAVOO_TEST_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0cG4iOiIyMjA5MjY0NzU3MTciLCJlbWFpbCI6Im5pc2hhbnRAdGhlZm9ydHVuZXRlY2guY29tIiwibWVyY2hhbnRJZCI6ImUxM2FjNDNjLTQzMmItNDM1OS1iM2Q4LTc3ZmFhMzc0ZjQ1YSIsInZlcnNpb24iOiJ2MiIsImlhdCI6MTc3NjIzMTc4M30.s815o3pltzDZJYMVUwaNpT59QMPo-saHJ95kcTsifvw
DEJAVOO_TEST_REGISTER_ID=837601

# ─── Synthetic Test Data Generator ──────────────────────────────────────────
# Disabled by default. When enabled, the backend runs a daily cron at the
# configured UTC hour that creates a realistic spread of transactions per org
# so analytics + reporting surfaces have meaningful numbers in test envs.
#
# DO NOT enable in production with real merchant data — the synthetic
# transactions are indistinguishable from real ones except by `txNumber`
# prefix `SYN-YYYY-MM-DD-`.
ENABLE_SYNTHETIC_DATA=false
# Hour-of-day (UTC) after which the daily generation fires. Defaults to 6.
# SYNTHETIC_DATA_HOUR_UTC=6
# Daily total (USD) bounds per org. Each org gets a uniform-random pick.
# SYNTHETIC_TARGET_LOW=4000
# SYNTHETIC_TARGET_HIGH=6000
# Number-of-transactions bounds per org per day (40-80 = realistic small store).
# SYNTHETIC_TX_LOW=40
# SYNTHETIC_TX_HIGH=80