# ─── Server Configuration ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# ─── CORS Configuration ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development:
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5005
# Production:
# CORS_ORIGIN=https://storeveu.com,https://pos.storeveu.com,https://admin.storeveu.com,https://shop-api.storeveu.com

# ─── PostgreSQL (Prisma) ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_pos"

# ─── Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Must be the same value in ecom-backend/.env for JWT sharing
JWT_SECRET=your_jwt_secret_key_here

# ─── E-commerce Sync (Optional) ────────────────────────────────────────────
# URL of the ecom-backend for HTTP fallback sync (when Redis is not available).
# Development:
ECOM_BACKEND_URL=http://localhost:5005
# Production:
# ECOM_BACKEND_URL=https://shop-api.storeveu.com

# ─── Redis (Optional) ──────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── External API Integrations ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Frontend URLs (used in emails for links) ──────────────────────────────
# Development:
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5175
# Production:
# FRONTEND_URL=https://storeveu.com
# ADMIN_URL=https://admin.storeveu.com


STORV_ORG_ID=<your-storv-org-id>


# ─── Email / SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ─── POS Connectivity ──────────────────────────────────────────────────────
POS_WRITE_DISABLED=false

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION URLS (copy-paste for deployment)
# ═══════════════════════════════════════════════════════════════════════════
#
# Backend API:        https://api.storeveu.com
# Dashboard/Portal:   https://storeveu.com
# POS Terminal:       https://pos.storeveu.com
# Admin Panel:        https://admin.storeveu.com
# E-com Backend:      https://shop-api.storeveu.com
# Storefront:         https://shop.storeveu.com
#
# ═══════════════════════════════════════════════════════════════════════════
