# ─── Admin Panel Environment Configuration ──────────────────────────────────
# Must point to your backend API's /api endpoint.

# Development (default — Vite proxy forwards /api to localhost:5000)
VITE_API_URL=http://localhost:5000/api

# Portal URL — used for "Login As" (impersonate user) feature.
# Opens a new tab at this URL with the impersonation token.
# Development:
VITE_PORTAL_URL=http://localhost:5173
# Production example:
# VITE_PORTAL_URL=https://storeveu.com
