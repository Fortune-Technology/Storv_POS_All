# ─── POS Backend API ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
# Production: VITE_API_URL=https://api.storeveu.com/api

# ─── E-commerce Backend (image previews in portal) ─────────────────────────
VITE_ECOM_URL=http://localhost:5005
# Production: VITE_ECOM_URL=https://shop-api.storeveu.com

# ─── Storefront URL (for "Live at" links in E-commerce Setup) ──────────────
VITE_STOREFRONT_URL=http://localhost:3000
# Production: VITE_STOREFRONT_URL=https://shop.storeveu.com

