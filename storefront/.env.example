# Ecom API base URL — server-side (getServerSideProps / getStaticProps)
ECOM_API_URL=http://localhost:5005/api

# Ecom API base URL — client-side (browser fetch)
NEXT_PUBLIC_ECOM_API_URL=http://localhost:5005/api

# Ecom backend base URL (used for product image / upload URLs)
NEXT_PUBLIC_ECOM_URL=http://localhost:5005

# Token for ISR /api/revalidate calls (must match ecom-backend REVALIDATE_SECRET)
REVALIDATE_SECRET=change_me_to_a_long_random_string

# Default store slug when no ?store= param and no hostname match (optional)
DEFAULT_STORE_SLUG=
