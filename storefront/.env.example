# ─── E-commerce API (server-side — getServerSideProps / getStaticProps) ─────
ECOM_API_URL=http://localhost:5005/api
# Production: ECOM_API_URL=https://shop-api.storeveu.com/api

# ─── E-commerce API (client-side — browser fetch) ──────────────────────────
NEXT_PUBLIC_ECOM_API_URL=http://localhost:5005/api
# Production: NEXT_PUBLIC_ECOM_API_URL=https://shop-api.storeveu.com/api

# ─── E-commerce Backend Base URL (for image/upload URLs) ───────────────────
NEXT_PUBLIC_ECOM_URL=http://localhost:5005
# Production: NEXT_PUBLIC_ECOM_URL=https://shop-api.storeveu.com

# ─── ISR Revalidation Secret ───────────────────────────────────────────────
# Must match ecom-backend REVALIDATE_SECRET
REVALIDATE_SECRET=any_random_secret_string

# ─── CardPointe Hosted iFrame (checkout payments) ──────────────────────────
NEXT_PUBLIC_CP_SITE=fts
NEXT_PUBLIC_CP_LIVE=false

# ─── Default Store Slug (Optional) ─────────────────────────────────────────
# If set, this store loads when no ?store= param and no hostname match
# DEFAULT_STORE_SLUG=my-store
