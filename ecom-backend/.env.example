# ─── Core ────────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# Postgres connection string (separate DB from POS backend)
DATABASE_URL=postgresql://user:password@localhost:5432/storeveu_ecom

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must match POS backend JWT_SECRET for shared customer auth
JWT_SECRET=your_jwt_secret_key_here
# Shared key for ecom-backend ↔ POS internal calls (must match POS INTERNAL_API_KEY)
INTERNAL_API_KEY=change_me_to_a_long_random_string

# ─── External services ───────────────────────────────────────────────────────
# POS backend URL (used for storefront pricing config + stock check)
POS_BACKEND_URL=http://localhost:5000
# Public storefront URL (used in order confirmation emails)
STOREFRONT_URL=http://localhost:3000
# Token sent to Next.js /api/revalidate for ISR cache busts
REVALIDATE_SECRET=change_me_to_a_long_random_string

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SUPPORT_EMAIL=
