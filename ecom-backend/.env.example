# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── E-commerce Database (separate from POS) ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/storeveu_ecom

# ─── POS Backend (for stock checks + JWT secret sharing) ────────────────────
POS_BACKEND_URL=http://localhost:5000
JWT_SECRET=your_jwt_secret_key_here

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Storefront (for ISR revalidation) ──────────────────────────────────────
STOREFRONT_URL=http://localhost:3000
REVALIDATE_SECRET=your_revalidate_secret_here

# ─── Cloudflare for SaaS (custom domains) ───────────────────────────────────
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─── Email / SMTP ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com