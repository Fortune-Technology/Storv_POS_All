# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Development:
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Production:
# CORS_ORIGIN=https://storeveu.com,https://shop.storeveu.com

# ─── E-commerce Database (separate from POS) ────────────────────────────────
# Create this database: CREATE DATABASE storeveu_ecom;
# Then run: cd ecom-backend && npx prisma db push
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_ecom"

# ─── POS Backend ────────────────────────────────────────────────────────────
# Development:
POS_BACKEND_URL=http://localhost:5000
# Production:
# POS_BACKEND_URL=https://api.storeveu.com

# ─── Authentication ─────────────────────────────────────────────────────────
# IMPORTANT: Must be the same value as backend/.env JWT_SECRET
JWT_SECRET=your_jwt_secret_key_here

# ─── Redis (Optional) ──────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Storefront (for ISR revalidation) ──────────────────────────────────────
# Development:
STOREFRONT_URL=http://localhost:3000
# Production:
# STOREFRONT_URL=https://shop.storeveu.com
REVALIDATE_SECRET=any_random_secret_string

# ─── Cloudflare for SaaS (Custom Domains — Production Only) ─────────────────
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─── Email / SMTP ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION URLS (copy-paste for deployment)
# ═══════════════════════════════════════════════════════════════════════════
#
# Backend API:        https://api.storeveu.com
# Dashboard/Portal:   https://storeveu.com
# POS Terminal:       https://pos.storeveu.com
# Admin Panel:        https://admin.storeveu.com
# E-com Backend:      https://shop-api.storeveu.com    ← THIS APP
# Storefront:         https://shop.storeveu.com
#
# ═══════════════════════════════════════════════════════════════════════════
