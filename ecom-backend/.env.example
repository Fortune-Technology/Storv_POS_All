# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Production: CORS_ORIGIN=https://storeveu.com,https://shop.storeveu.com

# ─── E-commerce Database (separate from POS DB) ────────────────────────────
# Create first: CREATE DATABASE storeveu_ecom; then run: npx prisma db push
DATABASE_URL="postgresql://user:password@localhost:5432/storeveu_ecom"

# ─── POS Backend (stock checks, product sync, customer auth) ───────────────
POS_BACKEND_URL=http://localhost:5000
# Production: POS_BACKEND_URL=https://api.storeveu.com

# ─── Authentication ─────────────────────────────────────────────────────────
# Must match backend/.env JWT_SECRET (customer JWT tokens are issued by the
# POS backend and verified here — same secret required).
JWT_SECRET=your_jwt_secret_key_here

# ─── Internal API Key (service-to-service calls to POS backend) ────────────
# REQUIRED — sent as X-Internal-Api-Key header on every stock-check call.
# Must match backend/.env INTERNAL_API_KEY exactly, otherwise online checkout
# fails with 401 at the stock verification step.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=your_internal_api_key

# ─── Redis (Optional — enables BullMQ async sync) ──────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Storefront (ISR on-demand revalidation) ───────────────────────────────
STOREFRONT_URL=http://localhost:3000
# Production: STOREFRONT_URL=https://shop.storeveu.com
REVALIDATE_SECRET=any_random_secret_string

# ─── Cloudflare for SaaS (custom domains — production only) ────────────────
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# ─── Email / SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@storeveu.com
SUPPORT_EMAIL=support@storeveu.com

# ─── Seed Scripts (Optional) ───────────────────────────────────────────────
# POS_DATABASE_URL=postgresql://user:pass@localhost:5432/storeveu_pos
# SEED_ORG_ID=your_org_id
# SEED_STORE_ID=your_store_id