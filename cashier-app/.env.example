# ─── POS Backend API ─────────────────────────────────────────────────────────
# Must point to backend /api endpoint
VITE_API_URL=http://localhost:5000/api
# Production: VITE_API_URL=https://api.storeveu.com/api
# ─── Dashboard / Portal URL (used by "Back Office" PIN-SSO from cashier) ──
VITE_PORTAL_URL=http://localhost:5173
# Production: VITE_PORTAL_URL=https://dashboard.storeveu.com

# Build modes:
#   npm run electron:dev           -> uses .env         -> localhost:5000
#   npm run electron:build:local   -> uses .env         -> localhost:5000
#   npm run electron:build         -> uses .env.production -> cloud backend

