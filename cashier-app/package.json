{
  "name": "futurefoods-cashier",
  "description": "StoreVeu Point of Sale Terminal",
  "author": "StoreVeu",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Fortune-Technology/Storv_POS_All.git"
  },
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron electron/main.cjs\"",
    "electron:dev:simulate-update": "concurrently \"vite\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development UPDATER_SIMULATE=1 electron electron/main.cjs\"",
    "version:bump": "node scripts/bumpVersion.mjs",
    "electron:build": "npm run version:bump && vite build && electron-builder",
    "electron:build:local": "npm run version:bump && vite build --mode development && electron-builder",
    "electron:build:no-bump": "vite build && electron-builder",
    "electron:pack": "electron-builder --dir",
    "electron:pack:local": "vite build --mode development && electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.8",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.454.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-toastify": "^11.0.5",
    "serialport": "^13.0.0",
    "storeveu-pos-platform": "file:..",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.storeveu.pos",
    "productName": "StoreVeu POS",
    "copyright": "Copyright © 2025 StoreVeu",
    "forceCodeSigning": false,
    "npmRebuild": true,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.*",
      "node_modules/serialport/**/*",
      "node_modules/@serialport/**/*"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/Fortune-Technology/Storv_POS_All/releases/download/latest-desktop",
        "channel": "latest",
        "useMultipleRangeRequest": false
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "StoreVeu.POS.Setup.${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "shortcutName": "StoreVeu POS"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
