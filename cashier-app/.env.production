# ─── Cashier App — Production Environment ──────────────────────────────────
# This URL is baked into the Vite bundle at build time.
#
# Build modes:
#   npm run electron:build         → uses THIS file  → points to cloud/production backend
#   npm run electron:build:local   → uses .env file  → points to localhost:5000 (for local installs)
#   npm run electron:dev           → uses .env file  → live-reloads from Vite dev server

VITE_API_URL=https://api.storeveu.com/api
