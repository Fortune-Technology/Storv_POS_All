# POS backend API base URL (used by footer's CMS pages list)
VITE_API_URL=http://localhost:5000/api

# Portal URL (cross-app links to /login, /signup, /portal/*)
VITE_PORTAL_URL=http://localhost:5173

# Public storefront URL (links from marketing → live customer storefront)
VITE_STOREFRONT_URL=http://localhost:3000

# Allow search engines to index this deploy (only true on the live site)
VITE_ALLOW_INDEXING=false

# Canonical site URL — used in sitemap.xml + canonical <link> tag
VITE_SITE_URL=https://storeveu.com
