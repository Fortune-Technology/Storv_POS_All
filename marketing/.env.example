# ─── POS Backend API ─────────────────────────────────────────────────────────
# Used by MarketingFooter to fetch the public CMS pages list (/api/public/cms-list).
VITE_API_URL=http://localhost:5000/api
# Production: VITE_API_URL=https://api.storeveu.com/api

# ─── Dashboard / Portal URL ────────────────────────────────────────────────
# Marketing site links to the dashboard app for: /login, /signup,
# /portal/realtime, /careers, /support, /privacy, /terms, /page/:slug, /shop.
# Set in dev when running on separate ports so cross-app links open the
# dashboard directly. In prod the dashboard lives on its own subdomain.
VITE_PORTAL_URL=http://localhost:5173
# Production: VITE_PORTAL_URL=https://dashboard.storeveu.com

# ─── E-commerce Storefront URL (cross-app links to the public shop) ────────
VITE_STOREFRONT_URL=http://localhost:3000
# Production: VITE_STOREFRONT_URL=https://shop.storeveu.com

# ─── POS Desktop Download (Download page CTAs) ─────────────────────────────
# VITE_POS_DOWNLOAD_URL=/downloads/StoreVeu-POS-Setup.exe
